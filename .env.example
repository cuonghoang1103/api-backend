# ============================================================
# CuongHoangDev API - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# IMPORTANT: For PRODUCTION deployment, copy this to .env.production
# and use: docker-compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# QUAN TRONG: Cac bien MOI TRUONG can phai duoc dien day du truoc khi deploy

# ============================================================
# 1. SERVER
# ============================================================
PORT=3001
NODE_ENV=development

# ============================================================
# 2. DATABASE (PostgreSQL + pgvector)
# ============================================================
# Local development
DATABASE_URL="postgresql://postgres:123456@localhost:5433/cuonghoangdev_db?schema=public"

# PRODUCTION: Override in .env.production
# DATABASE_URL se duoc tu dong build trong docker-compose.prod.yml
# DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres-db:5432/cuonghoangdev_db?schema=public&sslmode=prefer

# ============================================================
# 3. JWT AUTHENTICATION
# ============================================================
# PRODUCTION: Dung openssl rand -base64 64 de tao secret ngau nhien
JWT_SECRET="<generate-with-openssl-rand-base64-64>"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="<generate-with-openssl-rand-base64-64>"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================================
# 4. REDIS CACHE
# ============================================================
# Local development
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# PRODUCTION: Override in .env.production
# REDIS_URL=redis://redis-cache:6379

# ============================================================
# 5. CORS & FRONTEND
# ============================================================
FRONTEND_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000,https://cuonghoangdev.com,https://*.vercel.app"

# ============================================================
# 6. SESSION & COOKIES
# ============================================================
# PRODUCTION: Dung openssl rand -base64 32 de tao secret ngau nhien
COOKIE_SECRET="<generate-with-openssl-rand-base64-32>"

# ============================================================
# 7. FILE UPLOAD
# ============================================================
MAX_FILE_SIZE_IMAGES=10485760
MAX_FILE_SIZE_AUDIO=104857600
MAX_FILE_SIZE_VIDEO=524288000
MAX_FILE_SIZE_DOCUMENT=73400320
UPLOAD_DIR="./uploads"

# ============================================================
# 8. RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ============================================================
# 9. ADMIN ACCOUNTS
# ============================================================
ADMIN_EMAILS="cuongthaihnhe176322@gmail.com"
ADMIN_USERNAME="admin"

# ============================================================
# 10. HUGGING FACE AI (DeepSeek R1)
# ============================================================
# Su dung OpenAI-compatible API cua Hugging Face
# Token: get from https://huggingface.co/settings/tokens
OPENROUTER_API_KEY="your-huggingface-token-here"

# ============================================================
# 11. YOUTUBE DATA API
# ============================================================
# Lay API key tai: https://console.cloud.google.com/apis/credentials
# Su dung YouTube Data API v3 de tim kiem video nhac
YOUTUBE_API_KEY="your-youtube-api-key-here"

# ============================================================
# 12. FFMPEG (Audio Processing)
# ============================================================
# FFmpeg binary path — leave empty to auto-detect from PATH.
# If running in Docker, mount the FFmpeg binary or use a base image with FFmpeg.
# FFMPEG_PATH="/usr/bin/ffmpeg"
FFMPEG_PATH=""
FFMPEG_TIMEOUT_MS=120000

# yt-dlp binary path for the "Download YouTube track to site" music feature
# (POST /music/tracks/:id/download-audio). Leave empty/unset to use `yt-dlp`
# from PATH — the Docker runtime installs it to /usr/local/bin/yt-dlp.
# YT_DLP_PATH="yt-dlp"

# ============================================================
# 13. AI CONFIG DEFAULTS
# ============================================================
AI_CHAT_MODEL="deepseek-ai/DeepSeek-R1-Distill-Qwen-32B"
AI_EMBEDDING_MODEL="gemini-embedding-002"
AI_EMBEDDING_DIMENSIONS=768
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7
AI_CHUNK_SIZE=1000
AI_CHUNK_OVERLAP=200
AI_SIMILARITY_THRESHOLD=0.7

# ============================================================
# 12. OAUTH 2.0 (Google)
# ============================================================
# Lay OAuth credentials tai: https://console.cloud.google.com/
# Redirect URI: https://your-backend-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID="your-google-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-client-secret-here"

# ============================================================
# 13. OAUTH 2.0 (GitHub)
# ============================================================
# Register app tai: https://github.com/settings/applications/new
# Callback URL: https://your-backend-domain.com/api/auth/github/callback
GITHUB_CLIENT_ID="<your-github-oauth-app-client-id>"
GITHUB_CLIENT_SECRET="<your-github-oauth-app-client-secret>"

# ============================================================
# 14. EMAIL (for password reset, contact notifications)
# ============================================================
# Khuyen nghi: dung Gmail App Password hoac SendGrid/SES
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@cuonghoangdev.com"

# ─── Resend (RECOMMENDED for transactional email) ─────────
# Get API key: https://resend.com/api-keys (3,000 emails/month free)
# Verify your domain: https://resend.com/domains
# IMPORTANT: Resend requires a verified domain in production. For dev,
# you can use the sandbox sender onboarding@resend.dev (limited to your
# own verified email only).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="CuongHoangDev <noreply@cuongthai.com>"

# ============================================================
# 15. CONTACT FORM
# ============================================================
CONTACT_ADMIN_EMAIL="cuongthaihnhe176322@gmail.com"

# ============================================================
# 16. PRODUCTION SECRETS (for docker-compose.prod.yml)
# ============================================================
# CHI DUNG TRONG .env.production - KHONG BAO GIO COMMIT FILE NAY LEN GITHUB!

# Mat khau PostgreSQL (docker-compose.prod.yml requires this)
# POSTGRES_PASSWORD="your_super_secure_postgres_password_here"

# Ma hoac passphrase cho JWT (ngan hon, dung openssl rand -hex 32)
# JWT_SECRET="your-production-jwt-secret-min-32-chars-here"
# JWT_REFRESH_SECRET="your-production-refresh-secret-min-32-chars-here"

# Cookie signing secret (dung openssl rand -base64 32)
# COOKIE_SECRET="your-production-cookie-secret-here"

# ============================================================
# 17. OPTIONAL: Debug
# ============================================================
# DEBUG_SQL="true"
# DEBUG_LOGGING="true"

# ─── Quota / Rate-limit per user (Mục #4) ───
QUOTA_PER_MINUTE=30
QUOTA_PER_DAY=500
QUOTA_PER_MONTH=10000

# ============================================================
# 18a. PAYOS PAYMENT (Course checkout — PRIMARY gateway)
# ============================================================
# Dang ky merchant tai: https://payos.vn  → tao Kenh thanh toan →
# lay Client ID, API Key, Checksum Key trong muc "Cong tich hop".
# Webhook URL (khai bao trong dashboard PayOS):
#   https://cuongthai.com/api/v1/payments/payos/webhook
PAYOS_CLIENT_ID="REPLACE_WITH_PAYOS_CLIENT_ID"
PAYOS_API_KEY="REPLACE_WITH_PAYOS_API_KEY"
PAYOS_CHECKSUM_KEY="REPLACE_WITH_PAYOS_CHECKSUM_KEY"

# ============================================================
# 18. VNPAY PAYMENT (Course checkout — secondary/fallback)
# ============================================================
# Dang ky sandbox tai: https://sandbox.vnpayment.vn/devreg
# Lay TMN_CODE va HASH_SECRET tu email sau khi dang ky.
# Production: doi sang https://pay.vnpayment.vn va lay credentials that.
VNPAY_TMN_CODE="REPLACE_WITH_SANDBOX_TMN_CODE"
VNPAY_HASH_SECRET="REPLACE_WITH_SANDBOX_HASH_SECRET"
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
# URL ma VNPay redirect user ve sau khi thanh toan (frontend page)
VNPAY_RETURN_URL="https://cuongthai.com/payment/return"
# URL server-to-server IPN callback (backend xu ly)
VNPAY_IPN_URL="https://cuongthai.com/api/v1/payments/vnpay/ipn"
VNPAY_VERSION="2.1.0"
# Set =1 in dev/sandbox to skip the IP allowlist check (sandbox IPs
# are not in the production allowlist). MUST be 0/unset in production.
VNPAY_SANDBOX="1"
# Order TTL — pending orders older than this are considered expired
# and the user must create a new one. Default 15 minutes.
VNPAY_ORDER_TTL_MINUTES="15"
# Optional: override VNPay production IP allowlist (comma-separated CIDR).
# Default includes the most common ranges; extend if VNPay adds more.
# VNPAY_IP_ALLOWLIST="203.171.20.0/24,123.30.235.0/24"

# ============================================================
# 19. SENTRY (Error Tracking)
# ============================================================
# Get your DSN from: https://sentry.io/settings/.../projects/.../keys/
# When DSN is empty, Sentry is disabled and the app behaves exactly
# as before — no overhead, no network calls.
#
# Backend DSN (Node/Express):
SENTRY_DSN=""
# Frontend DSN (Next.js browser) — get a separate project for the
# frontend, or reuse the same DSN if you want events merged.
# (Read on the client as NEXT_PUBLIC_SENTRY_DSN.)
NEXT_PUBLIC_SENTRY_DSN=""

# Sample 10% of transactions. Lower = cheaper. Set 0 to disable perf
# monitoring but keep error capture.
SENTRY_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"

# Environment label (e.g. "production", "staging"). Defaults to NODE_ENV.
# SENTRY_ENVIRONMENT=""
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=""

# Release identifier (e.g. git SHA). Helps correlate errors with deploys.
# SENTRY_RELEASE=""
# NEXT_PUBLIC_SENTRY_RELEASE=""


# ─── Interview Simulator — LLM layer (Phase 4) ───────────────────
# All optional. With no ANTHROPIC_API_KEY the module runs in STATIC mode
# (self-assessment, zero LLM). Add the key + set DEFAULT_ENGINE_MODE=HYBRID
# to enable AI grading. These live in runtime env (VPS /opt/cuonghoangdev/.env).
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL_INTERVIEW=claude-haiku-4-5      # cheaper model for turn-by-turn grading
LLM_MODEL_REPORT=claude-opus-4-8          # stronger model for the final report
LLM_MODEL_GENERATION=claude-sonnet-5      # admin AI question generation (later)
DEFAULT_ENGINE_MODE=STATIC                # STATIC | HYBRID | FULL_AI (default when user doesn't pick)
FORCE_STATIC_MODE=false                   # kill switch: disable ALL LLM calls platform-wide
SCORE_REDFLAG_PENALTY=15                  # points deducted per factual red flag
SCORE_DISAGREEMENT_THRESHOLD=35           # flag a turn for review when Pass A vs AI diverge by this much
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=3
INTERVIEW_DAILY_TOKEN_CAP=                # per-user daily token cap (blank = unlimited)
DRILL_DAILY_CARD_LIMIT=20
