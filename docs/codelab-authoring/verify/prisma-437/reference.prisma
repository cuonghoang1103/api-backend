generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:x@localhost:55432/prisma_codelab"
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  name      String
  tenantId  Int
  deletedAt DateTime?
  posts     Post[]
}

model Post {
  id        Int       @id @default(autoincrement())
  title     String    @unique
  views     Int       @default(0)
  tenantId  Int
  deletedAt DateTime?
  authorId  Int
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Account {
  id      Int    @id @default(autoincrement())
  owner   String @unique
  balance Int
}
