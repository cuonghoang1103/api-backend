# Frontend Docker build context
node_modules
npm-debug.log*
yarn-error.log*
.env.local
.env.development
.env.production.local
.vercel

# .next/ build cache — exclude these
.next/cache
.next/server
.next/BUILD_ID
.next/turbopack
.nextTrace-*
.next/future/
.next/image/

# Keep what the standalone runtime needs
!.next/standalone
!.next/standalone/**
!.next/static
!.next/static/**