# ─── Database (NextAuth) ───────────────────────────────────────────────
# Shared NeonDB — used by both frontend (NextAuth) and backend (Spring Boot)
# Get connection string from: https://neon.tech → your project → Connection Details
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth Configuration ───────────────────────────────────────────
# NEXTAUTH_URL is auto-detected in most deployments (Vercel, etc.)
# Only set this explicitly if you encounter redirect issues in local dev.
NEXTAUTH_URL=http://localhost:3000

# AUTH_SECRET — REQUIRED. Generate with:
#   openssl rand -base64 32
# This replaces NEXTAUTH_SECRET from v4.
AUTH_SECRET="replace-with-your-generated-secret-key"

# ─── OAuth Providers ────────────────────────────────────────────────────
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Facebook: https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret

# ─── Admin Configuration ────────────────────────────────────────────────
# Comma-separated list of emails that get ADMIN role on login
# Example: admin@example.com,another-admin@gmail.com
ADMIN_EMAILS=cuongthaihnhe176322@gmail.com

# ─── API Configuration ─────────────────────────────────────────────────
# Backend URL — used for local dev only
# On Vercel, set NEXT_PUBLIC_API_URL to your Render backend URL
NEXT_PUBLIC_API_URL=http://localhost:8082

# ─── YouTube Data API ──────────────────────────────────────────────────
# Get key from: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your project
NEXT_PUBLIC_YOUTUBE_API_KEY=AIzaSyDSDK6Lb6uEDYUWXoRbMRcVLhE5g-pj8Rw

# ─── Sentry (Frontend Error Tracking) ───────────────────────────────────
# Get your DSN from: https://sentry.io/settings/.../projects/.../keys/
# When DSN is empty, Sentry is disabled and the app behaves exactly
# as before — no overhead, no network calls.
NEXT_PUBLIC_SENTRY_DSN=""

# Sample 10% of transactions. Lower = cheaper.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"

# Environment label (e.g. "production", "staging"). Defaults to NODE_ENV.
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=""

# Release identifier (e.g. git SHA). Helps correlate errors with deploys.
# NEXT_PUBLIC_SENTRY_RELEASE=""
