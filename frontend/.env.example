# ─── Database (NextAuth) ───────────────────────────────────────────────
# Shared NeonDB — used by both frontend (NextAuth) and backend (Node.js)
# Get connection string from: https://neon.tech → your project → Connection Details
# KHONG CAN THIET cho NextAuth JWT strategy (hien tai), chi can neu chuyen sang database strategy
# DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth Configuration ───────────────────────────────────────────
# Domain production: https://cuongthai.com
# Trong Docker compose, set NEXTAUTH_URL = https://cuongthai.com
# Khi dev local (ngoai Docker), set = http://localhost:3000
NEXTAUTH_URL=https://cuongthai.com

# AUTH_SECRET — REQUIRED. Generate with:
#   openssl rand -base64 32
# This replaces NEXTAUTH_SECRET from v4.
AUTH_SECRET="replace-with-your-generated-secret-key"

# ─── OAuth Providers ────────────────────────────────────────────────────
# Google: https://console.cloud.google.com/apis/credentials
#   1. Tạo project mới hoặc chọn project có sẵn
#   2. APIs & Services → Credentials → Create Credentials → OAuth client ID
#   3. Application type: Web application
#   4. Authorized JavaScript origins:
#        - http://localhost:3000 (dev)
#        - https://cuongthai.com (prod)
#   5. Authorized redirect URIs:
#        - http://localhost:3000/api/auth/callback/google (dev)
#        - https://cuongthai.com/api/auth/callback/google (prod)
#   6. Copy Client ID + Client Secret paste vào /opt/cuonghoangdev/.env (VPS)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub: https://github.com/settings/developers
#   1. New OAuth App
#   2. Homepage URL: https://cuongthai.com
#   3. Authorization callback URL:
#        - http://localhost:3000/api/auth/callback/github (dev)
#        - https://cuongthai.com/api/auth/callback/github (prod)
#   4. Generate a new client secret, paste vào /opt/cuonghoangdev/.env
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Facebook: https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret

# ─── Admin Configuration ────────────────────────────────────────────────
# Comma-separated list of emails that get ADMIN role on login
# Example: admin@example.com,another-admin@gmail.com
ADMIN_EMAILS=cuongthaihnhe176322@gmail.com

# ─── API Configuration ─────────────────────────────────────────────────
# Backend URL — dùng cho /api/auth/oauth/token proxy
# - Local dev: http://localhost:3001
# - Production: https://api.cuongthai.com (cùng domain, khác subdomain)
NEXT_PUBLIC_API_URL=https://api.cuongthai.com
BACKEND_URL=https://api.cuongthai.com

# ─── YouTube Data API ──────────────────────────────────────────────────
# Get key from: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your project
NEXT_PUBLIC_YOUTUBE_API_KEY=AIzaSyDSDK6Lb6uEDYUWXoRbMRcVLhE5g-pj8Rw
