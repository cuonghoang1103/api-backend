{
  "name": "cuonghoangdev-api",
  "version": "2.0.0",
  "type": "module",
  "description": "Node.js/TypeScript/Express Backend for CuongHoangDev Portfolio",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:debug": "tsx watch --inspect src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "migrate:r2": "tsx scripts/migrate-to-r2.ts",
    "migrate:r2:dry": "tsx scripts/migrate-to-r2.ts --dry-run",
    "test:smoke": "tsx scripts/test-all.ts",
    "test:image": "tsx scripts/test-image-optimizer.ts",
    "test:r2": "tsx scripts/test-r2.ts",
    "test:pipeline": "tsx scripts/test-pipeline.ts",
    "test:migration": "tsx scripts/test-migration.ts",
    "test:music": "tsx scripts/test-music-stream.ts",
    "test:music:cyber": "tsx scripts/test-music-cyber.ts",
    "test:listen": "tsx scripts/test-listen-together.ts",
    "test:errors": "tsx scripts/test-errors.ts",
    "test:cdn": "tsx scripts/test-cdn.ts"
  },
  "keywords": [
    "portfolio",
    "api",
    "express",
    "typescript",
    "prisma",
    "postgresql"
  ],
  "author": "CuongHoangDev",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@aws-sdk/s3-request-presigner": "^3.1071.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^7.120.4",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "node-cron": "^3.0.3",
    "openai": "^4.77.0",
    "pgvector": "0.3.0",
    "redis": "^4.7.1",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "resend": "^6.12.4",
    "sharp": "^0.35.1",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "uuid": "^10.0.0",
    "vnpay": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.19.20",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "playwright": "^1.61.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
