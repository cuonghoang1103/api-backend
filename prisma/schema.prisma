// ============================================================
// CuongHoangDev API - Prisma Schema
// Source of truth for the Node.js backend runtime.
// Database: PostgreSQL with pgvector extension
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. USERS & AUTHENTICATION
// ============================================================

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique(map: "roles_name_key") @db.VarChar(50)

  users UserRole[]

  @@map("roles")
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique(map: "uk_user_username") @db.VarChar(50)
  password      String?   @db.VarChar(255)
  email         String    @unique(map: "uk_user_email") @db.VarChar(100)
  fullName      String?   @map("full_name") @db.VarChar(100)
  bio           String?   @db.Text
  avatarUrl     String?   @map("avatar_url") @db.VarChar(500)
  coverPhotoUrl String?   @map("cover_photo_url") @db.VarChar(500)
  lastActiveAt  DateTime? @map("last_active_at")

  // ─── Extended profile (Phase 1) ─────────────────────────
  // displayName: tên hiển thị (có thể khác username, dùng cho UI
  // trên header feed). Null → fallback về fullName → username.
  displayName        String?      @map("display_name") @db.VarChar(100)
  // gender: 'MALE' | 'FEMALE' | 'OTHER' | null (tuỳ chọn).
  gender             String?      @db.VarChar(20)
  // birthYear: năm sinh 4 chữ số (1900..currentYear). Null nếu user
  // không muốn tiết lộ. Lưu riêng năm (không phải full DOB) để
  // giảm thiểu PII và dễ tính tuổi trên feed.
  birthYear          Int?         @map("birth_year")
  // phone: optional, không bắt buộc (giữ nguyên pattern 10-15 số
  // quốc tế). Không dùng cho 2FA trong phase này.
  phone              String?      @db.VarChar(20)
  // socialLinks: JSON map { github?, twitter?, linkedin?, website?, youtube?, facebook? }
  // — schema-free, mỗi frontend tự định nghĩa key khi đọc.
  socialLinks        Json?        @map("social_links")
  // Phase 3 add — back-relation for the new SocialLink model.
  // Kept separate from the legacy JSON column above so we don't
  // break existing data; the mobile route uses this relation.
  socialLinkProfiles SocialLink[]

  enabled               Boolean @default(true)
  accountNonExpired     Boolean @default(true) @map("account_non_expired")
  accountNonLocked      Boolean @default(true) @map("account_non_locked")
  credentialsNonExpired Boolean @default(true) @map("credentials_non_expired")

  // Per-user access to the /music page, used when the global music
  // access mode (AppSetting "music_access_mode") is SPECIFIC. Admins
  // always have access regardless of this flag.
  musicAccess Boolean @default(false) @map("music_access")

  // ─── Pro membership (unlocks music page, AI chat Pro/Max, Interview AI
  //     grading, full Academy). Admins are always effectively Pro regardless.
  //     `proExpiresAt` null while isPro=true means a LIFETIME membership. ─────
  isPro        Boolean   @default(false) @map("is_pro")
  proSince     DateTime? @map("pro_since")
  proExpiresAt DateTime? @map("pro_expires_at")
  proSource    String?   @map("pro_source") @db.VarChar(20) // CODE | ADMIN

  // ─── Account security (Giai đoạn 1 — bảo mật cao) ────────────────────
  // Email verification
  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")

  // Account lockout (sau 5 lần nhập sai → khoá 15 phút)
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lockoutUntil      DateTime? @map("lockout_until")
  lastFailedLoginAt DateTime? @map("last_failed_login_at")

  // Login tracking (phát hiện thiết bị lạ)
  lastLoginAt        DateTime? @map("last_login_at")
  lastLoginIp        String?   @map("last_login_ip") @db.VarChar(64)
  lastLoginUserAgent String?   @map("last_login_user_agent") @db.VarChar(500)
  // Theme preference: dark or light
  theme              String?   @default("dark") @map("theme") @db.VarChar(10)

  provider   String? @db.VarChar(50)
  providerId String? @map("provider_id") @db.VarChar(255)

  roleVersion BigInt @default(0) @map("role_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roles                   UserRole[]
  posts                   Post[]                   @relation("PostAuthor")
  courses                 Course[]                 @relation("CourseInstructor")
  enrollments             Enrollment[]
  certificates            Certificate[]
  musicPlaylists          MusicPlaylist[]
  // Cyber-music Phase 1: per-user play queue (idempotent upsert).
  musicQueueItems         MusicQueueItem[]
  // Cyber-music Phase 2a: per-user likes + play counts (additive).
  musicLikes              MusicLike[]
  musicPlayCounts         MusicPlayCount[]
  fileAttachments         FileAttachment[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  blogComments            Comment[]
  devPostComments         PostComment[]
  courseReviews           CourseReview[]
  productReviews          ProductReview[]
  shopOrders              ShopOrder[]
  courseOrders            CourseOrder[]
  refundedCourseOrders    CourseOrder[]            @relation("CourseOrderRefunder")
  chatSessions            ChatSession[]
  chatFeedback            ChatFeedback[]
  assignmentSubmissions   AssignmentSubmission[]
  aiConfigUpdates         AiConfig[]               @relation("AiConfigUpdater")
  musicHistories          MusicHistory[]
  socialPosts             SocialPost[]
  socialLikes             SocialLike[]
  socialComments          SocialComment[]
  socialCommentLikes      SocialCommentLike[]
  socialSaves             SocialSave[]
  socialShares            SocialShare[]
  // Saved Collections (multi-folder bookmark system). The
  // relation `feedCollections` is the list of collections
  // the user OWNS. The relation `feedSavedPosts` is the
  // junction table that stores which posts they've saved
  // into which collections.
  feedCollections         FeedCollection[]         @relation("FeedCollectionOwner")
  feedSavedPosts          FeedSavedPost[]
  // Stories (Phase 6)
  stories                 Story[]
  storyHighlights         StoryHighlight[]
  storyViews              StoryView[]
  storyHides              StoryHide[]

  // Notification graph — who is the receiver / sender on social
  // notifications. The reverse relations are defined on
  // SocialNotification above.
  socialNotificationsReceived SocialNotification[]   @relation("NotificationsReceived")
  socialNotificationsSent     SocialNotification[]   @relation("NotificationsSent")
  socialPollVotes             SocialPollVote[]
  techTrendArticles           TechTrendArticle[]     @relation("TechTrendAuthor")
  techTrendComments           TechTrendComment[]
  techTrendCommentLikes       TechTrendCommentLike[]
  gamePlays                   GamePlay[]
  announcements               Announcement[]         @relation("AnnouncementAuthor")

  cyberProfile   CyberProfile?
  cyberTasks     CyberTask[]
  cyberInventory CyberInventory?
  discountCodes  DiscountCode[]
  savedCodes     UserSavedCode[]

  // ─── Direct messaging (Phase 6) ─────────────────────────
  // Per-user flag controlling whether strangers (users with no
  // prior interaction) can start a new conversation. Default on;
  // users can flip it off in /profile settings. Admins and users
  // the viewer has already exchanged messages with bypass this
  // check — the flag only gates the very first contact.
  allowMessagesFromStrangers Boolean @default(true) @map("allow_messages_from_strangers")

  messageThreadsAsUser  MessageThread[]   @relation("ThreadAsUser")
  messageThreadsAsAdmin MessageThread[]   @relation("ThreadAsAdmin")
  messageThreadsAsUserA MessageThread[]   @relation("ThreadUserA")
  messageThreadsAsUserB MessageThread[]   @relation("ThreadUserB")
  messagesSent          Message[]         @relation("MessageSender")
  messageReads          MessageRead[]     @relation("MessageReadUser")
  nicknamesOwned        ThreadNickname[]  @relation("NicknameOwner")
  nicknamesTargeted     ThreadNickname[]  @relation("NicknameTarget")
  reactions             MessageReaction[] @relation("ReactionUser")
  blocksCreated         UserBlock[]       @relation("UserBlocksCreated")
  blocksReceived        UserBlock[]       @relation("UserBlocksReceived")
  reportsFiled          ThreadReport[]    @relation("ThreadReportsFiled")
  reportsResolved       ThreadReport[]    @relation("ThreadReportsResolved")

  // ─── Personal dashboard (per-user, never deleted) ────────
  // Each user owns exactly one DashboardState row. The 1:N
  // dashboardTasks relation stores both active and archived
  // (soft-deleted) tasks — see DashboardTask.archivedAt below.
  // We persist state on the server (instead of just localStorage)
  // so the dashboard follows the user across devices, survives
  // cache clears, and is recoverable from the DB if the client
  // gets wiped. Server is the source of truth; the client still
  // keeps a localStorage mirror for offline-first behavior.
  dashboardState        DashboardState?
  dashboardTasks        DashboardTask[]
  dashboardCelebrations DashboardCelebration[]

  // ─── Personal Hub — bookmark manager (Phase 7) ─────
  // User-owned folders + links. Every row is scoped by userId;
  // all routes put `userId` in their WHERE clause to prevent
  // cross-tenant reads. Cascade on delete so removing a user
  // takes their Hub data with it (no orphans).
  hubFolders          HubFolder[]
  hubLinks            HubLink[]
  hubFiles            HubFile[]
  langNotebookFolders LangNotebookFolder[] @relation("UserLangNotebookFolders")
  langNotebookEntries LangNotebookEntry[]  @relation("UserLangNotebookEntries")
  // Hub user-sharing (Phase 2): the rows where this user is
  // the owner (gave access) or the recipient (got access). Two
  // named relations because Prisma requires a unique name per
  // FK even when the target model is the same.
  hubSharesOwned      HubShare[]           @relation("HubShareOwner")
  hubSharesReceived   HubShare[]           @relation("HubShareRecipient")

  // ─── Voice Hub (admin creator channel — vlog/reaction/code-exp/podcast) ─
  voicePosts        VoicePost[]        @relation("VoicePostAuthor")
  voiceComments     VoiceComment[]
  voiceCommentLikes VoiceCommentLike[]
  voiceLikes        VoiceLike[]

  // ─── Orphaned upload cleanup (Phase 7) ─────────────────────────
  // PendingUpload rows track video uploads that have been started
  // but not yet linked to a post. Cron job cleans up expired rows.
  pendingUploads PendingUpload[]

  // Phase 4 add — Music Post. Admin uploads mp3 / m4a tracks
  // to R2 and tags them with a title + artist + cover. Users
  // pick one of these from the composer and clip a 1-second-
  // resolution snippet (< 40s) onto their post. We use Restrict
  // (not Cascade) on uploader so deleting the original admin
  // doesn't silently wipe every post that referenced the track.
  songsUploaded Song[]       @relation("SongUploader")
  // Phase 4 add — extended profile (bio, cover photo, location,
  // education, work, links). Optional 1-1 with user so legacy
  // rows keep working — defaults fill in on the next read.
  profile       UserProfile?

  // ─── Notes — personal study notebooks ──────────────────

  // ─── Notes — personal study notebooks ──────────────────
  // User-owned subjects → chapters → notes (+ attachments,
  // links, vocab). Same per-user scoping rule as Hub: every
  // row carries userId and every query filters on it. Cascade
  // on delete so removing a user removes their notes.
  noteSubjects               NoteSubject[]
  noteChapters               NoteChapter[]
  notes                      Note[]
  noteAttachments            NoteAttachment[]
  noteLinks                  NoteLink[]
  noteVocabEntries           NoteVocabEntry[]
  // Phase 4 add — notes subject sharing
  noteSubjectsOwned          NoteSubjectShare[]          @relation("NoteSubjectSharesOwned")
  noteSubjectsReceived       NoteSubjectShare[]          @relation("NoteSubjectSharesReceived")
  noteSubjectShareRecipients NoteSubjectShareRecipient[] @relation("UserShareRecipients")

  // ─── Social Follow Graph ────────────────────────────────
  following         Follow[]           @relation("Following")
  followers         Follow[]           @relation("Followers")
  // Phase 3: Post actions back-relations
  postFeedbacks     PostFeedback[]
  postNotifications PostNotification[]
  postReports       PostReport[]       @relation("PostReports")
  snoozesGiven      UserSnooze[]       @relation("Snoozer")
  snoozesReceived   UserSnooze[]       @relation("SnoozedBy")
  postArchives      PostArchive[]

  // ─── Friend Graph (two-way, FB-style requests) ──────────
  // Additive alongside the follow graph above. `friendshipsSent`
  // are rows where this user is the requester; `friendshipsReceived`
  // are rows where this user is the addressee (the one who
  // accepts/declines). See model Friendship below.
  friendshipsSent     Friendship[] @relation("FriendshipsSent")
  friendshipsReceived Friendship[] @relation("FriendshipsReceived")

  // Sticker packs this user (an admin) created.
  stickerPacksCreated StickerPack[] @relation("StickerPacksCreated")

  // ─── EXP_Hub — Snippet Library ──────────────────────────────
  // Snippets authored by this user
  snippets                Snippet[]
  // Bookmarks saved by this user (authenticated)
  snippetBookmarks        SnippetBookmark[]
  // Upvotes by this user (authenticated)
  snippetUpvotes          SnippetUpvote[]
  // Comments on snippets
  snippetComments         SnippetComment[]
  // Webhooks configured by this user
  snippetWebhooks         SnippetWebhook[]
  SnippetVersion          SnippetVersion[]
  // Emoji reactions on snippets / snippet comments
  snippetReactions        SnippetReaction[]
  snippetCommentReactions SnippetCommentReaction[]

  // ─── Code Lab — authored exercises + personal practice progress ──
  codeExercises CodeExercise[]
  codeProgress  CodeProgress[]

  // ─── My Language — learning progress (per-user, SRS) ─────────
  // Additive. Every row is scoped by userId; SM-2 spaced repetition
  // progress + quiz history live here. See models at end of file.
  languageProgress     LangUserProgress[]
  languageQuizzes      LangQuizResult[]
  langVocabFavorites   LangVocabFavorite[]
  langVocabCollections LangVocabCollection[]
  langRoadmapDone      LangRoadmapDone[]
  langGameStates       LangGameState[]
  langLessonProgress   LangLessonProgress[]

  @@index([email], name: "idx_users_email")
  @@map("users")
}

model UserRole {
  userId Int
  roleId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId], map: "pk_user_roles")
  @@map("user_roles")
}

// Generic site-wide key/value settings. Currently holds
// "music_access_mode" (ADMIN_ONLY | SPECIFIC | EVERYONE) governing
// who can see the /music page. Reusable for future global toggles.
model AppSetting {
  key       String   @id @db.VarChar(100)
  value     String?  @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ─── Pro membership codes (global entitlement, unlike per-course CourseCode) ──
// An admin creates a ProCode with an optional duration (null = lifetime) and a
// use cap; a user redeems it to become Pro. Mirrors the CourseCode redeem
// pattern but grants an account-wide flag instead of a per-course enrollment.
model ProCode {
  id           Int             @id @default(autoincrement())
  code         String          @unique @db.VarChar(40)
  label        String?         @db.VarChar(120)
  durationDays Int?            @map("duration_days") // null = lifetime
  maxUses      Int             @default(1) @map("max_uses")
  usedCount    Int             @default(0) @map("used_count")
  isActive     Boolean         @default(true) @map("is_active")
  expiresAt    DateTime?       @map("expires_at") // the code's own validity window
  note         String?         @db.VarChar(255)
  createdBy    Int?            @map("created_by") // admin userId (no FK, matches interview convention)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  redemptions  ProRedemption[]

  @@map("pro_codes")
}

model ProRedemption {
  id          Int      @id @default(autoincrement())
  proCodeId   Int      @map("pro_code_id")
  userId      Int      @map("user_id") // no FK (matches interview convention)
  grantedDays Int?     @map("granted_days") // snapshot; null = lifetime
  createdAt   DateTime @default(now()) @map("created_at")
  proCode     ProCode  @relation(fields: [proCodeId], references: [id], onDelete: Cascade)

  @@unique([proCodeId, userId], name: "uk_pro_redemption")
  @@map("pro_redemptions")
}

// ============================================================
// 2. PASSWORD RESET
// ============================================================

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique(map: "uk_password_reset_token") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token], name: "idx_password_reset_tokens_token")
  @@index([userId], name: "idx_password_reset_tokens_user_id")
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  email     String   @db.VarChar(100)
  token     String   @unique(map: "uk_email_verification_token") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token], name: "idx_email_verification_tokens_token")
  @@index([userId], name: "idx_email_verification_tokens_user_id")
  @@map("email_verification_tokens")
}

// ============================================================
// 2b. CYBER GAMIFICATION
// ============================================================

enum CyberTaskType {
  TASK
  STUDY
  ROUTINE
}

model CyberProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique @map("user_id")
  level       Int      @default(1)
  currentExp  Int      @default(0) @map("current_exp")
  totalPoints Int      @default(0) @map("total_points")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cyber_profiles")
}

model CyberTask {
  id          Int           @id @default(autoincrement())
  userId      Int           @map("user_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String        @db.VarChar(255)
  description String?       @db.Text
  type        CyberTaskType @default(TASK)
  startTime   String        @map("start_time") @db.VarChar(5)
  endTime     String        @map("end_time") @db.VarChar(5)
  isCompleted Boolean       @default(false) @map("is_completed")
  expReward   Int           @default(10) @map("exp_reward")
  date        DateTime      @db.Date
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([userId, date], name: "idx_cyber_tasks_user_date")
  @@map("cyber_tasks")
}

model CyberInventory {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointBalance Int      @default(0) @map("point_balance")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("cyber_inventories")
}

// ============================================================
// 3. FILE ATTACHMENTS
// ============================================================

model FileAttachment {
  id           Int      @id @default(autoincrement())
  originalName String   @map("original_name") @db.VarChar(255)
  storedName   String   @map("stored_name") @db.VarChar(255)
  filePath     String   @map("file_path") @db.VarChar(500)
  contentType  String   @map("content_type") @db.VarChar(100)
  fileSize     BigInt   @map("file_size")
  uploadedBy   Int?     @map("uploaded_by")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")
  fileCategory String?  @map("file_category") @db.VarChar(50)

  uploader           User?               @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)
  messageAttachments MessageAttachment[]

  @@index([uploadedBy], name: "idx_file_attachments_uploaded_by")
  @@index([fileCategory], name: "idx_file_attachments_file_category")
  @@index([storedName], name: "idx_file_attachments_stored_name")
  @@map("file_attachments")
}

// ============================================================
// 4. BLOG MODULE
// ============================================================

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique(map: "uk_category_name") @db.VarChar(100)
  slug        String   @unique(map: "uk_category_slug") @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  posts Post[]

  @@map("categories")
}

model Post {
  id            Int       @id @default(autoincrement())
  title         String    @db.VarChar(255)
  slug          String    @unique(map: "uk_post_slug") @db.VarChar(255)
  excerpt       String?   @db.Text
  content       String    @db.Text
  thumbnailUrl  String?   @map("thumbnail_url") @db.VarChar(500)
  status        String    @default("DRAFT") @db.VarChar(20)
  categoryId    Int?      @map("category_id")
  authorId      Int?      @map("author_id")
  viewCount     Int       @default(0) @map("view_count")
  isFeatured    Boolean   @default(false) @map("is_featured")
  publishedAt   DateTime? @map("published_at")
  sourceUrl     String?   @map("source_url") @db.VarChar(555)
  downloadCount Int       @default(0) @map("download_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author   User?     @relation("PostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  tags     PostTag[]
  comments Comment[]

  @@index([categoryId], name: "idx_posts_category_id")
  @@index([authorId], name: "idx_posts_author_id")
  @@index([status], name: "idx_posts_status")
  @@index([publishedAt(sort: Desc)], name: "idx_posts_published_at")
  @@index([isFeatured], name: "idx_posts_is_featured")
  @@map("posts")
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique(map: "uk_tag_name") @db.VarChar(50)
  slug      String   @unique(map: "uk_tag_slug") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  posts PostTag[]
  // Many-to-many back-relation to GithubRepo through GithubRepoTag.
  // Same tag taxonomy as blog posts so users can navigate by
  // topic (Backend, Frontend, Clean Architecture, Payment, etc.)
  // across both surfaces without re-tagging.
  repos GithubRepoTag[]

  @@index([slug], name: "idx_tags_slug")
  @@map("tags")
}

model PostTag {
  postId Int
  tagId  Int

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId], map: "pk_post_tags")
  @@map("post_tags")
}

model Comment {
  id          Int      @id @default(autoincrement())
  postId      Int?     @map("post_id")
  userId      Int?     @map("user_id")
  userName    String   @map("user_name") @db.VarChar(100)
  userAvatar  String?  @map("user_avatar") @db.VarChar(255)
  commentText String   @map("comment_text") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  post Post? @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([postId], name: "idx_comments_post_id")
  @@map("comments")
}

// ============================================================
// 5. SKILLS & PROJECTS
// ============================================================

model Skill {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  slug            String   @unique(map: "uk_skill_slug") @db.VarChar(100)
  category        String?  @db.VarChar(50)
  proficiency     Int      @default(3)
  description     String?  @db.Text
  yearsExperience Int      @default(0) @map("years_experience")
  isFeatured      Boolean  @default(false) @map("is_featured")
  displayOrder    Int      @default(0) @map("display_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  projects ProjectSkill[]

  @@index([category], name: "idx_skills_category")
  @@index([isFeatured], name: "idx_skills_is_featured")
  @@index([displayOrder], name: "idx_skills_display_order")
  @@map("skills")
}

model Project {
  id           Int       @id @default(autoincrement())
  title        String    @db.VarChar(255)
  slug         String    @unique(map: "uk_project_slug") @db.VarChar(255)
  description  String?   @db.Text
  content      String?   @db.Text
  thumbnailUrl String?   @map("thumbnail_url") @db.VarChar(500)
  images       String?   @db.Text
  projectUrl   String?   @map("project_url") @db.VarChar(500)
  videoUrl     String?   @map("video_url") @db.VarChar(500)
  githubUrl    String?   @map("github_url") @db.VarChar(500)
  techStack    String?   @map("tech_stack") @db.Text
  role         String?   @db.VarChar(100)
  duration     String?   @db.VarChar(100)
  status       String    @default("COMPLETED") @db.VarChar(20)
  isFeatured   Boolean   @default(false) @map("is_featured")
  startDate    DateTime? @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date
  // ─── Case study / build log fields (Phase 2, additive) ───
  // category — free-form string ("Web", "AI", "DevOps"…).
  // difficulty — BEGINNER | INTERMEDIATE | ADVANCED.
  // bodyMdx — Markdown source of truth.
  // bodyHtml — server-rendered cache of bodyMdx; backfilled
  // lazily on first public read if empty.
  // schemaCode / schemaLang — optional code block for the
  // "Database Schema" section on the case-study page.
  // viewCount — denormalised counter, fire-and-forget on
  // public detail reads. Not transactional.
  // likeCount — denormalised counter for anonymous likes,
  // kept consistent with project_likes table by routes.
  // isPublished — admin can flip to false to hide a project
  // without deleting it; defaults to true so existing
  // projects stay public.
  category     String?   @db.VarChar(80)
  difficulty   String?   @db.VarChar(20)
  bodyMdx      String?   @map("body_mdx") @db.Text
  bodyHtml     String?   @map("body_html") @db.Text
  schemaCode   String?   @map("schema_code") @db.Text
  schemaLang   String?   @map("schema_lang") @db.VarChar(40)
  viewCount    Int       @default(0) @map("view_count")
  likeCount    Int       @default(0) @map("like_count")
  isPublished  Boolean   @default(true) @map("is_published")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  skills     ProjectSkill[]
  milestones ProjectMilestone[]
  features   ProjectFeature[]
  resources  ProjectResource[]
  likes      ProjectLike[]
  listItems  ProjectListItem[]

  @@index([status], name: "idx_projects_status")
  @@index([isFeatured], name: "idx_projects_is_featured")
  @@index([category], name: "idx_projects_category")
  @@index([difficulty], name: "idx_projects_difficulty")
  @@index([isPublished], name: "idx_projects_is_published")
  @@map("projects")
}

model ProjectMilestone {
  id          Int       @id @default(autoincrement())
  projectId   Int       @map("project_id")
  phase       String    @db.VarChar(40)
  title       String    @db.VarChar(255)
  description String?   @db.Text
  date        DateTime? @db.Date
  imageUrl    String?   @map("image_url") @db.VarChar(500)
  // codeBlock / codeLang — optional VSCode-style code review
  // snippet shown below the milestone description. The
  // content is plain text (no syntax tree in DB); highlighting
  // is rendered client-side via Shiki / highlight.js based on
  // codeLang. Free-form VARCHAR(40) to keep the same set of
  // languages as project.schemaLang.
  codeBlock   String?   @map("code_block") @db.Text
  codeLang    String?   @map("code_lang") @db.VarChar(40)
  order       Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, order], name: "idx_project_milestones_project_order")
  @@map("project_milestones")
}

model ProjectFeature {
  id          Int      @id @default(autoincrement())
  projectId   Int      @map("project_id")
  title       String   @db.VarChar(255)
  description String?  @db.Text
  status      String   @default("PLANNED") @db.VarChar(20)
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, order], name: "idx_project_features_project_order")
  @@index([projectId, status], name: "idx_project_features_project_status")
  @@map("project_features")
}

model ProjectResource {
  id          Int      @id @default(autoincrement())
  projectId   Int      @map("project_id")
  title       String   @db.VarChar(255)
  url         String   @db.VarChar(1000)
  type        String   @default("LINK") @db.VarChar(20)
  fileSize    Int?     @map("file_size")
  description String?  @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, order], name: "idx_project_resources_project_order")
  @@map("project_resources")
}

// ─────────────────────────────────────────────────────────────────
// ProjectListItem — single table for the three "list of strings"
// sections (Core Knowledge / Portfolio Bonus / Completion
// Outcomes). Using a kind enum keeps the schema compact and
// the API uniform: one CRUD pair handles all three.
// ─────────────────────────────────────────────────────────────────
enum ProjectListKind {
  CORE_KNOWLEDGE
  PORTFOLIO_BONUS
  COMPLETION_OUTCOME
}

model ProjectListItem {
  id        Int             @id @default(autoincrement())
  projectId Int             @map("project_id")
  kind      ProjectListKind
  // The "content" is the user-facing string the editor stores
  // and the public page renders. VARCHAR(500) so titles like
  // "NextAuth.js v5 flow (JWT, sessions)" fit comfortably.
  content   String          @db.VarChar(500)
  order     Int             @default(0)
  createdAt DateTime        @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, kind, order], name: "idx_project_list_items_project_kind_order")
  @@map("project_list_items")
}

model ProjectLike {
  // Anonymous like record, keyed by IP HMAC-SHA256 hash so
  // the user can hit "like" repeatedly without inflating
  // the count. Unique (project_id, ip_hash) enforces
  // idempotency at the DB level; the API layer also
  // catches and treats the duplicate as success.
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  ipHash    String   @map("ip_hash") @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, ipHash], name: "uk_project_like_project_ip")
  @@index([projectId], name: "idx_project_likes_project")
  @@map("project_likes")
}

model ProjectSkill {
  projectId Int
  skillId   Int

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([projectId, skillId], map: "pk_project_skills")
  @@map("project_skills")
}

// ============================================================
// 6. COURSE MODULE (Education / LMS)
// ============================================================

model CourseCategory {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  slug        String   @unique(map: "uk_course_category_slug") @db.VarChar(100)
  description String?  @db.Text
  icon        String?  @db.VarChar(50)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  courses Course[]

  @@map("course_categories")
}

model Semester {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  code        String   @unique(map: "uk_semester_code") @db.VarChar(20)
  ordinal     Int      @unique(map: "uk_semester_ordinal")
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  courses Course[]

  @@map("semesters")
}

model Course {
  id                     Int       @id @default(autoincrement())
  categoryId             Int?      @map("category_id")
  instructorId           Int?      @map("instructor_id")
  semesterId             Int?      @map("semester_id")
  courseCode             String?   @map("course_code") @db.VarChar(50)
  academyType            String    @default("GENERAL") @map("academy_type") @db.VarChar(30)
  title                  String    @db.VarChar(255)
  slug                   String    @unique(map: "uk_course_slug") @db.VarChar(255)
  shortDescription       String?   @map("short_description") @db.VarChar(500)
  description            String?   @db.Text
  thumbnailUrl           String?   @map("thumbnail_url") @db.VarChar(500)
  previewVideoUrl        String?   @map("preview_video_url") @db.VarChar(500)
  price                  Decimal   @default(0) @db.Decimal(10, 2)
  discountPrice          Decimal?  @map("discount_price") @db.Decimal(10, 2)
  discountExpiresAt      DateTime? @map("discount_expires_at")
  accessType             String    @default("FREE") @map("access_type") @db.VarChar(10)
  enrollmentDurationDays Int       @default(0) @map("enrollment_duration_days")
  level                  String    @default("BEGINNER") @db.VarChar(20)
  language               String    @default("Vietnamese") @db.VarChar(20)
  isFree                 Boolean   @default(false) @map("is_free")
  isFeatured             Boolean   @default(false) @map("is_featured")
  isPublished            Boolean   @default(false) @map("is_published")
  publishedAt            DateTime? @map("published_at")
  totalDurationSeconds   Int       @default(0) @map("total_duration_seconds")
  totalLessons           Int       @default(0) @map("total_lessons")
  totalStudents          Int       @default(0) @map("total_students")
  totalReviews           Int       @default(0) @map("total_reviews")
  avgRating              Decimal   @default(0) @db.Decimal(3, 2)
  requirements           String?   @db.Text
  whatYouLearn           String?   @map("what_you_learn") @db.Text
  // Free-text note shown above the course-level "Tài liệu" list to guide
  // students on how to use the attached materials.
  documentsNote          String?   @map("documents_note") @db.Text
  startDate              DateTime? @map("start_date")
  endDate                DateTime? @map("end_date")
  status                 String    @default("DRAFT") @db.VarChar(20)
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  category     CourseCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  instructor   User?            @relation("CourseInstructor", fields: [instructorId], references: [id], onDelete: SetNull)
  semester     Semester?        @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  sections     CourseSection[]
  documents    CourseDocument[]
  enrollments  Enrollment[]
  certificates Certificate[]
  reviews      CourseReview[]
  tags         CourseTag[]
  orders       CourseOrder[]
  courseCodes  CourseCode[]

  @@index([categoryId], name: "idx_courses_category")
  @@index([instructorId], name: "idx_courses_instructor")
  @@index([semesterId], name: "idx_courses_semester")
  @@index([status], name: "idx_courses_status")
  @@index([isFeatured], name: "idx_courses_featured")
  @@index([isPublished], name: "idx_courses_published")
  @@index([courseCode], name: "idx_courses_code")
  @@index([academyType], name: "idx_courses_academy_type")
  @@index([accessType], name: "idx_courses_access_type")
  @@index([isPublished, status, createdAt(sort: Desc)], name: "idx_courses_published_status_created")
  @@index([isPublished, isFeatured], name: "idx_courses_published_featured")
  @@index([categoryId, isPublished], name: "idx_courses_category_published")
  @@map("courses")
}

model CourseSection {
  id          Int      @id @default(autoincrement())
  courseId    Int      @map("course_id")
  title       String   @db.VarChar(255)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  isLocked    Boolean  @default(false) @map("is_locked")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId], name: "idx_sections_course")
  @@map("course_sections")
}

model Lesson {
  id                   Int      @id @default(autoincrement())
  sectionId            Int      @map("section_id")
  title                String   @db.VarChar(255)
  slug                 String?  @db.VarChar(255)
  description          String?  @db.Text
  content              String?  @db.Text
  lessonType           String   @default("VIDEO") @map("lesson_type") @db.VarChar(20)
  videoUrl             String?  @map("video_url") @db.VarChar(500)
  videoDurationSeconds Int      @default(0) @map("video_duration_seconds")
  thumbnailUrl         String?  @map("thumbnail_url") @db.VarChar(500)
  isFreePreview        Boolean  @default(false) @map("is_free_preview")
  isPublished          Boolean  @default(false) @map("is_published")
  sortOrder            Int      @default(0) @map("sort_order")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  section        CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  details        LessonDetail?
  documents      CourseDocument[]
  assignments    Assignment[]
  lessonProgress LessonProgress[]

  @@index([sectionId], name: "idx_lessons_section")
  @@index([isPublished], name: "idx_lessons_published")
  @@map("lessons")
}

model LessonDetail {
  id            Int      @id @default(autoincrement())
  lessonId      Int      @unique(map: "uk_lesson_detail_lesson") @map("lesson_id")
  videoPlatform String   @default("EMBED") @map("video_platform") @db.VarChar(30)
  videoUrl      String?  @map("video_url") @db.VarChar(500)
  sourceCodeUrl String?  @map("source_code_url") @db.VarChar(500)
  teachingNotes String?  @map("teaching_notes") @db.Text
  // Quiz (lessonType=QUIZ): { timeLimitSeconds, questions: [{ id, question,
  // options: string[], correctIndex, points }] }. Student answers are NOT
  // stored — the quiz is replayable and scored client-side on submit.
  quizData      Json?    @map("quiz_data")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_details")
}

model CourseDocument {
  id            Int      @id @default(autoincrement())
  // A document belongs to EITHER a lesson (lessonId) OR the whole course
  // (courseId) — the fixed "Tài liệu" area shown at course level. Exactly
  // one is set; both are nullable so the same table backs both.
  lessonId      Int?     @map("lesson_id")
  courseId      Int?     @map("course_id")
  title         String   @db.VarChar(255)
  fileUrl       String   @map("file_url") @db.VarChar(500)
  fileSizeBytes BigInt   @default(0) @map("file_size_bytes")
  fileType      String?  @map("file_type") @db.VarChar(50)
  downloadCount Int      @default(0) @map("download_count")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([lessonId], name: "idx_documents_lesson")
  @@index([courseId], name: "idx_documents_course")
  @@map("course_documents")
}

model Enrollment {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  courseId        Int       @map("course_id")
  enrolledAt      DateTime  @default(now()) @map("enrolled_at")
  expiresAt       DateTime? @map("expires_at")
  status          String    @default("ACTIVE") @db.VarChar(20)
  progressPercent Decimal   @default(0) @map("progress_percent") @db.Decimal(5, 2)
  lastLessonId    Int?      @map("last_lesson_id")
  lastAccessedAt  DateTime? @map("last_accessed_at")
  courseCodeId    Int?      @map("course_code_id")
  // How the user gained access: 'FREE' | 'PAID' | 'CODE' | 'ADMIN' | 'INSTRUCTOR'
  source          String    @default("FREE") @db.VarChar(20)

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  certificate    Certificate?
  lessonProgress LessonProgress[]
  usedCourseCode CourseCode?      @relation(fields: [courseCodeId], references: [id], onDelete: SetNull)

  @@unique([userId, courseId], map: "uk_enrollment_user_course")
  @@index([userId], name: "idx_enrollments_user")
  @@index([courseId], name: "idx_enrollments_course")
  @@index([status], name: "idx_enrollments_status")
  @@index([userId, status], name: "idx_enrollments_user_status")
  @@index([courseId, status], name: "idx_enrollments_course_status")
  @@index([expiresAt], name: "idx_enrollments_expires_at")
  @@map("enrollments")
}

model CourseCode {
  id        Int       @id @default(autoincrement())
  code      String    @db.VarChar(10)
  courseId  Int       @map("course_id")
  maxUses   Int       @default(1) @map("max_uses")
  usedCount Int       @default(0) @map("used_count")
  isActive  Boolean   @default(true) @map("is_active")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@unique([courseId, code], map: "uk_course_code_course_code")
  @@index([code], name: "idx_course_codes_code")
  @@index([courseId], name: "idx_course_codes_course")
  @@map("course_codes")
}

model LessonProgress {
  id                  Int       @id @default(autoincrement())
  enrollmentId        Int       @map("enrollment_id")
  lessonId            Int       @map("lesson_id")
  isCompleted         Boolean   @default(false) @map("is_completed")
  completedAt         DateTime? @map("completed_at")
  watchTimeSeconds    Int       @default(0) @map("watch_time_seconds")
  lastPositionSeconds Int       @default(0) @map("last_position_seconds")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId], map: "uk_progress_enrollment_lesson")
  @@index([enrollmentId], name: "idx_progress_enrollment")
  @@index([lessonId], name: "idx_progress_lesson")
  @@map("lesson_progress")
}

model Assignment {
  id           Int       @id @default(autoincrement())
  lessonId     Int       @map("lesson_id")
  title        String    @db.VarChar(255)
  instructions String?   @db.Text
  deadline     DateTime? @db.Timestamp(6)
  sortOrder    Int       @default(0) @map("sort_order")
  isPublished  Boolean   @default(true) @map("is_published")
  maxScore     Float     @default(10.0) @map("max_score")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  lesson      Lesson                 @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  @@index([lessonId], name: "idx_assignments_lesson")
  @@map("assignments")
}

model AssignmentSubmission {
  id            Int      @id @default(autoincrement())
  assignmentId  Int      @map("assignment_id")
  userId        Int      @map("user_id")
  submissionUrl String   @map("submission_url") @db.VarChar(500)
  notes         String?  @db.Text
  status        String   @default("SUBMITTED") @db.VarChar(30)
  grade         Float?   @db.DoublePrecision
  feedback      String?  @db.Text
  submittedAt   DateTime @default(now()) @map("submitted_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId], map: "uk_submission_assignment_user")
  @@index([assignmentId], name: "idx_assignment_submissions_assignment")
  @@index([userId], name: "idx_assignment_submissions_user")
  @@map("assignment_submissions")
}

model Certificate {
  id                Int       @id @default(autoincrement())
  certificateNumber String    @unique(map: "uk_certificate_number") @db.VarChar(64)
  userId            Int       @map("user_id")
  courseId          Int       @map("course_id")
  enrollmentId      Int?      @unique @map("enrollment_id")
  issuedAt          DateTime? @map("issued_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId], map: "uk_certificate_user_course")
  @@map("certificates")
}

model CourseReview {
  id         Int      @id @default(autoincrement())
  courseId   Int      @map("course_id")
  userId     Int      @map("user_id")
  rating     Int
  title      String?  @db.VarChar(255)
  content    String?  @db.Text
  isApproved Boolean  @default(false) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId], map: "uk_review_course_user")
  @@index([courseId], name: "idx_reviews_course")
  @@index([userId], name: "idx_reviews_user")
  @@map("course_reviews")
}

model CourseTag {
  id        Int      @id @default(autoincrement())
  courseId  Int      @map("course_id")
  tag       String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId], name: "idx_course_tags_course")
  @@map("course_tags")
}

// ============================================================
// 7. SHOP MODULE (E-Commerce)
// ============================================================

model ProductCategory {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(100)
  slug        String? @db.VarChar(100)
  description String? @db.Text
  sortOrder   Int     @default(0) @map("sort_order")

  products Product[]

  @@map("product_categories")
}

model Product {
  id               Int      @id @default(autoincrement())
  name             String   @unique @db.VarChar(255)
  slug             String   @unique(map: "uk_product_slug") @db.VarChar(255)
  description      String?  @db.Text
  shortDescription String?  @map("short_description") @db.VarChar(500)
  thumbnailUrl     String?  @map("thumbnail_url") @db.VarChar(500)
  images           String?  @db.Text
  price            Decimal  @db.Decimal(10, 2)
  originalPrice    Decimal? @map("original_price") @db.Decimal(10, 2)
  stockQuantity    Int      @default(0) @map("stock_quantity")
  soldCount        Int      @default(0) @map("sold_count")
  featured         Boolean  @default(false)
  isHot            Boolean  @default(false) @map("is_hot")
  isNew            Boolean  @default(false) @map("is_new")
  active           Boolean  @default(true)
  // Manual display order (admin-sortable). Lower = shown first.
  sortOrder        Int      @default(0) @map("sort_order")
  categoryId       Int?     @map("category_id")
  // PHYSICAL (needs shipping) | DIGITAL (delivered instantly on payment)
  type             String   @default("DIGITAL") @db.VarChar(20)
  fileUrl          String?  @map("file_url") @db.VarChar(500)
  // Digital deliverable shown to the buyer after payment: account info,
  // activation/license key, redemption link, etc. (guidance = how to use it).
  digitalContent   String?  @map("digital_content") @db.Text
  specs            Json     @default("{}") @db.JsonB
  guidance         String?  @db.Text
  // Denormalized review aggregates (recomputed on review add/moderate/delete).
  ratingAvg        Decimal  @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount      Int      @default(0) @map("rating_count")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  category ProductCategory? @relation(fields: [categoryId], references: [id])
  reviews  ProductReview[]
  keys     ProductKey[]

  @@index([categoryId], name: "idx_products_category")
  @@index([active], map: "idx_products_active")
  @@index([featured], map: "idx_products_featured")
  @@index([createdAt(sort: Desc)], name: "idx_products_created")
  @@map("products")
}

// A pool of UNIQUE digital deliverables (license keys, accounts, credentials)
// for a digital product. Each buyer is assigned ONE previously-unassigned key
// at fulfillment, so two buyers never get the same key. Products with no keys
// fall back to the single `Product.digitalContent` (legacy behaviour).
model ProductKey {
  id          Int       @id @default(autoincrement())
  productId   Int       @map("product_id")
  // The actual credential handed to the buyer (account, key, etc.).
  content     String    @db.Text
  // AVAILABLE = in stock; SOLD = assigned to a buyer; DISABLED = withheld.
  status      String    @default("AVAILABLE") @db.VarChar(20)
  orderItemId Int?      @map("order_item_id")
  buyerUserId Int?      @map("buyer_user_id")
  assignedAt  DateTime? @map("assigned_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, status], name: "idx_product_keys_product_status")
  @@map("product_keys")
}

model ShopOrder {
  id                Int       @id @default(autoincrement())
  orderCode         String    @unique(map: "uk_order_code") @db.VarChar(50)
  userId            Int?      @map("user_id")
  buyerName         String    @map("buyer_name") @db.VarChar(255)
  buyerEmail        String    @map("buyer_email") @db.VarChar(255)
  buyerPhone        String?   @map("buyer_phone") @db.VarChar(50)
  buyerAddress      String?   @map("buyer_address") @db.Text
  subtotal          Decimal   @db.Decimal(10, 2)
  discountAmount    Decimal   @default(0) @map("discount_amount")
  discountCode      String?   @map("discount_code") @db.VarChar(50)
  total             Decimal   @db.Decimal(10, 2)
  // Payment/main status: PENDING | PAID | CANCELLED | FAILED | REFUNDED
  status            String    @db.VarChar(20)
  // PHYSICAL | DIGITAL | MIXED — derived from the items at checkout.
  orderType         String    @default("DIGITAL") @map("order_type") @db.VarChar(20)
  // Shipping / fulfillment lifecycle (physical goods): PENDING | PROCESSING |
  // SHIPPED | DELIVERED | COMPLETED. Digital orders jump straight to COMPLETED.
  fulfillmentStatus String    @default("PENDING") @map("fulfillment_status") @db.VarChar(20)
  shippingFee       Decimal   @default(0) @map("shipping_fee") @db.Decimal(10, 2)
  shippingProvince  String?   @map("shipping_province") @db.VarChar(120)
  trackingNumber    String?   @map("tracking_number") @db.VarChar(120)
  shippedAt         DateTime? @map("shipped_at")
  deliveredAt       DateTime? @map("delivered_at")
  paymentMethod     String    @default("SIMULATED") @map("payment_method") @db.VarChar(50)
  paymentStatus     String    @default("PENDING") @map("payment_status") @db.VarChar(20)
  paymentId         String?   @map("payment_id") @db.VarChar(100)
  paidAt            DateTime? @map("paid_at")
  // ─── Refund tracking (set by admin, mirrors CourseOrder) ──
  // refundAmount: how much was actually returned (partial ≤ total). Null = not refunded.
  refundAmount      Decimal?  @map("refund_amount") @db.Decimal(10, 2)
  refundReason      String?   @map("refund_reason") @db.VarChar(500)
  refundedAt        DateTime? @map("refunded_at")
  refundedBy        Int?      @map("refunded_by")
  notes             String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user  User?           @relation(fields: [userId], references: [id])
  items ShopOrderItem[]

  @@index([userId], name: "idx_orders_user")
  @@index([status], name: "idx_orders_status")
  @@index([createdAt(sort: Desc)], name: "idx_orders_created")
  @@map("shop_orders")
}

model ShopOrderItem {
  id             Int     @id @default(autoincrement())
  orderId        Int     @map("order_id")
  productName    String  @map("product_name") @db.VarChar(255)
  productSlug    String? @map("product_slug") @db.VarChar(255)
  productImage   String? @map("product_image") @db.VarChar(500)
  price          Decimal @db.Decimal(10, 2)
  quantity       Int     @default(1)
  total          Decimal @db.Decimal(10, 2)
  productType    String? @map("product_type") @db.VarChar(20)
  fileUrl        String? @map("file_url") @db.VarChar(500)
  // Snapshot of the digital deliverable at purchase time (account/key/guide).
  digitalContent String? @map("digital_content") @db.Text
  credentials    String? @db.Text

  order ShopOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // NOTE: productName/productImage/price/fileUrl are DENORMALIZED snapshots of
  // the product at purchase time — intentionally NOT a live FK to Product, so
  // a product can be renamed or deleted without breaking order history. The
  // fulfillment path matches products by name separately (no relation needed).

  @@index([orderId], name: "idx_order_items_order")
  @@map("shop_order_items")
}

// A user's personal "code wallet" — discount codes, course activation
// codes, etc. Rows are either typed in by the user (source=MANUAL) or
// auto-saved when the user actually uses a code (source=AUTO), e.g. on
// course-code activation or certificate → 10% coupon redemption.
model UserSavedCode {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  label     String    @db.VarChar(120)
  code      String    @db.VarChar(80)
  // DISCOUNT | COURSE | OTHER
  codeType  String    @default("OTHER") @map("code_type") @db.VarChar(20)
  note      String?   @db.VarChar(255)
  expiresAt DateTime? @map("expires_at")
  // MANUAL (typed by the user) | AUTO (saved on use)
  source    String    @default("MANUAL") @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code], map: "uk_user_saved_code")
  @@index([userId], name: "idx_user_saved_code_user")
  @@map("user_saved_codes")
}

// Verified-purchase product reviews (star rating + optional comment). One
// review per user per product; the aggregate is denormalized onto Product.
model ProductReview {
  id         Int      @id @default(autoincrement())
  productId  Int      @map("product_id")
  userId     Int      @map("user_id")
  rating     Int
  comment    String?  @db.Text
  isApproved Boolean  @default(true) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId], map: "uk_product_review_user")
  @@index([productId], name: "idx_product_review_product")
  @@map("product_reviews")
}

model DiscountCode {
  id                Int       @id @default(autoincrement())
  code              String    @unique(map: "uk_discount_code") @db.VarChar(50)
  userId            Int?      @map("user_id")
  discountType      String    @default("PERCENT") @map("discount_type") @db.VarChar(20)
  discountValue     Decimal   @db.Decimal(10, 2)
  minOrderAmount    Decimal   @default(0) @map("min_order_amount") @db.Decimal(10, 2)
  maxDiscountAmount Decimal?  @map("max_discount_amount") @db.Decimal(10, 2)
  maxUses           Int?      @map("max_uses")
  usedCount         Int       @default(0) @map("used_count")
  startsAt          DateTime? @map("starts_at")
  expiresAt         DateTime? @map("expires_at")
  active            Boolean   @default(true)
  description       String?   @db.VarChar(255)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  courseOrders CourseOrder[]

  @@index([code], name: "idx_discount_code")
  @@index([userId], name: "idx_discount_code_user_id")
  @@map("discount_codes")
}

// ============================================================
// 7b. ORPHANED UPLOAD CLEANUP
// Tracks uploads that have been started but not yet linked to a post.
// Used to clean up orphaned R2 objects from:
//   - User navigated away mid-upload
//   - Network timeout / browser crash
//   - Post submission that somehow skipped the media (e.g. bug)
// ============================================================
model PendingUpload {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  r2Key     String   @map("r2_key") @db.VarChar(700)
  url       String   @db.VarChar(700)
  thumbnail String?  @db.VarChar(700)
  fileSize  BigInt   @map("file_size")
  mimeType  String   @map("mime_type") @db.VarChar(100)
  fileName  String?  @map("file_name") @db.VarChar(255)
  status    String   @default("PENDING") @map("status") @db.VarChar(20)
  // PENDING = uploaded to R2, waiting to be linked to a post
  // CONFIRMED = successfully linked to a SocialMedia row
  // EXPIRED = cron job marked as orphaned, R2 object deleted
  expiresAt DateTime @updatedAt @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One pending upload per (user, R2 key). If the user re-uploads
  // the same file, we refresh the TTL instead of creating a duplicate.
  @@unique([userId, r2Key], map: "uk_pending_upload_user_key")
  @@index([userId, status], name: "idx_pending_upload_user_status")
  @@index([status, expiresAt], name: "idx_pending_upload_status_expires")
  @@map("pending_uploads")
}

// ============================================================
// 8. MUSIC MODULE (Spotify Clone)
// ============================================================

model MusicTrack {
  id              Int       @id @default(autoincrement())
  title           String    @db.VarChar(255)
  artist          String    @db.VarChar(255)
  audioUrl        String?   @map("audio_url") @db.VarChar(700)
  coverImage      String?   @map("cover_image") @db.VarChar(700)
  durationSeconds Int?      @map("duration_seconds")
  fileSize        BigInt?   @map("file_size")
  publicId        String?   @map("public_id") @db.VarChar(500)
  cloudinaryUrl   String?   @map("cloudinary_url") @db.VarChar(700)
  supabasePath    String?   @map("supabase_path") @db.VarChar(500)
  localPath       String?   @map("local_path") @db.VarChar(500)
  // Content bucket: "NORMAL" (regular music, the default) or "REMIX"
  // (DJ / remix tracks shown ONLY on the /music/remix deck, never in the
  // normal library or the "Tất cả" listing). Filtered server-side in
  // musicService.getTracks so the two libraries stay fully separated.
  category        String    @default("NORMAL") @db.VarChar(16)
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")

  playlists  MusicPlaylistTrack[]
  histories  MusicHistory[]
  queueItems MusicQueueItem[]
  likes      MusicLike[]
  playCounts MusicPlayCount[]
  lyrics     MusicLyrics?

  @@index([category], name: "idx_music_tracks_category")
  @@map("music_tracks")
}

model MusicPlaylist {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  coverUrl    String?  @map("cover_url") @db.VarChar(700)
  userId      Int?     @map("user_id")
  isPublic    Boolean  @default(true) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks MusicPlaylistTrack[]

  @@index([userId], name: "idx_playlists_user")
  @@map("music_playlists")
}

model MusicPlaylistTrack {
  id         Int      @id @default(autoincrement())
  playlistId Int      @map("playlist_id")
  trackId    Int      @map("track_id")
  position   Int      @default(0)
  addedAt    DateTime @default(now()) @map("added_at")

  playlist MusicPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    MusicTrack    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId], map: "uk_playlist_track")
  @@index([playlistId], name: "idx_playlist_tracks_playlist")
  @@index([trackId], name: "idx_playlist_tracks_track")
  @@map("music_playlist_tracks")
}

// ============================================================
// 8b. MUSIC LISTENING HISTORY
// ============================================================
model MusicHistory {
  id       Int      @id @default(autoincrement())
  userId   Int      @map("user_id")
  trackId  Int      @map("track_id")
  playedAt DateTime @default(now()) @map("played_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  track MusicTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId], name: "music_history_user_track_unique")
  @@index([userId, playedAt(sort: Desc)], name: "idx_history_user_time")
  @@index([userId], name: "idx_history_user")
  @@map("music_history")
}

// ============================================================
// 8c. MUSIC PLAY QUEUE (Phase 1)
// ============================================================
model MusicQueueItem {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  trackId   Int      @map("track_id")
  position  Float    @default(0)
  intent    String   @default("queue") @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  track MusicTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId], name: "music_queue_user_track_unique")
  @@index([userId, position], name: "idx_queue_user_position")
  @@map("music_queue_items")
}

// ============================================================
// 8d. MUSIC LIKES (Phase 2a)
// ============================================================
// One row per (userId, trackId). Idempotent: a "like" is an INSERT,
// an "unlike" is a DELETE. The unique constraint enforces this at
// the DB layer; the service uses upsert+delete to keep the API
// "fire and forget".
model MusicLike {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  trackId   Int      @map("track_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  track MusicTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId], name: "music_likes_user_track_unique")
  @@index([trackId], name: "idx_music_likes_track")
  @@index([userId, createdAt(sort: Desc)], name: "idx_music_likes_user_recent")
  @@map("music_likes")
}

// ============================================================
// 8e. MUSIC PLAY COUNTS (Phase 2a)
// ============================================================
// One row per (userId, trackId). `count` is incremented each time
// the user actually plays the track (driven by the existing
// POST /api/v1/music/history endpoint, no new round-trip).
//
// Why a separate table instead of GROUP BY MusicHistory?
// MusicHistory is unique-on-(userId, trackId) (last-play semantics),
// so it can only count "did the user ever play this". To answer
// "how many times has the user played this" we need an additive
// counter that survives repeats — that's what this table is for.
//
// `lastPlayedAt` is denormalized so the "Most Played" sort can
// break ties with recency without joining MusicHistory.
model MusicPlayCount {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  trackId      Int      @map("track_id")
  count        Int      @default(0)
  lastPlayedAt DateTime @default(now()) @map("last_played_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  track MusicTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId], name: "music_play_counts_user_track_unique")
  @@index([userId, count(sort: Desc)], name: "idx_music_play_counts_user_count")
  @@map("music_play_counts")
}

// ============================================================
// 8f. MUSIC LYRICS (Phase 2b) — synced karaoke lyrics
// ============================================================
// One row per track (1:1, UNIQUE track_id). `synced` holds the
// time-synced lines as JSON: [{ "t": <seconds:number>, "text": <string> }]
// sorted ascending by `t`. `plain` is a newline-separated fallback
// used when a track has lyrics but no timestamps (format='plain').
// `format` lets the client decide between karaoke-scroll and a plain
// block without inspecting the JSON. Editing is an idempotent upsert
// on the unique track_id, so re-saving never creates a duplicate row.
model MusicLyrics {
  id          Int      @id @default(autoincrement())
  trackId     Int      @unique @map("track_id")
  format      String   @default("synced") @db.VarChar(16)
  synced      Json?
  plain       String?  @db.Text
  updatedById Int?     @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  track MusicTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@map("music_lyrics")
}

// ============================================================
