// ===== 2. VOCABULARY =====
model LangVocabCategory {
  id         Int      @id @default(autoincrement())
  languageId Int      @map("language_id")
  name       String   @db.VarChar(150) // "Công nghệ"
  icon       String?  @db.VarChar(64) // emoji or lucide icon name
  level      String?  @db.VarChar(20) // free-text level tag (A1..C2 | N5..N1 | HSK)
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  language Language        @relation(fields: [languageId], references: [id], onDelete: Cascade)
  words    LangVocabWord[]

  @@index([languageId, order], name: "idx_lang_vocab_categories_lang")
  @@map("lang_vocab_categories")
}

model LangVocabWord {
  id              Int      @id @default(autoincrement())
  categoryId      Int      @map("category_id")
  word            String   @db.VarChar(255) // "時間" / "variable"
  meaningVi       String   @map("meaning_vi") @db.Text
  exampleSentence String?  @map("example_sentence") @db.Text
  exampleMeaning  String?  @map("example_meaning") @db.Text
  imageUrl        String?  @map("image_url") @db.VarChar(500)
  audioUrl        String?  @map("audio_url") @db.VarChar(500)
  note            String?  @db.Text
  order           Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  // NOTE: a raw-SQL `search_vector tsvector` column + GIN index is
  // added by the migration and queried via $queryRawUnsafe. It is
  // intentionally NOT declared here (Prisma can't express it).

  category        LangVocabCategory         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  pronunciations  LangVocabPronunciation[]
  favorites       LangVocabFavorite[]
  collectionWords LangVocabCollectionWord[]

  @@index([categoryId, order], name: "idx_lang_vocab_words_category")
  @@map("lang_vocab_words")
}

model LangVocabPronunciation {
  id     Int    @id @default(autoincrement())
  wordId Int    @map("word_id")
  type   String @db.VarChar(40) // "hiragana", "romaji", "pinyin", "IPA"
  value  String @db.VarChar(255) // "じかん", "jikan"
  order  Int    @default(0)

  word LangVocabWord @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([wordId, order], name: "idx_lang_vocab_pron_word")
  @@map("lang_vocab_pronunciations")
}

// ===== 3. GRAMMAR =====
model LangGrammarPoint {
  id             Int      @id @default(autoincrement())
  languageId     Int      @map("language_id")
  level          String?  @db.VarChar(20) // "N5".."N1" | "A1".."C2" — free text
