  voiceUrl              String?  @map("voice_url") @db.VarChar(500)
  imageUrl              String?  @map("image_url") @db.VarChar(500)
  note                  String?  @db.Text
  order                 Int      @default(0)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@index([languageId, order], name: "idx_lang_conversation_items_lang")
  @@map("lang_conversation_items")
}

// ===== 6. READING =====
model LangReadingArticle {
  id          Int             @id @default(autoincrement())
  languageId  Int             @map("language_id")
  level       String?         @db.VarChar(20) // free-text level tag (A1..C2 | N5..N1 | HSK)
  title       String          @db.VarChar(255)
  type        LangReadingType @default(TEXT)
  images      Json?           @db.JsonB // [imageUrl]
  content     Json?           @db.JsonB // TipTap rich text when TEXT
  translation Json?           @db.JsonB // optional VI translation
