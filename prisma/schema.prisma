// ============================================================
// 12. DOCUMENT CHUNKS (RAG Vector Store)
// ============================================================

model DocumentChunk {
  id           Int      @id @default(autoincrement())
  content      String   @db.Text
  metadata     Json?    @default("{}") @db.JsonB
  chunkIndex   Int      @map("chunk_index")
  documentId   String   @map("document_id") @db.VarChar(100)
  documentType String   @map("document_type") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at")
  /// 768-dim vector embedding (Groq `nomic-embed-text-v1.5` compatible).
  /// Added via raw SQL migration in scripts/enable-pgvector.sql because
  /// Prisma doesn't natively support pgvector's `vector(N)` type.
  embedding    Json?

  @@index([documentType], name: "idx_document_chunks_type")
  @@index([documentId], name: "idx_document_chunks_doc_id")
  @@map("document_chunks")
}

// ============================================================
// 14. SOCIAL FEED MODULE (Personal Social Network)
// ============================================================

// Video categories (IT, Giải trí, Game, Music, Vlog, Reaction…) used to
// classify + filter VIDEO posts on the home feed. Managed in the admin
// panel; the feed shows active ones as filter pills.
model VideoCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(80)
  slug      String   @unique @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  posts SocialPost[]

  @@index([isActive, sortOrder], name: "idx_video_categories_active_sort")
  @@map("video_categories")
}

model SocialPost {
  id              Int        @id @default(autoincrement())
  authorId        Int        @map("author_id")
  content         String     @db.Text
  visibility      String     @default("PUBLIC") @map("visibility") @db.VarChar(20)
  status          String     @default("PUBLISHED") @db.VarChar(20)
  latitude        Float?     @db.DoublePrecision
  longitude       Float?     @db.DoublePrecision
  locationName    String?    @map("location_name") @db.VarChar(255)
  viewCount       Int        @default(0) @map("view_count")
  // Phase 6 — shares/reposts count. Tracks how many users have
  // shared this post (via the repost toggle). Incremented on
  // share, decremented on unshare.
  sharesCount     Int        @default(0) @map("shares_count")
  // Optional YouTube link attached to the post. Used by the feed
  // composer ("Paste YouTube URL") and rendered as an embedded
  // player on the post card when present.
  youtubeUrl      String?    @map("youtube_url") @db.VarChar(500)
  // Content-type bucket for the home feed tabs (Tất cả / Bài viết /
  // Video / File). Additive: defaults to POST so every existing row is
  // valid the moment the column is added; old rows are backfilled to
  // VIDEO/FILE by the migration based on their media/youtubeUrl. The
  // composer sets this explicitly; getFeed filters by it per tab.
  type            String     @default("POST") @map("type") @db.VarChar(20) // POST | VIDEO | FILE
  // Optional video category (IT, Game, Music, Vlog…) — only meaningful
  // for VIDEO posts. Powers the per-category filter pills on the home
  // feed. SetNull so deleting a category doesn't delete the videos.
  videoCategoryId Int?       @map("video_category_id")
  // Composer checkbox "Hiện ở mục Tất cả". Only meaningful for VIDEO
  // posts that picked a category: when false the post is EXCLUDED from
  // every feed query that has no videoCategoryId filter (the "Tất cả"
  // type tab and the "Tất cả" video pill) and only surfaces under its
  // own category pill. Defaults to true so all existing rows and all
  // non-video posts keep today's behaviour unchanged.
  showInAll       Boolean    @default(true) @map("show_in_all")
  // Instagram-style music attach (Phase 3 add). When set, the
  // PostCard renders a small "🎵 <track title> — <artist>" sticker
  // overlay on the first media tile. Tapping the sticker opens
  // a mini-player. We use SetNull (not Cascade) so deleting a
  // track doesn't cascade-delete the user's post — the post
  // simply loses its music attachment.
  musicTrackId    Int?       @map("music_track_id")
  musicStartSec   Int?       @map("music_start_sec") // optional: skip ahead to this point in the track
  // Phase 4 add — when this post has a clipped song attached,
  // a 1-row PostMusic record stores the song + start/end
  // seconds (startSec to endSec must be < 40s — the user
  // picked a 1-second-resolution snippet in the composer
  // audio trimmer). The PostCard's MusicSticker uses this
  // record to render the full sticker (cover, title, artist,
  // play/pause with the snippet offset).
  postMusic       PostMusic?
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  author         User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  videoCategory  VideoCategory?     @relation(fields: [videoCategoryId], references: [id], onDelete: SetNull)
  media          SocialMedia[]
  likes          SocialLike[]
  comments       SocialComment[]
  saves          SocialSave[]
  shares         SocialShare[]
  // Back-relation from the new multi-collection save table.
  // A post can be saved into N collections per user (one
  // row per (user, post, collection) triple).
  feedSavedPosts FeedSavedPost[]
  poll           SocialPoll?
  archivedAt     DateTime?          @map("archived_at")
  // Phase 3 relations
  feedbacks      PostFeedback[]
  notifications  PostNotification[]
  reports        PostReport[]
  archive        PostArchive?

  @@index([authorId], name: "idx_social_posts_author")
  @@index([createdAt(sort: Desc)], name: "idx_social_posts_created")
  // Powers the content-type feed tabs (filter by type, newest first).
  @@index([type, createdAt(sort: Desc)], name: "idx_social_posts_type_created")
  @@index([visibility], name: "idx_social_posts_visibility")
  @@index([status, createdAt(sort: Desc)], name: "idx_social_posts_status_created")
  @@index([authorId, createdAt(sort: Desc)], name: "idx_social_posts_author_created")
  @@index([visibility, status, createdAt(sort: Desc)], name: "idx_social_posts_vis_status_created")
  // Powers per-category video filtering on the home feed.
  @@index([videoCategoryId, createdAt(sort: Desc)], name: "idx_social_posts_vidcat_created")
  // GIN trigram index powering fast ILIKE/substring search on
  // post content (see social.service.ts). Requires the pg_trgm
  // extension. `map:` pins the DB index name to match the
  // migration SQL; `raw("gin_trgm_ops")` selects the trigram
  // operator class.
  @@index([content(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_social_posts_content_trgm")
  @@map("social_posts")
}

model SocialMedia {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  type      String   @db.VarChar(20) // IMAGE, VIDEO, CODE_FILE, FILE
  url       String   @db.VarChar(700)
  thumbnail String?  @db.VarChar(700)
  width     Int?     @db.Integer
  height    Int?     @db.Integer
  duration  Int?     @map("duration_seconds")
  fileSize  BigInt?  @map("file_size")
  mimeType  String?  @map("mime_type") @db.VarChar(100)
  // Original file name (used for downloads to set the right
  // Content-Disposition filename). Different from `alt` which is
  // the human-readable caption.
  fileName  String?  @map("file_name") @db.VarChar(255)
  alt       String?  @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId], name: "idx_social_media_post")
  @@map("social_media")
}

model SocialLike {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  // ─── Reaction type (added 2026-06-20) ─────────────────────────
  // The legacy like was a single (postId, userId) row. We now
  // support multi-emoji reactions. The type is a small enum stored
  // as VARCHAR(16) at the DB level so we can add new reactions
  // without a Prisma migration. Default 'LIKE' keeps every row
  // created before the upgrade behaving like a regular like.
  type      String   @default("LIKE") @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at")

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One reaction per (post, user, type) — the user can only have
  // ONE 'LIKE' on a post, ONE 'LOVE' on the same post, etc. They
  // can change their reaction by deleting the old one and inserting
  // a new one (handled in the service).
  @@unique([postId, userId, type], name: "uk_social_reaction_post_user_type")
  @@index([postId], name: "idx_social_likes_post")
  @@index([userId], name: "idx_social_likes_user")
  @@index([postId, type], name: "idx_social_likes_post_type")
  @@map("social_likes")
}

// ─── Social Links (Phase 3 add) ────────────────────────────
// One row per platform link the user has configured (e.g.
// github, twitter, linkedin, website, youtube, facebook).
// mobile.routes.ts expects this model — without it the backend
// build fails (tsc error TS2551 "Property socialLink does
// not exist on PrismaClient"). The previous schema only had
// a `socialLinks` JSON column on User which the mobile route
// doesn't query. Adding the model + relation is the smallest
// fix that unblocks the build without touching unrelated code.
model SocialLink {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  platform  String   @db.VarChar(32) // 'github' | 'twitter' | ...
  url       String   @db.VarChar(500)
  username  String?  @db.VarChar(64) // optional handle
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform], name: "uk_social_link_user_platform")
  @@index([userId], name: "idx_social_links_user")
  @@map("social_link_profiles")
}

model SocialComment {
  id           Int      @id @default(autoincrement())
  postId       Int      @map("post_id")
  userId       Int      @map("user_id")
  parentId     Int?     @map("parent_id")
  content      String   @db.Text
  // ─── Rich media (GIF / sticker), added 2026-07-02 ─────────────
  // Mirrors Message.mediaUrl/mediaKind. `mediaUrl` is fully qualified
  // (GIFs → GIPHY CDN; stickers → our R2). `mediaKind` = 'gif' |
  // 'sticker'. Both null for a plain text comment. Content may be
  // empty when a comment is media-only.
  mediaUrl     String?  @map("media_url") @db.Text
  mediaKind    String?  @map("media_kind") @db.VarChar(12)
  // ─── @mentions (added 2026-06-20) ─────────────────────────────
  // Array of user IDs the commenter tagged with @username. Stored
  // on the comment so the notification job can fan out a single
  // "bạn được nhắc tới" alert per tag without re-parsing the
  // content. The frontend also reads this to render the
  // `<a href="/profile/123">@name</a>` links inside the comment.
  mentions     Int[]    @default([]) @map("mentions")
  likesCount   Int      @default(0) @map("likes_count")
  repliesCount Int      @default(0) @map("replies_count")
  // ─── Phase 5 home upgrade: depth + rootId for 2-level threads ─
  // `depth` is 0 for top-level comments, 1 for first-level replies.
  // Service layer rejects parentId where the parent is already at
  // depth >= 1, so maxDepth=2 stays enforced in code even if a
  // client tries to bypass it. `rootId` lets us load the whole
  // thread in one query (parent + all replies) without recursion.
  depth        Int      @default(0) @map("depth")
  rootId       Int?     @map("root_id")
  isEdited     Boolean  @default(false) @map("is_edited")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  post     SocialPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   SocialComment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  root     SocialComment?      @relation("CommentThread", fields: [rootId], references: [id], onDelete: Cascade)
  replies  SocialComment[]     @relation("CommentReplies")
  inThread SocialComment[]     @relation("CommentThread")
  likes    SocialCommentLike[]

  @@index([rootId], name: "idx_social_comments_root")
  @@index([postId], name: "idx_social_comments_post")
  @@index([userId], name: "idx_social_comments_user")
  @@index([parentId], name: "idx_social_comments_parent")
  @@index([createdAt(sort: Desc)], name: "idx_social_comments_created")
  @@index([postId, parentId, createdAt(sort: Desc)], name: "idx_social_comments_post_parent_created")
  @@index([parentId, createdAt(sort: Desc)], name: "idx_social_comments_parent_created")
  @@map("social_comments")
}

model SocialCommentLike {
  id        Int      @id @default(autoincrement())
  commentId Int      @map("comment_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  comment SocialComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId], name: "uk_social_comment_like")
  @@index([commentId], name: "idx_social_comment_likes_comment")
  @@index([userId], name: "idx_social_comment_likes_user")
  @@map("social_comment_likes")
}

model SocialSave {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  folder    String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId], name: "uk_social_save_post_user")
  @@index([userId], name: "idx_social_saves_user")
  @@index([folder], name: "idx_social_saves_folder")
  @@map("social_saves")
}

// ════════════════════════════════════════════════════════════════════
// FeedCollection — "Saved Collections" multi-folder bookmark system
// ════════════════════════════════════════════════════════════════════
//
// A user owns N named collections (e.g. "Gaming", "Tài liệu").
// Each row represents the collection itself — the actual
// (post ↔ collection) membership lives in FeedSavedPost below.
//
// We do NOT delete these in cascade when a user is removed in
// the `User` model: the cascade sits on the many-to-many
// relation (FeedSavedPost). Hard-deleting a collection,
// however, must cascade to FeedSavedPost so we don't end up
// with orphan saves.
model FeedCollection {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(80)
  ownerId   Int      @map("owner_id")
  // Optional emoji chosen by the user for quick visual ID.
  icon      String?  @db.VarChar(8)
  // Soft-sort key for the order the user arranged their
  // collections in. Defaults to createdAt so the popover
  // lists them in a stable order without explicit drag-drop.
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner User            @relation("FeedCollectionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  saves FeedSavedPost[]

  // Two collections on the same user can't share the same
  // name. The check is case-insensitive via the unique
  // extension `citext` would normally need; here we just
  // normalise on write and rely on a unique constraint at
  // the storage layer. Postgres won't fold case by default,
  // so we lowercase before insert in the service.
  @@unique([ownerId, name], name: "uk_feed_collection_owner_name")
  @@index([ownerId], name: "idx_feed_collections_owner")
  @@map("feed_collections")
}

// FeedSavedPost — junction row that says "user X saved post Y
// into collection Z". One row per (user, post, collection).
// A post can be saved into MULTIPLE collections (unlike
// SocialSave which is single-folder). The UNIQUE constraint
// enforces that.
model FeedSavedPost {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  postId       Int      @map("post_id")
  collectionId Int      @map("collection_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       SocialPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  collection FeedCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, collectionId], name: "uk_feed_saved_user_post_collection")
  @@index([userId, collectionId], name: "idx_feed_saved_user_collection")
  @@index([userId, createdAt(sort: Desc)], name: "idx_feed_saved_user_recent")
  @@map("feed_saved_posts")
}

model SocialShare {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  platform  String?  @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Phase 6 — unique constraint for repost toggle. One user can
  // only share a post once. This enables the toggle semantics
  // (first click = share, second click = unshare) in the service.
  @@unique([postId, userId], name: "uk_social_share_post_user")
  @@index([postId], name: "idx_social_shares_post")
  @@index([userId], name: "idx_social_shares_user")
  @@index([createdAt(sort: Desc)], name: "idx_social_shares_created")
  @@map("social_shares")
}

// ════════════════════════════════════════════════════════════════
// 14b. SOCIAL NOTIFICATIONS (added 2026-06-20)
// ════════════════════════════════════════════════════════════════
// In-app notifications for the social feed. Each row is addressed
// to a single receiver (the user who should see the bell badge)
// and points at a single "actor" (the user who triggered the
// event). `entityId` is the polymorphic pointer to whatever the
// notification is about — post id, comment id, or message id
// depending on `type`. We don't add FK constraints on `entityId`
// because the target table varies by type, and the cascade
// behaviour differs (deleting a post should drop related
// notifications; deleting a comment should too; deleting a
// message is a soft-delete so notifications stay).
//
// `payload` (JSONB) is a free-form per-type blob (e.g. for
// reactions: { type: 'LOVE' }; for comments: { commentId, parentId }).
// The frontend uses it to render the right icon / route the user
// to the right place when they click the bell item.
//
// `isRead` is the source of truth for the unread badge — when the
// user opens the dropdown we flip this in bulk. There is no
// per-notification "seen at" timestamp yet.

model SocialNotification {
  id                Int       @id @default(autoincrement())
  receiverId        Int       @map("receiver_id")
  senderId          Int       @map("sender_id")
  // NEW_POST | NEW_REACTION | NEW_COMMENT | NEW_REPLY |
  // NEW_MENTION | NEW_MESSAGE
  type              String    @db.VarChar(20)
  // Polymorphic pointer — meaning depends on `type`. We keep it
  // as Int (no FK) for forward flexibility.
  entityId          Int?      @map("entity_id")
  // Optional second polymorphic pointer (e.g. comment.parentId
  // for a reply so the bell can deep-link into the right thread).
  secondaryEntityId Int?      @map("secondary_entity_id")
  payload           Json?     @map("payload") @db.JsonB
  isRead            Boolean   @default(false) @map("is_read")
  // ─── Phase 5 home upgrade: readAt timestamp ──────────────────
  // We previously only had a boolean isRead; storing the
  // timestamp lets the bell badge show "read 2h ago" without a
  // extra query, and gives analytics a "time-to-read" signal.
  // Nullable: existing rows + unread rows stay NULL.
  readAt            DateTime? @map("read_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  receiver User @relation("NotificationsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  sender   User @relation("NotificationsSent", fields: [senderId], references: [id], onDelete: Cascade)

  // Hot path: "list the latest unread notifications for user X".
  @@index([receiverId, isRead, createdAt(sort: Desc)], name: "idx_social_notif_receiver_unread")
  @@index([receiverId, createdAt(sort: Desc)], name: "idx_social_notif_receiver_time")
  @@index([senderId], name: "idx_social_notif_sender")
  @@map("social_notifications")
}

// ─── Poll (Phase 2 — admin-style quick vote on a post) ────────────
// Each post can carry 0..1 poll. The options live in their own table
// so we can count votes efficiently and reorder them on the client.
model SocialPoll {
  id          Int       @id @default(autoincrement())
  postId      Int       @unique @map("post_id")
  question    String    @db.VarChar(500)
  multiChoice Boolean   @default(false) @map("multi_choice")
  closesAt    DateTime? @map("closes_at")
  totalVotes  Int       @default(0) @map("total_votes")
  createdAt   DateTime  @default(now()) @map("created_at")

  post    SocialPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options SocialPollOption[]
  votes   SocialPollVote[]

  @@map("social_polls")
}

model SocialPollOption {
  id         Int      @id @default(autoincrement())
  pollId     Int      @map("poll_id")
  text       String   @db.VarChar(255)
  votesCount Int      @default(0) @map("votes_count")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  poll  SocialPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes SocialPollVote[]

  @@index([pollId], name: "idx_social_poll_options_poll")
  @@map("social_poll_options")
}

model SocialPollVote {
  id        Int      @id @default(autoincrement())
  pollId    Int      @map("poll_id")
  optionId  Int      @map("option_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  poll   SocialPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option SocialPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId], name: "uk_social_poll_vote_user")
  @@index([optionId], name: "idx_social_poll_votes_option")
  @@map("social_poll_votes")
}

// ============================================================
// 13. CONTACT FORM
// ============================================================

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  subject   String?  @db.VarChar(500)
  message   String   @db.Text
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_submissions")
}

// ============================================================
// 17. DIRECT MESSAGING
// ============================================================
// User ↔ admin support chat, plus user ↔ user private chat.
// One MessageThread per pair (canonical sort for user↔user to
// avoid duplicates). Messages are soft-deletable (deletedAt) so
// admins can moderate without losing audit trail.
//
// Realtime fan-out is done via Socket.IO in src/socket/messaging.socket.ts;
// this schema only stores the durable record. Read receipts are
// tracked per (thread, user) so the inbox can show unread badges.
// ============================================================

model MessageThread {
  id            Int       @id @default(autoincrement())
  // 'ADMIN' = user↔admin support, 'USER' = user↔user DM.
  type          String    @db.VarChar(20)
  // ADMIN-thread participants
  userId        Int?      @map("user_id")
  adminUserId   Int?      @map("admin_user_id")
  // USER-thread participants (canonical: userAId < userBId)
  userAId       Int?      @map("user_a_id")
  userBId       Int?      @map("user_b_id")
  // Last activity timestamp — used to sort the inbox
  // (most-recent first) without joining messages.
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user        User?            @relation("ThreadAsUser", fields: [userId], references: [id], onDelete: Cascade)
  adminUser   User?            @relation("ThreadAsAdmin", fields: [adminUserId], references: [id], onDelete: Cascade)
  userA       User?            @relation("ThreadUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB       User?            @relation("ThreadUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages    Message[]
  readStates  MessageRead[]
  nicknames   ThreadNickname[]
  reports     ThreadReport[]   @relation("ThreadReportsTarget")
  // Per-user thread preferences. JSONB keyed by userId so each
  // participant can independently pin/mute/archive the thread
  // without affecting the other side.
  //
  // Shape: { [userId]: { pinnedAt?, mutedUntil?, archivedAt?, markedUnreadAt? } }
  preferences Json             @default("{}") @map("preferences")

  @@unique([userId, adminUserId, type], name: "uk_thread_admin_pair")
  @@unique([userAId, userBId, type], name: "uk_thread_user_pair")
  @@index([userId, type], name: "idx_thread_user_type")
  @@index([adminUserId, type], name: "idx_thread_admin_type")
  @@index([lastMessageAt(sort: Desc)], name: "idx_thread_last_msg")
  @@index([userAId, lastMessageAt(sort: Desc)], name: "idx_thread_user_a_last_msg")
  @@index([userBId, lastMessageAt(sort: Desc)], name: "idx_thread_user_b_last_msg")
  @@map("message_threads")
}

/// Per-user blocklist for direct messaging. When user A blocks
/// user B, B can no longer send A new messages, start a new
/// thread with A, or even see A's existing thread in their
/// sidebar. We don't delete the thread — A still keeps their
/// copy and can unblock at any time.
model UserBlock {
  id        Int      @id @default(autoincrement())
  blockerId Int      @map("blocker_id")
  blockedId Int      @map("blocked_id")
  // Optional reason stored for the blocker's reference. Not
  // shown to the blocked user.
  reason    String?  @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("UserBlocksCreated", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId], name: "uk_block_pair")
  @@index([blockerId], name: "idx_block_blocker")
  @@index([blockedId], name: "idx_block_blocked")
  @@map("user_blocks")
}

/// Reports against a chat thread. Each row is a "user X reports
/// thread Y because ..." entry. Stored for moderator review;
/// the reporter can withdraw by deleting the row.
model ThreadReport {
  id         Int       @id @default(autoincrement())
  reporterId Int       @map("reporter_id")
  threadId   Int       @map("thread_id")
  // Free-form reason. Kept short (200 chars) so we can render
  // it directly in the admin inbox without further truncation.
  reason     String    @db.VarChar(200)
  // Optional structured category for filtering in admin.
  // 'SPAM' | 'HARASSMENT' | 'HATE' | 'IMPERSONATION' | 'OTHER' | null
  category   String?   @db.VarChar(30)
  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")
  resolvedBy Int?      @map("resolved_by")
  resolution String?   @db.VarChar(500)

  reporter User          @relation("ThreadReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  thread   MessageThread @relation("ThreadReportsTarget", fields: [threadId], references: [id], onDelete: Cascade)
  resolver User?         @relation("ThreadReportsResolved", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([reporterId], name: "idx_report_reporter")
  @@index([threadId], name: "idx_report_thread")
  @@index([resolvedAt], name: "idx_report_resolved")
  @@map("thread_reports")
}

model Message {
  id              Int       @id @default(autoincrement())
  threadId        Int       @map("thread_id")
  senderId        Int       @map("sender_id")
  content         String    @db.Text
  // Rich media payload (GIF or sticker). `mediaUrl` is a fully
  // qualified URL: GIFs point at GIPHY's CDN; stickers point at our
  // own storage/R2 (never hotlinked). `mediaKind` distinguishes how
  // the client renders it ('gif' | 'sticker'). Both null for plain
  // text/file/post-share messages — fully additive, old rows unaffected.
  mediaUrl        String?   @map("media_url") @db.Text
  mediaKind       String?   @map("media_kind") @db.VarChar(12)
  // Reply-to: optional reference to the parent message this is replying to.
  parentMessageId Int?      @map("parent_message_id")
  // Soft delete: message hidden from UI but kept for audit.
  // Note: `deletedAt` means "Xoá" (delete for me / unsend).
  // `recalledAt` means "Thu hoi" (withdraw, also hides content).
  deletedAt       DateTime? @map("deleted_at")
  // Recall: sender retracted the message. After this timestamp
  // the message is treated as "Tin nhắn đã thu hồi" everywhere.
  // We keep the row for audit but the content is wiped.
  recalledAt      DateTime? @map("recalled_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  thread        MessageThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender        User                @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  parentMessage Message?            @relation("MessageReplies", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies       Message[]           @relation("MessageReplies")
  attachments   MessageAttachment[]
  reactions     MessageReaction[]
  // Phase 6 — shared social post preview in chat
  postShare     MessagePostShare?

  @@index([threadId, createdAt], name: "idx_msg_thread_time")
  @@index([senderId], name: "idx_msg_sender")
  @@index([parentMessageId], name: "idx_msg_parent")
  @@map("messages")
}

/// Per-user, per-thread nickname. Lets a user rename the other
/// participant in their own sidebar / chat header without
/// affecting the peer's view. Maps userId -> (threadId -> alias).
model ThreadNickname {
  id        Int      @id @default(autoincrement())
  threadId  Int      @map("thread_id")
  // The user who SET the nickname (not the user being renamed).
  ownerId   Int      @map("owner_id")
  // The user being renamed (the "other" participant in the
  // owner's view of this thread).
  targetId  Int      @map("target_id")
  // The alias. Empty string means "no alias" / cleared.
  alias     String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  owner  User          @relation("NicknameOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  target User          @relation("NicknameTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([threadId, ownerId, targetId], name: "uk_nickname_per_user")
  @@index([ownerId], name: "idx_nickname_owner")
  @@map("thread_nicknames")
}

/// One row per (user, message, emoji). Multiple users can react
/// with the same emoji, but the same user can only have one
/// reaction of a given emoji per message (re-react is a no-op).
model MessageReaction {
  id        Int      @id @default(autoincrement())
  messageId Int      @map("message_id")
  userId    Int      @map("user_id")
  // The reaction emoji — we use a short string code (e.g. "👍")
  // to keep things simple. We don't need a separate ReactionType
  // table for v1; new emojis are added by just sending them.
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("ReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji], name: "uk_reaction_user_emoji")
  @@index([messageId], name: "idx_reaction_message")
  @@map("message_reactions")
}

model MessageAttachment {
  id           Int      @id @default(autoincrement())
  messageId    Int      @map("message_id")
  fileId       Int      @map("file_id")
  mimeType     String   @map("mime_type") @db.VarChar(100)
  fileName     String   @map("file_name") @db.VarChar(255)
  fileSize     BigInt   @map("file_size")
  // Optional thumbnail URL for image previews. Generated
  // client-side via <img> on the same URL; backend doesn't
  // pre-render thumbnails for chat attachments.
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")

  message Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  file    FileAttachment @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([messageId], name: "idx_msg_attach_msg")
  @@map("message_attachments")
}

// ─── Message Post Share (Phase 6) ───────────────────────────────
// When a user shares a social post into a chat thread, we store
// the post preview (author, content snippet, media URL) here so
// the message bubble can render a clickable card that links to
// the original post at /social/post/:postId. The preview is
// denormalised from the SocialPost at share-time so the card
// remains readable even if the original post is later deleted
// (we show a "bài viết đã bị xoá" stub in that case).
model MessagePostShare {
  id             Int      @id @default(autoincrement())
  messageId      Int      @map("message_id")
  postId         Int      @map("post_id")
  // Denormalised preview data — copied from the post at share time
  authorUsername String   @map("author_username") @db.VarChar(64)
  authorDisplay  String?  @map("author_display") @db.VarChar(128)
  authorAvatar   String?  @map("author_avatar") @db.VarChar(500)
  contentPreview String   @map("content_preview") @db.Text
  mediaThumbnail String?  @map("media_thumbnail") @db.VarChar(700)
  createdAt      DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId], name: "uk_msg_post_share_msg")
  @@index([postId], name: "idx_msg_post_share_post")
  @@map("message_post_shares")
}

model MessageRead {
  id         Int      @id @default(autoincrement())
  threadId   Int      @map("thread_id")
  userId     Int      @map("user_id")
  lastReadAt DateTime @map("last_read_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User          @relation("MessageReadUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId], name: "uk_read_thread_user")
  @@map("message_reads")
}

// ============================================================
// STICKERS (chat sticker packs)
// ------------------------------------------------------------
// Facebook-Messenger-style stickers. A StickerPack groups many
// Sticker images. Images are uploaded by an ADMIN and stored in
// our own storage/R2 (never hotlinked from a third party). The
// picker lists active packs; a message sends a sticker by storing
// its URL in Message.mediaUrl with mediaKind = 'sticker'.
// Fully additive — independent of the existing messaging tables.
// ============================================================
model StickerPack {
  id        Int      @id @default(autoincrement())
  // URL-friendly unique key, e.g. "openmoji-faces".
  slug      String   @unique(map: "uk_sticker_pack_slug") @db.VarChar(60)
  name      String   @db.VarChar(80)
  // Optional cover image (one of the stickers) shown as the pack tab.
  coverUrl  String?  @map("cover_url") @db.Text
  // Hidden packs stay in the DB but are excluded from the picker.
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  // Admin who created the pack (nullable for seeded packs).
  createdBy Int?     @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator  User?     @relation("StickerPacksCreated", fields: [createdBy], references: [id], onDelete: SetNull)
  stickers Sticker[]

  @@index([isActive, sortOrder], map: "idx_sticker_pack_active")
  @@map("sticker_packs")
}

model Sticker {
  id        Int      @id @default(autoincrement())
  packId    Int      @map("pack_id")
  // Fully qualified URL in our storage/R2.
  url       String   @db.Text
  // Optional short label / keywords for future sticker search.
  label     String?  @db.VarChar(80)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  pack StickerPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([packId, sortOrder], map: "idx_sticker_pack_sort")
  @@map("stickers")
}

// ============================================================
// 19. COURSE PAYMENT (VNPay)
// ============================================================
// Luu moi order mua course qua VNPay. Khi IPN xac nhan thanh
// toan thanh cong, backend tu dong tao Enrollment cho user.
//
// orderCode = vnp_TxnRef (VNPay), unique, format: COURSE_{courseId}_{userId}_{ts}
model CourseOrder {
  id              Int       @id @default(autoincrement())
  orderCode       String    @unique(map: "uk_course_order_code") @db.VarChar(80)
  userId          Int       @map("user_id")
  courseId        Int       @map("course_id")
  // So tien user phai tra (VND), da tru discount. Luu Decimal
  // de tranh floating point rounding error.
  amount          Decimal   @db.Decimal(10, 2)
  // Trang thai: PENDING | PAID | FAILED | REFUNDED
  status          String    @default("PENDING") @db.VarChar(20)
  paymentMethod   String    @default("VNPAY") @map("payment_method") @db.VarChar(30)
  // VNPay tra ve sau khi thanh toan thanh cong
  paymentTxnNo    String?   @map("payment_txn_no") @db.VarChar(50)
  paymentBankCode String?   @map("payment_bank_code") @db.VarChar(30)
  paymentPayDate  DateTime? @map("payment_pay_date")
  // Idempotent guard: true sau khi da tao Enrollment tu IPN.
  // Tranh increment totalStudents 2 lan khi VNPay retry IPN.
  enrolled        Boolean   @default(false)
  // Frontend-sent idempotency key. Prevents the same client from
  // creating two orders by double-clicking "Mua" before the first
  // redirect takes effect. Unique per user (a different user can
  // safely re-use the same UUID).
  idempotencyKey  String?   @map("idempotency_key") @db.VarChar(64)
  // Optional discount code applied to this order. We keep both the
  // code (string) and the FK so the snapshot survives coupon deletion
  // or value change.
  discountCode    String?   @map("discount_code") @db.VarChar(50)
  discountCodeId  Int?      @map("discount_code_id")
  // The amount BEFORE applying the discount code, for audit.
  originalAmount  Decimal?  @map("original_amount") @db.Decimal(10, 2)
  // ─── Refund tracking (set by admin) ──
  // refundAmount: how much was actually returned to the user.
  // Can be less than `amount` for partial refunds. Null = not refunded.
  refundAmount    Decimal?  @map("refund_amount") @db.Decimal(10, 2)
  refundReason    String?   @map("refund_reason") @db.VarChar(500)
  refundedAt      DateTime? @map("refunded_at")
  refundedBy      Int?      @map("refunded_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  // set null on delete so the order stays visible even after the
  // coupon is removed by an admin.
  coupon         DiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)
  refundedByUser User?         @relation("CourseOrderRefunder", fields: [refundedBy], references: [id], onDelete: SetNull)

  @@unique([userId, idempotencyKey], name: "uk_course_order_idempotency")
  @@index([userId, status], name: "idx_course_orders_user_status")
  @@index([courseId], name: "idx_course_orders_course")
  @@index([discountCodeId], name: "idx_course_orders_coupon")
  @@index([refundedBy], name: "idx_course_orders_refunder")
  @@index([status, createdAt(sort: Desc)], name: "idx_course_orders_status_created")
  @@index([courseId, status], name: "idx_course_orders_course_status")
  @@index([createdAt(sort: Desc)], name: "idx_course_orders_created")
  @@map("course_orders")
}

// Log moi IPN callback tu VNPay de audit/debug.
// KHONG dung de quyet dinh trang thai don hang (xem CourseOrder).
// Mot don hang co the co nhieu log (VNPay retry).
model PaymentTransaction {
  id           Int       @id @default(autoincrement())
  orderCode    String    @map("order_code") @db.VarChar(80)
  gatewayTxnNo String?   @map("gateway_txn_no") @db.VarChar(50)
  bankCode     String?   @map("bank_code") @db.VarChar(30)
  payDate      DateTime? @map("pay_date")
  responseCode String?   @map("response_code") @db.VarChar(10)
  amount       Decimal   @db.Decimal(10, 2)
  // Raw payload tu VNPay (de debug/audit)
  rawPayload   Json      @map("raw_payload")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([orderCode], name: "idx_payment_tx_order")
  @@map("payment_transactions")
}

// ============================================================
// 20. GITHUB REPO HUB & FEED
// ============================================================
//
// Curated, opinionated feed of GitHub repositories the site
// owner has starred or hand-picked. Each entry has the admin's
// own `myReview` (markdown) attached — this is the editorial
// layer, not just an aggregation of GitHub stars. Status
// (DRAFT/PUBLISHED) lets the admin stage entries before going
// live.
//
// `url` is the canonical repo URL on github.com and is unique
// to prevent duplicate rows when the same repo is added twice
// from different code paths (manual form, fetch-starred, sync).
// ────────────────────────────────────────────────────────────────

enum GithubRepoStatus {
  DRAFT
  PUBLISHED

  @@map("github_repo_status")
}

model GithubRepo {
  // UUID is friendlier for public-facing API responses than a
  // sequential int. We expose this in card URLs.
  id          String           @id @default(uuid()) @db.Uuid
  repoName    String           @map("repo_name") @db.VarChar(200)
  owner       String           @db.VarChar(100)
  // Canonical https://github.com/{owner}/{repo} URL. Unique so
  // a second POST with the same URL is rejected at the DB level.
  url         String           @unique(map: "uk_github_repos_url") @db.VarChar(500)
  // Most recent stargazers_count pulled from the GitHub API.
  // Cached so the feed can render without re-hitting GitHub
  // on every request.
  stars       Int              @default(0)
  // Primary language from GitHub. Nullable because some
  // repos (e.g. all-docs) report null.
  language    String?          @db.VarChar(50)
  // Original description from GitHub. Optional in case the
  // admin wants to clear it before publishing.
  description String?          @db.Text
  // The admin's own editorial review / lessons learned. This
  // is the centerpiece of the feature — the reason to list a
  // repo at all. Supports markdown rendered client-side.
  myReview    String           @db.Text
  status      GithubRepoStatus @default(DRAFT)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Many-to-many join to Tag for multi-axis classification.
  tags GithubRepoTag[]

  @@index([status], name: "idx_github_repos_status")
  // Composite index to support the common public-feed query
  // (status=PUBLISHED ORDER BY createdAt DESC).
  @@index([status, createdAt(sort: Desc)], name: "idx_github_repos_status_created")
  @@index([language], name: "idx_github_repos_language")
  @@index([owner, repoName], name: "idx_github_repos_owner_name")
  @@map("github_repos")
}

model GithubRepoTag {
  repoId String @map("repo_id") @db.Uuid
  tagId  Int    @map("tag_id")

  repo GithubRepo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  tag  Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([repoId, tagId], map: "pk_github_repo_tags")
  // Lookup tags for a repo (used when serializing for the feed).
  @@index([repoId], name: "idx_github_repo_tags_repo")
  // Lookup repos for a tag (used when filtering the feed by tag).
  @@index([tagId], name: "idx_github_repo_tags_tag")
  @@map("github_repo_tags")
}

// ══════════════════════════════════════════════════════════════════
// Personal Dashboard — private per-user scheduling & task tracking
// ══════════════════════════════════════════════════════════════════
//
// We persist this on the server (not localStorage) so:
//   - User data survives device wipe / browser change / private mode
//   - User gets the same dashboard on phone, laptop, tablet
//   - Backup/restore is just a SQL export — no JS state to chase
//   - Admins can audit "this user has X tasks pending" without
//     scraping the client
//
// All data is private (always scoped to req.userId). Anonymous
// visitors get nothing — there's no guest mode at the DB level.
// The cron job in src/jobs/dashboardArchive.ts soft-archives
// tasks older than the retention window (default 30 days) and
// hard-deletes them after 180 days.

model DashboardState {
  id                     Int       @id @default(autoincrement())
  userId                 Int       @unique @map("user_id")
  level                  Int       @default(1)
  exp                    Int       @default(0)
  // JSON-encoded TimelineSlot[24]. Stored as text so we can evolve
  // the shape without migrations; the API layer parses it.
  timeline               String    @default("[]") @map("timeline") @db.Text
  // YYYY-MM-DD of the last "end of day" celebration, or null.
  // We persist this so a user can't double-claim EXP by clicking
  // the celebration twice (the API checks today == lastCelebratedAt
  // before awarding).
  lastCelebratedAt       DateTime? @map("last_celebrated_at")
  // YYYY-MM-DD of the day the user locked the next-day plan.
  // Distinct from lastCelebratedAt so we can let the user lock
  // a plan in the morning without having to celebrate first.
  tomorrowPlanLockedDate DateTime? @map("tomorrow_plan_locked_date")
  // Cached total exp earned across the user's lifetime. The
  // server is the only authority on this — the client's local
  // EXP can drift and we periodically re-sync from here.
  totalExp               Int       @default(0) @map("total_exp")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dashboard_states")
}

model DashboardTask {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  // 'today' | 'week' | 'month' — matches the existing TaskScope.
  // We store it as a string to match the API and avoid enum
  // churn when we add new scopes (e.g. 'quarter').
  scope        String    @db.VarChar(16)
  // YYYY-MM-DD. We always normalize on write so query by date
  // works as a string compare (date_trunc would be slower on
  // the volumes we expect).
  date         String    @db.VarChar(10)
  title        String    @db.VarChar(500)
  done         Boolean   @default(false)
  // EXP awarded when this task is checked off. Defaults to 25
  // to match the legacy client behavior; admin can tweak per
  // task in the future.
  exp          Int       @default(25)
  // Optional link to the activity this task belongs to
  // (study/work/exercise/...). Same values as ACTIVITY_META.
  activityType String?   @map("activity_type") @db.VarChar(32)
  // When this task was created (UTC).
  createdAt    DateTime  @default(now()) @map("created_at")
  // When it was checked off. Used for streak / heatmap reports.
  completedAt  DateTime? @map("completed_at")
  // Soft-delete: a non-null value means the task is archived.
  // Archived tasks are kept for 180 days then hard-deleted by
  // the archive cron. We never lose user data — even deleted
  // tasks remain recoverable from a DB backup for years.
  archivedAt   DateTime? @map("archived_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Active-task index: we read "today's tasks" all the time, so
  // (userId, archivedAt IS NULL, date) is our hottest access path.
  // The composite index on (userId, date) covers the timeline view.
  @@index([userId, archivedAt, date], name: "idx_dashboard_tasks_active")
  @@index([userId, date], name: "idx_dashboard_tasks_user_date")
  @@index([userId, completedAt], name: "idx_dashboard_tasks_completed")
  @@map("dashboard_tasks")
}

model DashboardCelebration {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  // The calendar day (YYYY-MM-DD) the user celebrated. The
  // uniqueness that guarantees one celebration per day is the
  // COMPOSITE (user_id, celebrated_date) constraint below — NOT
  // a global unique on this column. A global unique here was a
  // multi-user bug: the first user to celebrate on a date would
  // win the row and every other user's celebrate POST would hit
  // a unique violation. Each user gets exactly one celebration
  // per day, independent of everyone else.
  celebratedDate String   @map("celebrated_date") @db.VarChar(10)
  // EXP awarded for this celebration. We keep the amount so we
  // can show "you got +150 EXP on 2026-06-15" later if we add
  // a history view.
  expAwarded     Int      @default(0) @map("exp_awarded")
  tasksDone      Int      @default(0) @map("tasks_done")
  tasksTotal     Int      @default(0) @map("tasks_total")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One celebration per (user, day). Serves as both the
  // uniqueness guard and the (userId, celebratedDate) lookup
  // index, so no separate @@index is needed. `map:` sets the
  // DATABASE constraint name so it matches the migration SQL
  // (uniq_dashboard_celeb_user_date) — using `name:` instead
  // would only rename the Prisma Client field and leave the DB
  // index on Prisma's default name, causing schema drift.
  @@unique([userId, celebratedDate], map: "uniq_dashboard_celeb_user_date")
  @@map("dashboard_celebrations")
}

// ============================================================
// TECH TRENDS & INSIGHTS (added 2026-06-17)
// ============================================================
// Long-form editorial articles for the /tech-trends public page.
//
// `category` is a small enum to keep the filter UI fast and the
// trending aggregation simple — we don't need a full category
// join table for a 4-bucket set. `tags` is a free-form string
// array because authors tag organically; for tag-based search
// the public /posts/search endpoint does a case-insensitive
// substring match in code, which is fine at the current
// cardinality (< 1000 articles expected lifetime).
//
// `cover_image_url` is nullable so authors can skip a cover and
// fall back to the emoji we set in `cover_emoji` (or the default
// per-category icon on the frontend).
//
// `code_block` is JSON: { before: {lang, lines:[...]},
// after: {lang, lines:[...]}, takeaway: string }. Optional — only
// present on #FixBug posts.
//
// `is_featured` flips the bento card to span 2 columns on the
// public page.
//
// `trending_score` is a 0-100 score maintained by the admin UI
// (the admin sets it manually) and surfaced into the sidebar
// "Trending Tags" computation. We do not auto-compute it in
// the backend yet — too small a dataset to justify the SQL.
//
// `status` mirrors the Post model (DRAFT | PUBLISHED). Public
// queries always filter status = 'PUBLISHED' so drafts never
// leak. Admins see all statuses.
model TechTrendArticle {
  id            Int       @id @default(autoincrement())
  title         String    @db.VarChar(255)
  slug          String    @unique(map: "uk_tech_trend_slug") @db.VarChar(255)
  summary       String    @db.Text
  // ─── Rich body (Tier 1A — TipTap / Markdown) ───────────────
  // `bodyMdx` is the canonical Markdown source the admin edits
  // via the TipTap-backed editor. `bodyHtml` is the rendered
  // HTML cached server-side at write time so the public page
  // doesn't pay a render cost on every request. The legacy
  // `body` JsonB column is kept for backward compatibility with
  // articles created before this migration — readers detect
  // bodyMdx !== null and prefer it; otherwise they fall back to
  // the legacy `body` array.
  body          Json      @db.JsonB
  bodyMdx       String?   @map("body_mdx") @db.Text
  bodyHtml      String?   @map("body_html") @db.Text
  // Optional auto-extracted table of contents (heading list).
  // Built when bodyHtml is rendered and stored alongside it so
  // the public page can render a sidebar TOC without re-parsing.
  toc           Json?     @db.JsonB
  category      String    @db.VarChar(20)
  coverEmoji    String?   @map("cover_emoji") @db.VarChar(16)
  coverImageUrl String?   @map("cover_image_url") @db.VarChar(500)
  codeBlock     Json?     @map("code_block") @db.JsonB
  tags          String[]  @default([])
  trendingScore Int       @default(0) @map("trending_score")
  isFeatured    Boolean   @default(false) @map("is_featured")
  status        String    @default("DRAFT") @db.VarChar(20)
  readTimeMin   Int       @default(5) @map("read_time_min")
  authorId      Int?      @map("author_id")
  viewCount     Int       @default(0) @map("view_count")
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // ─── News bulletins (added 2026-07-20) ───────────────────────
  // The same table serves hand-written articles and the AI news
  // bulletin. `kind` splits them: 'ARTICLE' (default, everything
  // that existed before) vs 'NEWS'. A bulletin is written ONLY
  // from real items ingested into news_items — `sources` records
  // which ones, so every claim on the page can link out to the
  // official announcement it came from.
  kind        String    @default("ARTICLE") @db.VarChar(16)
  // [{ title, url, publisher, publishedAt }] — the grounding set.
  sources     Json?     @db.JsonB
  // True when the body was produced by the model rather than a
  // human. Surfaced in the UI: readers deserve to know.
  aiGenerated Boolean   @default(false) @map("ai_generated")
  aiModel     String?   @map("ai_model") @db.VarChar(80)
  // Future publish time. The scheduler flips DRAFT -> PUBLISHED
  // once now() passes it, which is how "đăng lúc 8h sáng" works.
  scheduledAt DateTime? @map("scheduled_at")

  author   User?              @relation("TechTrendAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  comments TechTrendComment[]

  @@index([category], name: "idx_tech_trend_category")
  @@index([status], name: "idx_tech_trend_status")
  @@index([isFeatured], name: "idx_tech_trend_featured")
  @@index([publishedAt(sort: Desc)], name: "idx_tech_trend_published_at")
  @@index([authorId], name: "idx_tech_trend_author_id")
  @@index([kind, status, publishedAt(sort: Desc)], name: "idx_tech_trend_kind_feed")
  @@index([scheduledAt], name: "idx_tech_trend_scheduled_at")
  @@map("tech_trend_articles")
}

// ─── Tech Trends — news ingestion (added 2026-07-20) ──────────
// A registry of official RSS/Atom feeds. Only first-party
// sources belong here (a vendor's own engineering blog, a
// project's release feed) — the whole point is that a bulletin
// can cite the announcement itself rather than someone's
// second-hand summary. `weight` biases selection when the day
// produces more candidates than one bulletin can carry.
model NewsFeed {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(120)
  url         String    @unique(map: "uk_news_feed_url") @db.VarChar(500)
  // Shown as the publisher on the bulletin, e.g. "GitHub".
  publisher   String    @db.VarChar(120)
  homepage    String?   @db.VarChar(500)
  // Topic hint used when grouping a bulletin, e.g. "ai", "web".
  topic       String?   @db.VarChar(40)
  weight      Int       @default(50)
  isActive    Boolean   @default(true) @map("is_active")
  lastFetchAt DateTime? @map("last_fetch_at")
  lastError   String?   @map("last_error") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  items NewsItem[]

  @@index([isActive], name: "idx_news_feed_active")
  @@map("news_feeds")
}

// One entry pulled from a feed. `urlHash` (sha256 of the
// normalised link) is the dedupe key — the same release note
// shows up in several feeds and must not become two bulletins.
// `usedInArticleId` records which bulletin consumed it so the
// next run never re-reports yesterday's news.
model NewsItem {
  id              Int       @id @default(autoincrement())
  feedId          Int       @map("feed_id")
  title           String    @db.VarChar(500)
  url             String    @db.VarChar(1000)
  urlHash         String    @unique(map: "uk_news_item_url_hash") @map("url_hash") @db.VarChar(64)
  summary         String?   @db.Text
  author          String?   @db.VarChar(200)
  imageUrl        String?   @map("image_url") @db.VarChar(1000)
  publishedAt     DateTime? @map("published_at")
  fetchedAt       DateTime  @default(now()) @map("fetched_at")
  usedInArticleId Int?      @map("used_in_article_id")
  usedAt          DateTime? @map("used_at")

  feed NewsFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@index([publishedAt(sort: Desc)], name: "idx_news_item_published_at")
  @@index([usedInArticleId], name: "idx_news_item_used_in")
  @@index([feedId], name: "idx_news_item_feed")
  @@map("news_items")
}

// ─── Tech Trends — reader comments (added 2026-07-16) ─────────
// Flat + one level of replies (parentId), like SnippetComment.
// Comments require a logged-in user (userId is NOT nullable);
// deleting the article or the user cascades. `likesCount` is a
// denormalised counter kept in sync by the like toggle.
model TechTrendComment {
  id         Int      @id @default(autoincrement())
  articleId  Int      @map("article_id")
  userId     Int      @map("user_id")
  parentId   Int?     @map("parent_id")
  content    String   @db.Text
  likesCount Int      @default(0) @map("likes_count")
  isEdited   Boolean  @default(false) @map("is_edited")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  article TechTrendArticle       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  TechTrendComment?      @relation("TechTrendCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies TechTrendComment[]     @relation("TechTrendCommentReplies")
  likes   TechTrendCommentLike[]

  @@index([articleId, createdAt(sort: Desc)], name: "idx_tt_comments_article_time")
  @@index([parentId], name: "idx_tt_comments_parent")
  @@index([userId], name: "idx_tt_comments_user")
  @@map("tech_trend_comments")
}

model TechTrendCommentLike {
  id        Int      @id @default(autoincrement())
  commentId Int      @map("comment_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  comment TechTrendComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId], name: "uk_tt_comment_like")
  @@index([commentId], name: "idx_tt_comment_likes_comment")
  @@index([userId], name: "idx_tt_comment_likes_user")
  @@map("tech_trend_comment_likes")
}

// ============================================================
// 21. HUB — Personal Bookmark Manager (added 2026-06-20)
// ============================================================
// User-owned folders + links. Pure CRUD, no sharing graph yet
// beyond the per-link `isPublic` flag. Every row is scoped by
// userId; all routes use `authenticate` middleware and a
// where: { id, userId } clause to prevent cross-tenant reads.
//
// `icon` is intentionally a short string — either a Lucide
// component name (e.g. "Layers") or a full URL to an uploaded
// cover image. The frontend decides which to render based on
// whether the value starts with "/" or "http".

model HubFolder {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  parentId      Int?     @map("parent_id")
  name          String   @db.VarChar(100)
  // Either a Lucide icon name (frontend resolves to component)
  // or an absolute URL to an uploaded image on R2.
  icon          String?  @db.VarChar(500)
  // Cover/banner image for the folder header — separate from
  // the small `icon` so users can keep the sidebar compact while
  // having a rich preview when the folder is open. Set by the
  // owner via the Folder dialog, stored on R2. Null = use the
  // auto-derived gradient fallback in the UI.
  coverImageUrl String?  @map("cover_image_url") @db.VarChar(2000)
  // Display order within the sidebar. Lower = first. Default 0.
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  links    HubLink[]
  files    HubFile[]
  parent   HubFolder?  @relation("HubSubFolders", fields: [parentId], references: [id], onDelete: Cascade)
  children HubFolder[] @relation("HubSubFolders")
  // Phase 2: which shares expose this folder to which users.
  // We only need the back-relation; the FK lives on HubShare.
  shares   HubShare[]

  @@index([userId, sortOrder], name: "idx_hub_folders_user_sort")
  @@index([userId, name], name: "idx_hub_folders_user_name")
  @@map("hub_folders")
}

model HubLink {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  folderId      Int?     @map("folder_id")
  url           String   @db.VarChar(2000)
  title         String   @db.VarChar(500)
  description   String?  @db.Text
  thumbnailUrl  String?  @map("thumbnail_url") @db.VarChar(2000)
  faviconUrl    String?  @map("favicon_url") @db.VarChar(500)
  // Owner-uploaded cover image (stored on R2). Overrides the
  // auto-scraped `thumbnailUrl` for card display when set —
  // useful when the web og:image is wrong/missing/ugly. UI
  // shows coverImageUrl in priority: cover > thumbnail > gradient.
  coverImageUrl String?  @map("cover_image_url") @db.VarChar(2000)
  // Free-form note (markdown/plain). No length cap at the DB
  // level — the API layer trims to 5000 chars which is plenty
  // for a personal note while still letting Postgres TEXT be
  // efficient.
  notes         String?  @db.Text
  // String[] tags. Native Postgres array — no join table needed
  // for a small set (typically < 20 per link). The API normalises
  // each tag to lowercase + trim before insert.
  tags          String[] @default([])
  // Progress status: "unread" | "learning" | "done"
  status        String   @default("unread") @map("status")
  // When true the link is reachable via /api/v1/hub/public/:slug
  // without auth. We never expose userId, notes, or personal
  // tags in the public payload.
  isPublic      Boolean  @default(false) @map("is_public")
  // Public slug used by /api/hub/public/:slug. Null until first
  // share; we generate it server-side with nanoid(10) for
  // unguessability.
  publicSlug    String?  @unique @map("public_slug") @db.VarChar(32)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder HubFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  // Phase 2: shares that expose this link to specific recipients.
  shares HubShare[]

  @@index([userId, createdAt(sort: Desc)], name: "idx_hub_links_user_recent")
  @@index([userId, folderId], name: "idx_hub_links_user_folder")
  @@index([userId], name: "idx_hub_links_user")
  @@index([isPublic, createdAt(sort: Desc)], name: "idx_hub_links_public")
  @@map("hub_links")
}

// ─── Hub File Storage ─────────────────────────────────────────

model HubFile {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  folderId      Int?     @map("folder_id")
  // Display name shown in the UI (original filename).
  name          String   @db.VarChar(255)
  // R2 object key, e.g. "hub-files/user42/abc123.pdf"
  key           String   @db.VarChar(500)
  size          Int // bytes
  mimeType      String   @db.VarChar(100)
  // Owner-uploaded cover image (stored on R2). For images this
  // is often the file's own bytes; for non-image files (pdf,
  // docx…) the owner can pick a separate thumbnail. When set
  // the card displays this instead of the mime icon.
  coverImageUrl String?  @map("cover_image_url") @db.VarChar(2000)
  // Progress status: "unread" | "learning" | "done"
  status        String   @default("unread")
  tags          String[] @default([])
  notes         String?  @db.Text
  isPublic      Boolean  @default(false)
  publicSlug    String?  @unique @map("public_slug") @db.VarChar(32)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder HubFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  // Phase 2: shares that expose this file to specific recipients.
  shares HubShare[]

  @@index([userId, folderId], name: "idx_hub_files_user_folder")
  @@index([userId, status], name: "idx_hub_files_user_status")
  @@index([userId], name: "idx_hub_files_user")
  @@map("hub_files")
}

// ─── Hub User-Sharing (Phase 2) ───────────────────────────────
// One row = "user `ownerId` shares [folderId | linkId | fileId]
// with user `recipientId`". Exactly one of folderId/linkId/fileId
// is set per row. Recipient has read-only access by default; if
// permission = "view_download" they can also download the file
// (links are always "downloadable" — clicking the link IS the
// download). The recipient NEVER gets edit/delete rights; the
// owner can revoke at any time by deleting the share row.
//
// Discovery note: this row is created explicitly by the owner.
// There is no auto-discovery — the recipient only sees the share
// in their inbox if they navigate to /hub/shared. We deliberately
// don't email them (privacy: don't leak which folder was shared).
model HubShare {
  id          Int      @id @default(autoincrement())
  ownerId     Int      @map("owner_id")
  recipientId Int      @map("recipient_id")
  // Exactly one of these is set. Validated in the service layer
  // — we throw AppError(400) if zero or more than one is set.
  folderId    Int?     @map("folder_id")
  linkId      Int?     @map("link_id")
  fileId      Int?     @map("file_id")
  // "view" (read-only) or "view_download" (file downloads too).
  // Default to view_download because that's the common request
  // pattern; if owner wants stricter, they can flip via PATCH.
  permission  String   @default("view_download") @db.VarChar(20)
  // Optional short note that rides along with the share (e.g.
  // "Báo cáo cuối kỳ — xem giúp mình nhé"). Truncated to 500
  // chars at the API layer.
  note        String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner     User       @relation("HubShareOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  recipient User       @relation("HubShareRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  folder    HubFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)
  link      HubLink?   @relation(fields: [linkId], references: [id], onDelete: Cascade)
  file      HubFile?   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  // Anti-spam: a recipient can only have one share per item
  // from the same owner. Re-sharing the same item updates the
  // existing row (we use upsert in the service layer) so this
  // unique constraint enforces "no duplicates" at the DB level.
  @@unique([ownerId, recipientId, folderId], name: "uk_hub_share_owner_recipient_folder")
  @@unique([ownerId, recipientId, linkId], name: "uk_hub_share_owner_recipient_link")
  @@unique([ownerId, recipientId, fileId], name: "uk_hub_share_owner_recipient_file")
  @@index([recipientId, createdAt(sort: Desc)], name: "idx_hub_share_recipient_recent")
  @@index([ownerId, createdAt(sort: Desc)], name: "idx_hub_share_owner_recent")
  @@map("hub_shares")
}

// ─── Social Follow Graph ──────────────────────────────────
model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int      @map("follower_id")
  followingId Int      @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId], map: "uk_follow_pair")
  @@index([followingId], map: "idx_follow_following")
  @@index([followerId], map: "idx_follow_follower")
  @@map("follows")
}

// ============================================================
// FRIEND GRAPH (two-way, Facebook-style requests)
// ------------------------------------------------------------
// Sits ALONGSIDE the follow graph above — the two are
// independent. Follow is asymmetric (Twitter/IG style);
// Friendship is a mutual relationship that must be confirmed.
//
// One row per unordered pair (enforced at the app layer + the
// uk_friendship_pair unique on the ordered pair). `requesterId`
// is whoever sent the invite; `addresseeId` is whoever must
// Confirm/Delete it. Lifecycle:
//   PENDING  → invite sent, awaiting the addressee
//   ACCEPTED → mutual friends
// A declined/cancelled invite is DELETED (FB doesn't keep a
// rejected record), so there is no REJECTED status.
// ============================================================
model Friendship {
  id          Int       @id @default(autoincrement())
  requesterId Int       @map("requester_id")
  addresseeId Int       @map("addressee_id")
  status      String    @default("PENDING") @db.VarChar(12) // PENDING | ACCEPTED
  createdAt   DateTime  @default(now()) @map("created_at")
  respondedAt DateTime? @map("responded_at")

  requester User @relation("FriendshipsSent", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipsReceived", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId], map: "uk_friendship_pair")
  @@index([addresseeId, status], map: "idx_friendship_addressee_status")
  @@index([requesterId, status], map: "idx_friendship_requester_status")
  @@map("friendships")
}

// ============================================================
// CONTENT CREATOR (Phase 1)
// ------------------------------------------------------------
// Personal production tool for planning, scripting and
// tracking videos posted to TikTok / YouTube / Facebook /
// Instagram. All tables are additive — no existing model is
// modified. The schema mirrors the data model the user
// authored in the spec: ContentProject (top level) →
// ProductionDay[] → Scene[]; plus 4 sibling child lists
// (affiliateProducts, platformPosts, checklistItems) and a
// one-to-one ContentPerformance. Order columns are kept on
// every child list so the editor can drag-reorder and the
// round-trip is deterministic.
// ============================================================

// ─── Enums ─────────────────────────────────────────────────────
enum ContentType {
  VLOG
  AFFILIATE
  CODE
  REVIEW
  IDEA
  OTHER

  @@map("content_type")
}

enum ContentStatus {
  IDEA
  SCRIPTING
  FILMING
  EDITING
  SCHEDULED
  PUBLISHED

  @@map("content_status")
}

enum SceneType {
  OPENING
  HOOK
  INTRO
  BODY
  BROLL
  CTA
  OUTRO

  @@map("scene_type")
}

enum ShotType {
  CLOSEUP
  MEDIUM
  WIDE
  POV
  OVERHEAD

  @@map("shot_type")
}

enum ContentPlatform {
  TIKTOK
  YOUTUBE
  FACEBOOK
  INSTAGRAM

  @@map("content_platform")
}

enum ChecklistPhase {
  PRE
  PRODUCTION
  POST
  PUBLISH

  @@map("checklist_phase")
}

// ─── Top-level entity ──────────────────────────────────────────
model ContentProject {
  id             Int           @id @default(autoincrement())
  slug           String        @unique @db.VarChar(120)
  title          String        @db.VarChar(200)
  type           ContentType
  status         ContentStatus @default(IDEA)
  ideaDate       DateTime?     @map("idea_date")
  filmDate       DateTime?     @map("film_date")
  publishDate    DateTime?     @map("publish_date")
  concept        String?       @db.Text
  // Phase 7: full freeform script body. Markdown-ish,
  // long-form (treated as @db.Text). Distinct from
  // `concept` (a 1-2 sentence description). The Script
  // editor tab owns this field.
  script         String?       @db.Text
  // Short opening hook (≤200 chars). Used as a teaser line
  // in Pipeline cards and Calendar popups.
  mainHook       String?       @map("main_hook") @db.VarChar(280)
  thumbnailUrl   String?       @map("thumbnail_url") @db.VarChar(500)
  // Free-form tags (lowercase kebab-case recommended).
  tags           String[]      @default([])
  // [{label: string, url: string}] — inspiration / competitor
  // links, kept schema-free in JSONB.
  referenceLinks Json          @default("[]") @map("reference_links")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  days              ProductionDay[]
  affiliateProducts AffiliateProduct[]
  platformPosts     PlatformPost[]
  checklistItems    ChecklistItem[]
  performance       ContentPerformance?
  // Reverse side: ideas that were promoted into this project.
  // Nullable, indexed so we can list "which ideas became this?".
  promotedFromIdeas ContentIdea[]

  @@index([status, type], map: "idx_content_projects_status_type")
  @@index([filmDate], map: "idx_content_projects_film_date")
  @@index([publishDate], map: "idx_content_projects_publish_date")
  @@index([type], map: "idx_content_projects_type")
  @@map("content_projects")
}

// ─── ProductionDay (1-n) ───────────────────────────────────────
model ProductionDay {
  id               Int       @id @default(autoincrement())
  contentProjectId Int       @map("content_project_id")
  dayNumber        Int       @map("day_number")
  date             DateTime?
  location         String?   @db.VarChar(200)
  notes            String?   @db.Text
  order            Int       @default(0)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  contentProject ContentProject @relation(fields: [contentProjectId], references: [id], onDelete: Cascade)
  scenes         Scene[]

  @@index([contentProjectId, order], map: "idx_production_days_project_order")
  @@map("production_days")
}

// ─── Scene (1-n) ───────────────────────────────────────────────
model Scene {
  id                 Int       @id @default(autoincrement())
  productionDayId    Int       @map("production_day_id")
  sceneNumber        Int       @map("scene_number")
  sceneType          SceneType @map("scene_type")
  // On-screen dialogue (lời thoại nhân vật).
  dialogue           String?   @db.Text
  // Voiceover narration (lời dẫn ngoài).
  voiceover          String?   @db.Text
  // Free-form camera direction (góc quay mô tả tự do).
  cameraAngle        String?   @map("camera_angle") @db.VarChar(200)
  shotType           ShotType? @map("shot_type")
  action             String?   @db.Text
  props              String?   @db.VarChar(300)
  brollNotes         String?   @map("broll_notes") @db.Text
  editingNotes       String?   @map("editing_notes") @db.Text
  durationSeconds    Int?      @map("duration_seconds")
  storyboardImageUrl String?   @map("storyboard_image_url") @db.VarChar(500)
  order              Int       @default(0)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  productionDay ProductionDay @relation(fields: [productionDayId], references: [id], onDelete: Cascade)

  @@index([productionDayId, order], map: "idx_scenes_day_order")
  @@map("scenes")
}

// ─── AffiliateProduct (1-n) ────────────────────────────────────
model AffiliateProduct {
  id                Int      @id @default(autoincrement())
  contentProjectId  Int      @map("content_project_id")
  name              String   @db.VarChar(200)
  url               String   @db.VarChar(500)
  discountCode      String?  @map("discount_code") @db.VarChar(50)
  commissionPercent Float?   @map("commission_percent")
  revenue           Float?   @default(0)
  notes             String?  @db.Text
  order             Int      @default(0)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  contentProject ContentProject @relation(fields: [contentProjectId], references: [id], onDelete: Cascade)

  @@index([contentProjectId, order], map: "idx_affiliate_products_project_order")
  @@map("affiliate_products")
}

// ─── PlatformPost (1-n) ────────────────────────────────────────
model PlatformPost {
  id               Int             @id @default(autoincrement())
  contentProjectId Int             @map("content_project_id")
  platform         ContentPlatform
  caption          String?         @db.Text
  hashtags         String[]        @default([])
  scheduledTime    DateTime?       @map("scheduled_time")
  postUrl          String?         @map("post_url") @db.VarChar(500)
  isPublished      Boolean         @default(false) @map("is_published")
  order            Int             @default(0)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  contentProject ContentProject @relation(fields: [contentProjectId], references: [id], onDelete: Cascade)

  @@index([contentProjectId, order], map: "idx_platform_posts_project_order")
  @@index([contentProjectId, platform], map: "idx_platform_posts_project_platform")
  @@map("platform_posts")
}

// ─── ChecklistItem (1-n) ───────────────────────────────────────
model ChecklistItem {
  id               Int            @id @default(autoincrement())
  contentProjectId Int            @map("content_project_id")
  phase            ChecklistPhase
  label            String         @db.VarChar(300)
  done             Boolean        @default(false)
  order            Int            @default(0)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  contentProject ContentProject @relation(fields: [contentProjectId], references: [id], onDelete: Cascade)

  @@index([contentProjectId, phase, order], map: "idx_checklist_items_project_phase_order")
  @@map("checklist_items")
}

// ─── ContentPerformance (1-1) ──────────────────────────────────
model ContentPerformance {
  id               Int      @id @default(autoincrement())
  contentProjectId Int      @unique @map("content_project_id")
  views            Int      @default(0)
  likes            Int      @default(0)
  comments         Int      @default(0)
  shares           Int      @default(0)
  // Click-through rate as a fraction (0..1) — render as %.
  ctr              Float?
  // Average watch time in seconds.
  watchTimeSec     Int?     @map("watch_time_sec")
  // Per-platform breakdown for future per-platform rollups.
  // Shape: { TIKTOK: { views, likes, ... }, YOUTUBE: {...} }
  platformMetrics  Json     @default("{}") @map("platform_metrics")
  lessonsLearned   String?  @map("lessons_learned") @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  contentProject ContentProject @relation(fields: [contentProjectId], references: [id], onDelete: Cascade)

  @@map("content_performance")
}

// ─── ContentIdea (Idea Bank) ─────────────────────────────────────
// Lightweight capture model: titles + a one-liner hook + free-form
// tags. Lives separately from ContentProject so the idea list stays
// fast (no JOINs) and the /creator/ideas page can show a different
// shape (card grid, capture-first form). Promoting an idea creates
// a new ContentProject with title/concept/tags copied over and
// links back via promotedToProjectId.
enum IdeaStatus {
  CAPTURED // just dumped, not yet refined
  REFINED // fleshed out, ready to commit to a project
  PROMOTED // turned into a ContentProject
  ARCHIVED // explicitly killed

  @@map("idea_status")
}

model ContentIdea {
  id                  Int          @id @default(autoincrement())
  // Short title (≤140 chars). The hero field of the card.
  title               String       @db.VarChar(140)
  // Optional one-liner hook (≤280 chars) — teaser for the
  // eventual video.
  hook                String?      @db.VarChar(280)
  // Free-form notes (any length). Why is this interesting?
  // What format? Who is the audience? This is the "long text"
  // of an idea, not a script.
  notes               String?      @db.Text
  // 1-5 personal score. Lets the user rank what to film next.
  // Optional: lots of users will just dump ideas without a
  // score, so this stays nullable.
  score               Int?         @db.SmallInt
  // Detected/favourite ContentType — used as a default when
  // the idea is promoted. Nullable so a raw idea can be just
  // "a thing I want to make" without committing to a format.
  suggestedType       ContentType? @map("suggested_type")
  // Lifecycle status. CAPTURED is the default.
  status              IdeaStatus   @default(CAPTURED)
  // When the idea is promoted, points back at the resulting
  // ContentProject (nullable + onDelete: SetNull so deleting
  // the project doesn't delete the idea — the user can re-
  // promote it later).
  promotedToProjectId Int?         @map("promoted_to_project_id")
  promotedAt          DateTime?    @map("promoted_at")
  // Free-form tags (same convention as ContentProject.tags).
  tags                String[]     @default([])
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  promotedToProject ContentProject? @relation(fields: [promotedToProjectId], references: [id], onDelete: SetNull)

  @@index([status], map: "idx_content_ideas_status")
  @@index([score], map: "idx_content_ideas_score")
  @@index([createdAt(sort: Desc)], map: "idx_content_ideas_created_at")
  @@map("content_ideas")
}

// ════════════════════════════════════════════════════════════
// Notes — personal study notebooks (per-user, no admin)
// ════════════════════════════════════════════════════════════
// Hierarchy: NoteSubject → NoteChapter → Note. Attachments and
// links may hang off a Subject, a Chapter, OR a Note (exactly
// one parent set). Vocab entries belong to a Note. Every row is
// scoped by userId and every query filters on it — same rule as
// Hub. Cascade deletes flow down the tree.

model NoteSubject {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  name        String   @db.VarChar(150)
  // Restrained accent color (hex) used for the sidebar dot/spine.
  color       String?  @db.VarChar(20)
  // Emoji or short icon token rendered before the name.
  emoji       String?  @db.VarChar(20)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  isPinned    Boolean  @default(false) @map("is_pinned")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user            User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapters        NoteChapter[]
  notes           Note[]
  attachments     NoteAttachment[]
  links           NoteLink[]
  // Phase 4 add — subject-level sharing
  shares          NoteSubjectShare[]
  shareRecipients NoteSubjectShareRecipient[] @relation("SubjectShareRecipients")

  @@index([userId, sortOrder], name: "idx_note_subjects_user_sort")
  @@index([userId, isPinned], name: "idx_note_subjects_user_pinned")
  @@map("note_subjects")
}

// Phase 4 add — share a NoteSubject (folder) with other users
model NoteSubjectShare {
  id          Int      @id @default(autoincrement())
  subjectId   Int      @map("subject_id")
  // Owner = the user who created the subject and is sharing it
  ownerId     Int      @map("owner_id")
  // Recipient = the user who has been granted access
  recipientId Int      @map("recipient_id")
  // 'view' = read-only | 'edit' = can modify notes inside
  permission  String   @default("view") @db.VarChar(20)
  // Optional note from the owner
  note        String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subject    NoteSubject                 @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  owner      User                        @relation("NoteSubjectSharesOwned", fields: [ownerId], references: [id], onDelete: Cascade)
  recipient  User                        @relation("NoteSubjectSharesReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  recipients NoteSubjectShareRecipient[]

  @@unique([subjectId, recipientId], name: "uk_note_subject_share")
  @@index([ownerId], name: "idx_note_subject_share_owner")
  @@index([recipientId], name: "idx_note_subject_share_recipient")
  @@map("note_subject_shares")
}

// Phase 4 add — recipient side: folders shared with current user
model NoteSubjectShareRecipient {
  id          Int       @id @default(autoincrement())
  shareId     Int       @map("share_id")
  subjectId   Int       @map("subject_id")
  recipientId Int       @map("recipient_id")
  seenAt      DateTime? @map("seen_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  share   NoteSubjectShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  subject NoteSubject      @relation("SubjectShareRecipients", fields: [subjectId], references: [id], onDelete: Cascade)
  user    User             @relation("UserShareRecipients", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([shareId, recipientId], name: "uk_note_share_recipient")
  @@map("note_subject_share_recipients")
}

model NoteChapter {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  subjectId Int      @map("subject_id")
  title     String   @db.VarChar(200)
  isPinned  Boolean  @default(false) @map("is_pinned")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     NoteSubject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  notes       Note[]
  attachments NoteAttachment[]
  links       NoteLink[]

  @@index([userId, subjectId, sortOrder], name: "idx_note_chapters_user_subject")
  @@map("note_chapters")
}

model Note {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  subjectId   Int       @map("subject_id")
  // Optional: a note can live directly under a subject (no chapter).
  chapterId   Int?      @map("chapter_id")
  title       String    @default("Untitled") @db.VarChar(300)
  // Rich editor document (TipTap/ProseMirror JSON). Source of truth.
  contentJson Json?     @map("content_json")
  // Server-rendered HTML cache of contentJson for fast read/print.
  contentHtml String?   @map("content_html") @db.Text
  tags        String[]  @default([])
  isPinned    Boolean   @default(false) @map("is_pinned")
  isFavorite  Boolean   @default(false) @map("is_favorite")
  isArchived  Boolean   @default(false) @map("is_archived")
  needsReview Boolean   @default(false) @map("needs_review")
  reviewDate  DateTime? @map("review_date")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      NoteSubject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chapter      NoteChapter?     @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  attachments  NoteAttachment[]
  links        NoteLink[]
  vocabEntries NoteVocabEntry[]

  @@index([userId, subjectId, chapterId, sortOrder], name: "idx_notes_user_tree")
  @@index([userId, updatedAt(sort: Desc)], name: "idx_notes_user_recent")
  @@index([userId, isPinned], name: "idx_notes_user_pinned")
  @@index([userId, isArchived], name: "idx_notes_user_archived")
  @@map("notes")
}

model NoteAttachment {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  // Exactly one of these parents is set (Subject/Chapter/Note).
  subjectId     Int?     @map("subject_id")
  chapterId     Int?     @map("chapter_id")
  noteId        Int?     @map("note_id")
  fileName      String   @db.VarChar(300)
  // Absolute URL (R2) returned by the existing /files/upload flow.
  fileUrl       String   @db.VarChar(2000)
  fileType      String?  @map("file_type") @db.VarChar(150)
  fileSizeBytes Int?     @map("file_size_bytes")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject NoteSubject? @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chapter NoteChapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  note    Note?        @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([userId, noteId], name: "idx_note_attachments_note")
  @@index([userId, subjectId], name: "idx_note_attachments_subject")
  @@map("note_attachments")
}

model NoteLink {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  subjectId    Int?     @map("subject_id")
  chapterId    Int?     @map("chapter_id")
  noteId       Int?     @map("note_id")
  label        String   @db.VarChar(500)
  url          String   @db.VarChar(2000)
  // "WEB" | "YOUTUBE" | "OTHER"
  type         String   @default("WEB") @db.VarChar(20)
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(2000)
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject NoteSubject? @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chapter NoteChapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  note    Note?        @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([userId, noteId], name: "idx_note_links_note")
  @@index([userId, subjectId], name: "idx_note_links_subject")
  @@map("note_links")
}

model NoteVocabEntry {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  noteId    Int      @map("note_id")
  term      String   @db.VarChar(500)
  // Furigana / pinyin / phonetic reading.
  reading   String?  @db.VarChar(500)
  meaning   String?  @db.Text
  example   String?  @db.Text
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  // ── Phase 3b: flashcard review state (additive, all optional) ──
  // `isKnown` is a coarse "marked known" flag — UI shows a checkmark
  // and lets the user "reset" it. `reviewCount` / `lastReviewedAt` /
  // `knownStreak` power a tiny stats line under the vocab table; we
  // don't do SRS scheduling yet (could be added in 3d).
  isKnown        Boolean   @default(false) @map("is_known")
  reviewCount    Int       @default(0) @map("review_count")
  knownStreak    Int       @default(0) @map("known_streak")
  lastReviewedAt DateTime? @map("last_reviewed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([userId, noteId, sortOrder], name: "idx_note_vocab_note")
  @@index([userId, noteId, isKnown], name: "idx_note_vocab_known")
  @@map("note_vocab_entries")
}

// ============================================================
// 30. MUSIC POST (Phase 4) — admin-curated song pool
// ============================================================
// Admin uploads mp3 / m4a tracks to R2 (capped at 50 MB,
// validated on both the frontend and the API) and tags them
// with a title + artist + cover image. Users pick one of
// these from the composer and clip a 1-second-resolution
// snippet (< 40 s) onto their post via the trimmer.
//
// Restrict on uploader so deleting the original admin
// account doesn't silently wipe every post that referenced
// the track — the post will need to be remapped first.
model Song {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  artist       String   @db.VarChar(255)
  audioUrl     String   @db.VarChar(700) // R2 URL to the mp3/m4a
  coverImage   String?  @db.VarChar(700) // R2 URL to the cover
  durationSec  Int      @map("duration_sec") // total track duration
  fileSize     Int?     @map("file_size") // bytes — audit + UI
  isActive     Boolean  @default(true) // admin can hide without deleting
  uploadedById Int      @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  uploader  User        @relation("SongUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  postMusic PostMusic[]

  @@index([isActive, createdAt(sort: Desc)], name: "idx_songs_active_created")
  @@map("songs")
}

// 1 post <-> 1 song. startSec to endSec must be < 40s. The user
// picks a 1-second-resolution snippet in the composer audio
// trimmer. PostMusic is a separate table (not columns on
// SocialPost) so that future feature work — e.g. song
// analytics, multiple-attached tracks — can extend without
// bloating the post row.
model PostMusic {
  id        Int      @id @default(autoincrement())
  // 1-1 with SocialPost: each post can have at most one attached
  // music snippet. The (postId, songId) composite unique keeps
  // it a 1-1 relationship on the post side; a 2nd snippet would
  // replace the first.
  postId    Int      @unique @map("post_id")
  songId    Int      @map("song_id")
  startSec  Int      @default(0) @map("start_sec")
  endSec    Int?     @map("end_sec") // null = play to end of file
  createdAt DateTime @default(now()) @map("created_at")

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  song Song       @relation(fields: [songId], references: [id], onDelete: Restrict)

  @@index([songId], name: "idx_post_music_song")
  @@map("post_music")
}

// 1-1 with User. Optional — every existing user row gets a
// default empty profile the first time the row is touched. We
// keep this in a separate table (instead of columns on User)
// to avoid bloating the hot User row with profile fields
// (the read path doesn't care about bio / cover photo / etc).
model UserProfile {
  userId     Int     @id @map("user_id")
  bio        String? @db.Text
  coverPhoto String? @map("cover_photo") @db.VarChar(700)
  location   String? @db.VarChar(255)
  websiteUrl String? @map("website_url") @db.VarChar(500)
  work       String? @db.VarChar(255)
  education  String? @db.VarChar(255)

  // ─── Extended "About" fields (FB-style profile) ─────────
  // All optional. languages is stored as a comma-joined string
  // (the UI splits/joins on ", ") to avoid a Postgres array column.
  hometown           String? @db.VarChar(255)
  jobTitle           String? @map("job_title") @db.VarChar(255)
  workplace          String? @db.VarChar(255)
  school             String? @db.VarChar(255)
  college            String? @db.VarChar(255)
  relationshipStatus String? @map("relationship_status") @db.VarChar(50)
  hobbies            String? @db.Text
  languages          String? @db.VarChar(255)
  pinnedPostId       Int?    @map("pinned_post_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ─── Stories / Tin (Phase 6) ──────────────────────────────────────
// Instagram/Facebook-style ephemeral stories. Stories disappear after
// 24h. Users can group them into Highlights (StoryHighlight) that
// persist on the profile permanently.

model Story {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  // Visibility: PUBLIC, FRIENDS, or PRIVATE (only the owner can see)
  visibility      String   @default("PUBLIC") @map("visibility") @db.VarChar(20)
  // Optional text overlay on the story (Instagram-style)
  caption         String?  @db.Text
  // Media URL (image or video) - can be empty for text-only stories
  mediaUrl        String?  @map("media_url") @db.VarChar(700)
  mediaType       String   @default("IMAGE") @map("media_type") @db.VarChar(10) // IMAGE | VIDEO
  // Video duration in seconds (null for images)
  duration        Int?     @map("duration_seconds")
  // Thumbnail for video stories
  thumbnail       String?  @db.VarChar(700)
  // Background color for text-only stories (hex)
  backgroundColor String?  @map("background_color") @db.VarChar(7)
  // When this story expires (24h from creation by default)
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  views      StoryView[]
  highlights StoryHighlight[]
  hiddenBy   StoryHide[]

  @@index([userId], name: "idx_story_user")
  @@index([expiresAt], name: "idx_story_expires")
  @@map("stories")
}

// Who has viewed a story
model StoryView {
  id       Int      @id @default(autoincrement())
  storyId  Int      @map("story_id")
  userId   Int      @map("user_id")
  viewedAt DateTime @default(now()) @map("viewed_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId], name: "uk_story_view")
  @@index([storyId], name: "idx_story_view_story")
  @@index([userId], name: "idx_story_view_user")
  @@map("story_views")
}

// Story Highlight - permanently pinned story on profile (like Facebook Highlights)
model StoryHighlight {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String   @db.VarChar(50)
  // Stories in this highlight (can have multiple)
  storyId   Int      @map("story_id")
  // Order within the highlight
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId], name: "uk_highlight_story")
  @@index([userId], name: "idx_highlight_user")
  @@map("story_highlights")
}

// Hidden stories - users who can't see a story
model StoryHide {
  id        Int      @id @default(autoincrement())
  storyId   Int      @map("story_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId], name: "uk_story_hide")
  @@index([storyId], name: "idx_story_hide_story")
  @@index([userId], name: "idx_story_hide_user")
  @@map("story_hides")
}

// ════════════════════════════════════════════════════════════════
// PHASE 3: Facebook-style Post Action Menu
// ────────────────────────────────────────────────────────────────

// Feedback on posts (Interested / Not Interested)
model PostFeedback {
  id        Int        @id @default(autoincrement())
  postId    Int        @map("post_id")
  userId    Int        @map("user_id")
  type      String
  createdAt DateTime   @default(now()) @map("created_at")
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId], name: "uk_post_feedback")
  @@index([postId], name: "idx_feedback_post")
  @@map("post_feedbacks")
}

// Subscribe to post update notifications
model PostNotification {
  id        Int        @id @default(autoincrement())
  postId    Int        @map("post_id")
  userId    Int        @map("user_id")
  createdAt DateTime   @default(now()) @map("created_at")
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId], name: "uk_post_notification")
  @@index([postId], name: "idx_notification_post")
  @@map("post_notifications")
}

// Report a post
model PostReport {
  id         Int        @id @default(autoincrement())
  postId     Int        @map("post_id")
  reporterId Int        @map("reporter_id")
  reason     String
  details    String?    @db.Text
  status     String     @default("PENDING") @map("status")
  createdAt  DateTime   @default(now()) @map("created_at")
  post       SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter   User       @relation("PostReports", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([postId], name: "idx_report_post")
  @@index([status], name: "idx_report_status")
  @@map("post_reports")
}

// Snooze a user (hide their posts for 30 days)
model UserSnooze {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  snoozedUserId Int      @map("snoozed_user_id")
  until         DateTime @map("until")
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation("Snoozer", fields: [userId], references: [id], onDelete: Cascade)
  snoozedUser   User     @relation("SnoozedBy", fields: [snoozedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, snoozedUserId], name: "uk_user_snooze")
  @@index([userId], name: "idx_snooze_user")
  @@index([until], name: "idx_snooze_until")
  @@map("user_snoozes")
}

// Archive a post (soft delete)
model PostArchive {
  id        Int        @id @default(autoincrement())
  postId    Int        @unique @map("post_id")
  userId    Int        @map("user_id")
  createdAt DateTime   @default(now()) @map("created_at")
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("post_archives")
}

// ════════════════════════════════════════════════════════════════
// EXP_HUB — Code Snippet Library
// ────────────────────────────────────────────────────────────────
// A read-mostly internal library of code snippets, organized into
// a nested folder tree. Admins upload/edit; all users browse/copy.
// ════════════════════════════════════════════════════════════════

// ─── Enums ─────────────────────────────────────────────────────

enum SnippetStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("snippet_status")
}

// CODE = a normal code snippet; NOTE = a rich-text note (HTML in
// `noteContent`) that can embed pasted images; PROJECT = a reference
// project that bundles a GitHub repo link (`repoUrl`) and/or several
// named code blocks acting as files and/or downloadable attachments,
// plus a README-style note. All three kinds live in the same nested
// folder tree and share the list / search / bookmark pipeline.
enum SnippetKind {
  CODE
  NOTE
  PROJECT

  @@map("snippet_kind")
}

// ─── Nested Folder Tree ─────────────────────────────────────────

model SnippetCategory {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(100)
  slug           String    @unique(map: "uk_snippet_category_slug") @db.VarChar(100)
  // parentId = null means root-level category
  parentId       Int?      @map("parent_id")
  // Display order within the same parent (null parent = root level)
  sortOrder      Int       @default(0) @map("sort_order")
  // ─── Rich metadata (P2 upgrade — all optional/additive) ───────────
  // Short intro shown in the category header on the public page
  // ("what is Node.js / when to use it"). Markdown/plain, rendered client-side.
  description    String?   @db.Text
  // Icon: either a Lucide icon name (frontend maps to a component / brand
  // glyph via slug too) or an absolute URL to an uploaded image on R2.
  icon           String?   @db.VarChar(500)
  // Accent color for the top group tab + header (hex, e.g. "#3178c6").
  // Null = frontend derives a color from the slug.
  color          String?   @map("color") @db.VarChar(20)
  // Optional banner image (R2) for the category header.
  coverImageUrl  String?   @map("cover_image_url") @db.VarChar(2000)
  // Link to the official documentation ("Tài liệu chính thức" button).
  docsUrl        String?   @map("docs_url") @db.VarChar(500)
  // ─── AI-generated reference doc (P3 — full-English tech doc) ───────
  // A complete "what is X / used for / install / setup / combines with"
  // reference for a technology, stored as an ORDERED array of typed blocks:
  //   {type:'heading',text} | {type:'prose',html} |
  //   {type:'code',title?,language,code} | {type:'mermaid',code} |
  //   {type:'image',url,caption?}
  // Prose HTML is sanitized on render (same as Snippet.noteContent). This is
  // ADDITIVE — null means "no doc yet"; the short `description` above is
  // unaffected. Written by the admin AI doc generator (snippets.aiDoc.service).
  docBlocks      Json?     @map("doc_blocks")
  // BCP-47-ish language tag of the doc ("EN"). Null when no doc.
  docLang        String?   @map("doc_lang") @db.VarChar(8)
  // Model that produced the doc (audit) + when it was last (re)generated.
  docModel       String?   @map("doc_model") @db.VarChar(80)
  docGeneratedAt DateTime? @map("doc_generated_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Self-relation for nested tree
  parent   SnippetCategory?  @relation("SnippetCategoryParent", fields: [parentId], references: [id], onDelete: Cascade)
  children SnippetCategory[] @relation("SnippetCategoryParent")

  // Snippets in this category
  snippets Snippet[]

  @@index([parentId, sortOrder], name: "idx_snippet_category_parent_order")
  @@index([slug], name: "idx_snippet_category_slug")
  @@map("snippet_categories")
}

// ─── Tags ───────────────────────────────────────────────────────

model SnippetTag {
  id   Int    @id @default(autoincrement())
  name String @unique(map: "uk_snippet_tag_name") @db.VarChar(50)
  slug String @unique(map: "uk_snippet_tag_slug") @db.VarChar(50)

  // M:N with Snippet goes THROUGH the SnippetToTag join table only —
  // do NOT add a direct `snippets Snippet[]` here (prisma format would
  // auto-invent a bogus `snippets.snippetTagId` column that doesn't
  // exist in the migration/DB).
  snippetToTags SnippetToTag[]

  @@index([slug], name: "idx_snippet_tag_slug")
  @@map("snippet_tags")
}

// ─── Snippets ───────────────────────────────────────────────────

model Snippet {
  id           Int           @id @default(autoincrement())
  title        String        @db.VarChar(255)
  slug         String        @unique(map: "uk_snippet_slug") @db.VarChar(255)
  description  String?       @db.Text
  // CODE = normal code snippet; NOTE = rich-text note with embedded images.
  kind         SnippetKind   @default(CODE)
  // Programming language (e.g. "javascript", "python", "java", "sql").
  // For NOTE records this is unused (stored as empty string).
  language     String        @db.VarChar(40)
  // Legacy single code content — kept as a fallback / the first block for
  // snippets created before multi-block support. New snippets store their
  // named blocks in `codeBlocks` below.
  code         String        @db.Text
  // Named, ordered code blocks: JSON array of { name, language, code }.
  // A snippet can hold several ("Code 1", "Code 2", …). When present this is
  // the source of truth; `code`/`language` above mirror the first block.
  codeBlocks   Json?         @map("code_blocks")
  // Optional rich-text (HTML) NOTE section of the snippet — supports pasted
  // images. This is a SECTION of the snippet, shown alongside its code.
  noteContent  String?       @map("note_content") @db.Text
  // Detailed explanation for the code (HTML content)
  explanation  String?       @map("explanation") @db.Text
  // YouTube video URL for tutorial
  youtubeUrl   String?       @map("youtube_url") @db.VarChar(500)
  // External reference website URL (embedded like the tutorial video)
  referenceUrl String?       @map("reference_url") @db.VarChar(500)
  // GitHub repository URL for PROJECT-kind entries. Rendered as a repo
  // card (owner/repo + ⭐ stars, resolved via github.service) on the
  // public detail. Null for plain CODE/NOTE snippets.
  repoUrl      String?       @map("repo_url") @db.VarChar(500)
  status       SnippetStatus @default(DRAFT)
  // Denormalised counters (updated by API, not transactions)
  viewCount    Int           @default(0) @map("view_count")
  copyCount    Int           @default(0) @map("copy_count")
  upvoteCount  Int           @default(0) @map("upvote_count")
  // Optional: a preview/test URL for the snippet
  previewUrl   String?       @map("preview_url") @db.VarChar(500)

  categoryId Int? @map("category_id")
  authorId   Int? @map("author_id")

  // Full-text search vector — a GENERATED ALWAYS STORED tsvector over
  // title + description + code (config 'simple'). Maintained by Postgres,
  // queried only via $queryRaw (websearch_to_tsquery); Unsupported so
  // Prisma tracks the column but never reads/writes it.
  searchVector Unsupported("tsvector")? @map("search_vector")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ─── Relations ───────────────────────────────────────────────
  category SnippetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author   User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)

  // Many-to-many via SnippetToTag join table
  snippetToTags SnippetToTag[]
  versions      SnippetVersion[]
  variables     SnippetVariable[]
  attachments   SnippetAttachment[]
  comments      SnippetComment[]
  upvotes       SnippetUpvote[]
  bookmarks     SnippetBookmark[]
  reactions     SnippetReaction[]

  @@index([categoryId], name: "idx_snippets_category")
  @@index([authorId], name: "idx_snippets_author")
  @@index([status], name: "idx_snippets_status")
  @@index([language], name: "idx_snippets_language")
  @@index([slug], name: "idx_snippets_slug")
  @@index([status, copyCount(sort: Desc)], name: "idx_snippets_status_copy")
  @@index([status, createdAt(sort: Desc)], name: "idx_snippets_status_created")
  @@index([status, upvoteCount(sort: Desc)], name: "idx_snippets_status_upvote")
  @@map("snippets")
}

// ─── Snippet <-> Tag join table ─────────────────────────────────

model SnippetToTag {
  snippetId Int @map("snippet_id")
  tagId     Int @map("tag_id")

  snippet Snippet    @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  tag     SnippetTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([snippetId, tagId], map: "pk_snippet_to_tag")
  @@index([tagId], name: "idx_snippet_to_tag_tag")
  @@map("snippet_to_tags")
}

// ─── Version History ─────────────────────────────────────────────
// Every snippet update creates a new version row so we can diff.

model SnippetVersion {
  id         Int      @id @default(autoincrement())
  snippetId  Int      @map("snippet_id")
  code       String   @db.Text
  // Who made the edit (nullable for the initial version)
  editedById Int?     @map("edited_by_id")
  editedAt   DateTime @default(now()) @map("edited_at")

  snippet  Snippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  editedBy User?   @relation(fields: [editedById], references: [id], onDelete: SetNull)

  @@index([snippetId, editedAt(sort: Desc)], name: "idx_snippet_versions_snippet_time")
  @@map("snippet_versions")
}

// ─── Template Variables ───────────────────────────────────────────
// For snippets with {{variable}} placeholders.
// When a user copies, they fill in values before the final code is copied.

model SnippetVariable {
  id           Int     @id @default(autoincrement())
  snippetId    Int     @map("snippet_id")
  // Key must match the placeholder text, e.g. "apiKey" for {{apiKey}}
  key          String  @db.VarChar(100)
  // Human-readable label shown in the form, e.g. "API Key"
  label        String  @db.VarChar(200)
  // Default value pre-filled in the copy form
  defaultValue String? @map("default_value") @db.Text
  // Display order
  sortOrder    Int     @default(0) @map("sort_order")

  snippet Snippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@unique([snippetId, key], name: "uk_snippet_variable_snippet_key")
  @@index([snippetId], name: "idx_snippet_variables_snippet")
  @@map("snippet_variables")
}

// ─── File Attachments (optional) ────────────────────────────────
// Optional files attached to a snippet (e.g. a sample JSON config,
// an image, a diagram). Stored on R2.

model SnippetAttachment {
  id           Int      @id @default(autoincrement())
  snippetId    Int      @map("snippet_id")
  // Fully qualified R2/public URL
  fileUrl      String   @map("file_url") @db.VarChar(2000)
  originalName String   @map("original_name") @db.VarChar(255)
  fileType     String?  @map("file_type") @db.VarChar(100)
  fileSize     Int?     @map("file_size") // bytes
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  snippet Snippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@index([snippetId], name: "idx_snippet_attachments_snippet")
  @@map("snippet_attachments")
}

// ─── Comments (Phase 2) ─────────────────────────────────────────

model SnippetComment {
  id        Int      @id @default(autoincrement())
  snippetId Int      @map("snippet_id")
  userId    Int?     @map("user_id")
  // Optional parentId for threaded replies (nullable = top-level)
  parentId  Int?     @map("parent_id")
  content   String   @db.Text
  isEdited  Boolean  @default(false) @map("is_edited")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  snippet   Snippet                  @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  user      User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  parent    SnippetComment?          @relation("SnippetCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   SnippetComment[]         @relation("SnippetCommentReplies")
  reactions SnippetCommentReaction[]

  @@index([snippetId, createdAt(sort: Desc)], name: "idx_snippet_comments_snippet_time")
  @@index([parentId], name: "idx_snippet_comments_parent")
  @@map("snippet_comments")
}

// ─── Reactions (emoji) ──────────────────────────────────────────
// GitHub-style: a user may add several distinct emoji to one target, but each
// (target, user, emoji) combination is unique. Logged-in users only — no
// anonymous reactions, so we always have a userId.

model SnippetReaction {
  id        Int      @id @default(autoincrement())
  snippetId Int      @map("snippet_id")
  userId    Int      @map("user_id")
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at")

  snippet Snippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([snippetId, userId, emoji], name: "uk_snippet_reaction")
  @@index([snippetId], name: "idx_snippet_reactions_snippet")
  @@map("snippet_reactions")
}

model SnippetCommentReaction {
  id        Int      @id @default(autoincrement())
  commentId Int      @map("comment_id")
  userId    Int      @map("user_id")
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at")

  comment SnippetComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji], name: "uk_snippet_comment_reaction")
  @@index([commentId], name: "idx_snippet_comment_reactions_comment")
  @@map("snippet_comment_reactions")
}

// ─── Upvotes (Phase 2) ──────────────────────────────────────────
// IP hash for anonymous upvotes, userId for authenticated upvotes.

model SnippetUpvote {
  // Exactly one of userId / ipHash is set
  id        Int      @id @default(autoincrement())
  snippetId Int      @map("snippet_id")
  userId    Int?     @map("user_id")
  ipHash    String?  @map("ip_hash") @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at")

  snippet Snippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Enforce unique upvote per snippet+ipHash (IP-based anonymous upvotes)
  // For authenticated users: service layer checks userId uniqueness separately
  @@unique([snippetId, ipHash], name: "uk_snippet_upvote_snippet_ip")
  @@index([snippetId], name: "idx_snippet_upvotes_snippet")
  @@index([userId], name: "idx_snippet_upvotes_user")
  @@map("snippet_upvotes")
}

// ─── Bookmarks ───────────────────────────────────────────────────
// Bookmarks are scoped to the current user (by userId if logged in,
// by ipHash for anonymous users). Anonymous and authenticated
// bookmarks are kept separate so a logged-in user sees only their
// own list when they sign in.

model SnippetBookmark {
  id        Int      @id @default(autoincrement())
  snippetId Int      @map("snippet_id")
  userId    Int?     @map("user_id")
  ipHash    String?  @map("ip_hash") @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at")

  snippet Snippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Prevent duplicate bookmarks for the same snippet+ipHash
  // For authenticated users: service layer checks userId uniqueness
  @@unique([snippetId, ipHash], name: "uk_snippet_bookmark_snippet_ip")
  @@index([snippetId], name: "idx_snippet_bookmarks_snippet")
  @@index([userId, createdAt(sort: Desc)], name: "idx_snippet_bookmarks_user_recent")
  @@index([ipHash, createdAt(sort: Desc)], name: "idx_snippet_bookmarks_ip_recent")
  @@map("snippet_bookmarks")
}

// ─── Webhook Configurations (Phase 2) ────────────────────────────

model SnippetWebhook {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  url         String   @db.VarChar(2000)
  // Event types: "snippet.published" | "snippet.updated" | "snippet.created"
  event       String   @db.VarChar(50)
  // Optional custom headers (JSON: { "Authorization": "Bearer ..." })
  headers     Json?    @db.JsonB
  isActive    Boolean  @default(true) @map("is_active")
  createdById Int?     @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isActive, event], name: "idx_snippet_webhooks_active_event")
  @@map("snippet_webhooks")
}

// ============================================================
// MY LANGUAGE — multi-language learning platform (additive)
// Public read + admin CRUD content, plus per-user SRS progress.
// All IDs Int autoincrement, snake_case @map, plural @@map — matches
// the rest of this schema. Content cascades on Language delete.
// Full-text search on vocab_words uses a raw-SQL tsvector column
// (created in the migration, NOT declared here) — same pattern as
// the projects module.
// ============================================================

model Language {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100) // "Tiếng Nhật"
  nameEn    String   @map("name_en") @db.VarChar(100) // "Japanese"
  code      String   @unique(map: "uk_language_code") @db.VarChar(10) // "ja", "en"
  flagEmoji String   @map("flag_emoji") @db.VarChar(16)
  coverUrl  String?  @map("cover_url") @db.VarChar(500)
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  alphabetGroups    LangAlphabetGroup[]
  vocabCategories   LangVocabCategory[]
  grammarPoints     LangGrammarPoint[]
  listeningItems    LangListeningItem[]
  conversationItems LangConversationItem[]
  readingArticles   LangReadingArticle[]
  qnaItems          LangQnaItem[]
  quizResults       LangQuizResult[]
  vocabCollections  LangVocabCollection[]
  notebookFolders   LangNotebookFolder[]
  notebookEntries   LangNotebookEntry[]
  roadmapNodes      LangRoadmapNode[]
  gameStates        LangGameState[]
  lessonProgress    LangLessonProgress[]
  hanziChars        LangHanziChar[]

  @@index([isActive, order], name: "idx_languages_active_order")
  @@map("languages")
}

// ─── My Language — Han characters (kanji / hanzi) writing practice ───
// Stroke PATHS are not stored here: hanzi-writer-data (9,575 chars) already has
// them, served from our own origin so the CSP never sees a third-party CDN.
// This table holds what that data cannot know — the Vietnamese meaning, the
// mnemonic, and the admin's own illustrations.
model LangHanziChar {
  id          Int     @id @default(autoincrement())
  languageId  Int     @map("language_id")
  char        String  @db.VarChar(8) // 漢 — one grapheme (surrogate pairs fit in 8)
  level       String? @db.VarChar(20) // N5..N1 | HSK1..HSK6
  strokeCount Int?    @map("stroke_count")

  // Readings. JA needs both on'yomi and kun'yomi; ZH uses pinyin. Kept as
  // separate columns rather than one blob so a language only fills what it has.
  onyomi  String? @db.VarChar(120) // カン、ケン
  kunyomi String? @db.VarChar(120) // みなもと
  pinyin  String? @db.VarChar(120) // hàn

  meaningVi String   @map("meaning_vi") @db.Text // "Hán, sông Hán"
  mnemonic  String?  @db.Text // cách nhớ — admin viết hoặc AI sinh
  radical   String?  @db.VarChar(16) // 氵
  breakdown String?  @db.Text // chiết tự: 氵(nước) + 難(khó)
  // Compound words that USE this char — what makes a character stick.
  examples  Json     @default("[]") @db.JsonB // [{word,reading,meaningVi}]
  // 1–3 admin-uploaded illustrations (R2 URLs). Order is the display order.
  images    Json     @default("[]") @db.JsonB // [{url,caption}]
  note      String?  @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  language Language            @relation(fields: [languageId], references: [id], onDelete: Cascade)
  progress LangHanziProgress[]

  // One row per character per language — re-running a seed must never double up.
  @@unique([languageId, char], name: "uk_lang_hanzi_lang_char", map: "uk_lang_hanzi_lang_char")
  @@index([languageId, level, order], name: "idx_lang_hanzi_lang_level")
  @@map("lang_hanzi_chars")
}

// Per-user writing progress. userId has no FK (matches the rest of the module),
// so deleting a user leaves rows that are simply never read again.
model LangHanziProgress {
  id     Int @id @default(autoincrement())
  userId Int @map("user_id")
  charId Int @map("char_id")

  // How the learner is doing, not just whether they looked at it.
  attempts     Int      @default(0) // quiz runs finished
  mistakes     Int      @default(0) // strokes drawn wrong across all attempts
  bestMistakes Int?     @map("best_mistakes") // fewest mistakes in one run — the real skill signal
  learned      Boolean  @default(false) // one clean run from memory
  lastAt       DateTime @default(now()) @map("last_at")

  char LangHanziChar @relation(fields: [charId], references: [id], onDelete: Cascade)

  @@unique([userId, charId], name: "uk_lang_hanzi_progress", map: "uk_lang_hanzi_progress")
  @@index([userId, lastAt], name: "idx_lang_hanzi_progress_user")
  @@map("lang_hanzi_progress")
}

// ===== 1. ALPHABET =====
model LangAlphabetGroup {
  id          Int      @id @default(autoincrement())
  languageId  Int      @map("language_id")
  name        String   @db.VarChar(100) // "Hiragana", "Katakana", "Kanji N5"
  description String?  @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  language Language           @relation(fields: [languageId], references: [id], onDelete: Cascade)
  items    LangAlphabetItem[]

  @@index([languageId, order], name: "idx_lang_alphabet_groups_lang")
  @@map("lang_alphabet_groups")
}

model LangAlphabetItem {
  id           Int      @id @default(autoincrement())
  groupId      Int      @map("group_id")
  character    String   @db.VarChar(32) // "あ"
  romanization String?  @db.VarChar(64) // "a"
  audioUrl     String?  @map("audio_url") @db.VarChar(500)
  imageUrl     String?  @map("image_url") @db.VarChar(500)
  note         String?  @db.Text
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

