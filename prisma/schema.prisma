  @@index([languageId, order], name: "idx_lang_reading_articles_lang")
  @@map("lang_reading_articles")
}

// ===== 7. Q&A =====
model LangQnaItem {
  id            Int      @id @default(autoincrement())
  languageId    Int      @map("language_id")
  level         String?  @db.VarChar(20) // free-text level tag (A1..C2 | N5..N1 | HSK)
  question      String   @db.Text
  answer        String   @db.Text
  pronunciation String?  @db.Text
  meaningVi     String?  @map("meaning_vi") @db.Text
  audioUrl      String?  @map("audio_url") @db.VarChar(500)
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
