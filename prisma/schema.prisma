  transcript  String?             @db.Text
  translation String?             @db.Text
  questions   Json?               @db.JsonB // [{ question, answer }]
  order       Int                 @default(0)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@index([languageId, order], name: "idx_lang_listening_items_lang")
  @@map("lang_listening_items")
}

// ===== 5. DAILY CONVERSATION =====
model LangConversationItem {
  id                    Int      @id @default(autoincrement())
  languageId            Int      @map("language_id")
  level                 String?  @db.VarChar(20) // free-text level tag (A1..C2 | N5..N1 | HSK)
  question              String   @db.Text
  answer                String   @db.Text
  questionPronunciation String?  @map("question_pronunciation") @db.Text
  answerPronunciation   String?  @map("answer_pronunciation") @db.Text
