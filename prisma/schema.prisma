  itemType       LangItemType    @map("item_type")
  itemId         Int             @map("item_id")
  status         LangLearnStatus @default(NEW)
  // SRS fields (simplified SM-2)
  easeFactor     Float           @default(2.5) @map("ease_factor")
  intervalDays   Int             @default(0) @map("interval_days")
  repetitions    Int             @default(0)
  nextReviewAt   DateTime?       @map("next_review_at")
  lastReviewedAt DateTime?       @map("last_reviewed_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId], map: "uk_lang_progress_user_item")
  @@index([userId, nextReviewAt], name: "idx_lang_progress_user_due")
  @@map("lang_user_progress")
}

model LangQuizResult {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  languageId Int      @map("language_id")
  categoryId Int?     @map("category_id")
  score      Int
  total      Int
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@index([userId, languageId, createdAt(sort: Desc)], name: "idx_lang_quiz_user_lang")
  @@map("lang_quiz_results")
}

// ===== FAVORITES & COLLECTIONS (per-user vocab playlists) =====
model LangVocabFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  wordId    Int      @map("word_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  word LangVocabWord @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId], map: "uk_lang_vocab_fav_user_word")
  @@index([userId, createdAt(sort: Desc)], name: "idx_lang_vocab_fav_user")
  @@map("lang_vocab_favorites")
}

model LangVocabCollection {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  languageId Int      @map("language_id")
  name       String   @db.VarChar(120)
  icon       String?  @db.VarChar(16) // emoji
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  language Language                  @relation(fields: [languageId], references: [id], onDelete: Cascade)
  words    LangVocabCollectionWord[]

  @@unique([userId, languageId, name], map: "uk_lang_vocab_coll_user_name")
  @@index([userId, languageId, order], name: "idx_lang_vocab_coll_user_lang")
  @@map("lang_vocab_collections")
}

model LangVocabCollectionWord {
  id           Int      @id @default(autoincrement())
  collectionId Int      @map("collection_id")
  wordId       Int      @map("word_id")
  createdAt    DateTime @default(now()) @map("created_at")

  collection LangVocabCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  word       LangVocabWord       @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([collectionId, wordId], map: "uk_lang_vocab_coll_word")
  @@index([wordId], name: "idx_lang_vocab_coll_word_word")
  @@map("lang_vocab_collection_words")
}

enum LangListeningSource {
  UPLOAD
  YOUTUBE

  @@map("lang_listening_source")
}

enum LangReadingType {
  IMAGE_LIST
  TEXT

  @@map("lang_reading_type")
}

enum LangItemType {
  VOCAB
  ALPHABET
  GRAMMAR
  LISTENING
  CONVERSATION
  READING
  QNA

  @@map("lang_item_type")
}

enum LangLearnStatus {
  NEW
  LEARNING
  REVIEWING
  MASTERED

  @@map("lang_learn_status")
}

// ===== NOTEBOOK — per-user, per-language, nested folders =====
model LangNotebookFolder {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  languageId Int      @map("language_id")
  parentId   Int?     @map("parent_id")
  name       String   @db.VarChar(120)
  icon       String?  @db.VarChar(64)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User                 @relation("UserLangNotebookFolders", fields: [userId], references: [id], onDelete: Cascade)
  language Language             @relation(fields: [languageId], references: [id], onDelete: Cascade)
  parent   LangNotebookFolder?  @relation("LangNbSub", fields: [parentId], references: [id], onDelete: Cascade)
  children LangNotebookFolder[] @relation("LangNbSub")
  entries  LangNotebookEntry[]

  @@index([userId, languageId, sortOrder], name: "idx_lang_nb_folder_user")
  @@map("lang_notebook_folders")
}

model LangNotebookEntry {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")
  languageId     Int       @map("language_id")
  folderId       Int?      @map("folder_id")
  kind           String    @default("note") @db.VarChar(32) // note | explanation | vocab | grammar | pronunciation | writing
  title          String    @db.VarChar(255)
  body           String    @db.Text // markdown
  reading        String?   @db.VarChar(255)
  meaning        String?   @db.Text
  sortOrder      Int       @default(0) @map("sort_order")
  // SRS (simplified SM-2) — spaced-repetition review of saved entries.
  easeFactor     Float     @default(2.5) @map("ease_factor")
  intervalDays   Int       @default(0) @map("interval_days")
  repetitions    Int       @default(0)
  nextReviewAt   DateTime? @map("next_review_at")
  lastReviewedAt DateTime? @map("last_reviewed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user     User                @relation("UserLangNotebookEntries", fields: [userId], references: [id], onDelete: Cascade)
  language Language            @relation(fields: [languageId], references: [id], onDelete: Cascade)
  folder   LangNotebookFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId, languageId, folderId], name: "idx_lang_nb_entry_user")
  @@index([userId, nextReviewAt], name: "idx_lang_nb_entry_due")
  @@map("lang_notebook_entries")
}

// ============================================================
// MONEYFLOW — Personal finance module (Phase 1)
// ------------------------------------------------------------
// Private, per-user data. Every model carries `userId Int` and is
// ALWAYS queried with `where: { userId }` in the service layer —
// the id is derived from the server session (req.userId), never
// from the client. Money is Decimal(18,2); no floats anywhere.
// Type/status fields are plain strings (validated in the route
// layer with express-validator) rather than Prisma enums so the
// vocab can grow without a migration.
// ============================================================

// ===== WALLETS (accounts) =====
model Wallet {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  name       String   @db.VarChar(120) // "Tiền mặt", "Vietcombank", "Momo"
  type       String   @db.VarChar(20) // CASH | BANK | EWALLET | OTHER
  icon       String?  @db.VarChar(40) // emoji or icon name
  color      String?  @db.VarChar(20) // hex for UI
  balance    Decimal  @default(0) @db.Decimal(18, 2) // maintained by transactions
  currency   String   @default("VND") @db.VarChar(8)
  isArchived Boolean  @default(false) @map("is_archived")
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  adjustments WalletAdjustment[]

  @@index([userId], name: "idx_fin_wallets_user")
  @@map("finance_wallets")
}

// Audit trail for manual balance adjustments and wallet-to-wallet
// transfers. A transfer creates a matched pair (out of A, into B).
model WalletAdjustment {
  id                   Int      @id @default(autoincrement())
  userId               Int      @map("user_id")
  walletId             Int      @map("wallet_id")
  kind                 String   @db.VarChar(20) // ADJUSTMENT | TRANSFER
  amount               Decimal  @db.Decimal(18, 2) // signed: + credit, - debit
  balanceAfter         Decimal  @map("balance_after") @db.Decimal(18, 2)
  counterpartyWalletId Int?     @map("counterparty_wallet_id") // the other side of a transfer
  reason               String?  @db.Text
  createdAt            DateTime @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId, walletId], name: "idx_fin_wallet_adj_user_wallet")
  @@map("finance_wallet_adjustments")
}

// ===== INCOME / SALARY =====
model IncomeSource {
  id                  Int      @id @default(autoincrement())
  userId              Int      @map("user_id")
  name                String   @db.VarChar(150) // "Công ty A", "Freelance"
  type                String   @db.VarChar(20) // SALARY | FREELANCE | PART_TIME | OTHER
  payType             String   @map("pay_type") @db.VarChar(20) // MONTHLY | HOURLY | PER_JOB
  baseSalary          Decimal? @map("base_salary") @db.Decimal(18, 2) // for MONTHLY
  hourlyRate          Decimal? @map("hourly_rate") @db.Decimal(18, 2) // for HOURLY
  currency            String   @default("VND") @db.VarChar(8) // VND | USD — what baseSalary/hourlyRate are denominated in
  otMultiplierNormal  Decimal  @default(1.5) @map("ot_multiplier_normal") @db.Decimal(4, 2)
  otMultiplierHoliday Decimal  @default(2.0) @map("ot_multiplier_holiday") @db.Decimal(4, 2)
  isActive            Boolean  @default(true) @map("is_active")
  note                String?  @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  workLogs      WorkLog[]
  incomeEntries IncomeEntry[]

  @@index([userId], name: "idx_fin_income_sources_user")
  @@map("finance_income_sources")
}

model WorkLog {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  sourceId       Int      @map("source_id")
  date           DateTime @db.Date
  hoursNormal    Decimal  @default(0) @map("hours_normal") @db.Decimal(5, 2)
  hoursOT        Decimal  @default(0) @map("hours_ot") @db.Decimal(5, 2)
  hoursOTHoliday Decimal  @default(0) @map("hours_ot_holiday") @db.Decimal(5, 2)
  note           String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  source IncomeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceId, date], name: "uk_fin_worklog_user_source_date")
  @@index([userId, date], name: "idx_fin_worklogs_user_date")
  @@map("finance_work_logs")
}

model IncomeEntry {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  sourceId  Int?     @map("source_id")
  walletId  Int      @map("wallet_id") // which wallet it went into
  amount    Decimal  @db.Decimal(18, 2)
  currency  String   @default("VND") @db.VarChar(8)
  date      DateTime @db.Date
  type      String   @db.VarChar(20) // SALARY | BONUS | OT_PAYOUT | FREELANCE | OTHER
  note      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  source IncomeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([userId, date], name: "idx_fin_income_entries_user_date")
  @@index([userId, sourceId], name: "idx_fin_income_entries_user_source")
  @@map("finance_income_entries")
}

// ===== DEBTS =====
model Debt {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  lenderName    String   @map("lender_name") @db.VarChar(150) // "App X", "Ngân hàng Y"
  lenderType    String   @map("lender_type") @db.VarChar(20) // LOAN_APP | BANK | PERSON | CREDIT_CARD | OTHER
  principal     Decimal  @db.Decimal(18, 2) // original amount borrowed
  currency      String   @default("VND") @db.VarChar(8)
  interestType  String   @map("interest_type") @db.VarChar(20) // FLAT_MONTHLY | REDUCING_BALANCE | DAILY_PERCENT | NO_INTEREST
  interestRate  Decimal  @map("interest_rate") @db.Decimal(8, 4) // %/month (FLAT/REDUCING) or %/day (DAILY_PERCENT)
  startDate     DateTime @map("start_date") @db.Date
  termMonths    Int?     @map("term_months")
  paymentDay    Int?     @map("payment_day") // day of month due (1-31)
  status        String   @default("ACTIVE") @db.VarChar(20) // ACTIVE | PAID_OFF | OVERDUE
  note          String?  @db.Text
  attachmentUrl String?  @map("attachment_url") @db.VarChar(500) // contract photo on R2
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  payments DebtPayment[]      @relation("DebtToPayment")
  schedule DebtScheduleItem[] @relation("DebtToSchedule")

  @@index([userId, status], name: "idx_fin_debts_user_status")
  @@map("finance_debts")
}

model DebtScheduleItem {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  debtId        Int       @map("debt_id")
  installmentNo Int       @map("installment_no") // 1-based sequence
  dueDate       DateTime  @map("due_date") @db.Date
  amountDue     Decimal   @map("amount_due") @db.Decimal(18, 2) // principalPart + interestPart
  principalPart Decimal   @map("principal_part") @db.Decimal(18, 2)
  interestPart  Decimal   @map("interest_part") @db.Decimal(18, 2)
  isPaid        Boolean   @default(false) @map("is_paid")
  paidAt        DateTime? @map("paid_at")
  paymentId     Int?      @map("payment_id") // link to the DebtPayment that settled it
  createdAt     DateTime  @default(now()) @map("created_at")

  debt Debt @relation("DebtToSchedule", fields: [debtId], references: [id], onDelete: Cascade)

  @@index([userId, dueDate, isPaid], name: "idx_fin_debt_sched_user_due_paid")
  @@index([debtId, installmentNo], name: "idx_fin_debt_sched_debt_seq")
  @@map("finance_debt_schedule_items")
}

model DebtPayment {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  debtId    Int      @map("debt_id")
  walletId  Int?     @map("wallet_id") // which wallet the payment came from
  amount    Decimal  @db.Decimal(18, 2)
  date      DateTime @db.Date
  note      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  debt Debt @relation("DebtToPayment", fields: [debtId], references: [id], onDelete: Cascade)

  @@index([userId, date], name: "idx_fin_debt_payments_user_date")
  @@index([debtId], name: "idx_fin_debt_payments_debt")
  @@map("finance_debt_payments")
}

// ===== EXPENSES =====
model ExpenseCategory {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  name          String   @db.VarChar(120) // "Ăn uống", "Đi lại"
  icon          String?  @db.VarChar(40)
  color         String?  @db.VarChar(20)
  order         Int      @default(0)
  monthlyBudget Decimal? @map("monthly_budget") @db.Decimal(18, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  expenses Expense[]

  @@index([userId], name: "idx_fin_expense_categories_user")
  @@map("finance_expense_categories")
}

model Expense {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  categoryId  Int      @map("category_id")
  walletId    Int      @map("wallet_id")
  amount      Decimal  @db.Decimal(18, 2)
  currency    String   @default("VND") @db.VarChar(8)
  date        DateTime @db.Date
  description String?  @db.VarChar(500)
  receiptUrl  String?  @map("receipt_url") @db.VarChar(500) // photo on R2
  isRecurring Boolean  @default(false) @map("is_recurring")
  recurringId Int?     @map("recurring_id") // link to RecurringTransaction
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId, date], name: "idx_fin_expenses_user_date")
  @@index([userId, categoryId], name: "idx_fin_expenses_user_category")
  @@map("finance_expenses")
}

model RecurringTransaction {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  kind        String   @db.VarChar(10) // EXPENSE | INCOME
  amount      Decimal  @db.Decimal(18, 2)
  categoryId  Int?     @map("category_id")
  walletId    Int      @map("wallet_id")
  description String   @db.VarChar(200) // "Tiền nhà", "Netflix"
  frequency   String   @db.VarChar(10) // MONTHLY | WEEKLY | YEARLY
  dayOfMonth  Int?     @map("day_of_month")
  nextRunAt   DateTime @map("next_run_at")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId, nextRunAt, isActive], name: "idx_fin_recurring_user_next_active")
  @@map("finance_recurring_transactions")
}

// ============================================================
// MONEYFLOW — Phase 2 (Investments & Savings). Same rules as Phase 1:
// per-user (userId Int), Decimal(18,2) money, no floats, scoped in service.
// ============================================================

// ===== INVESTMENTS =====
model Investment {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  type            String   @db.VarChar(10) // SELF (skills/courses) | ASSET (stocks/gold/crypto)
  name            String   @db.VarChar(200) // "Khóa Unity", "Vàng SJC"
  amount          Decimal  @db.Decimal(18, 2) // money put in
  currency        String   @default("VND") @db.VarChar(8)
  date            DateTime @db.Date
  walletId        Int?     @map("wallet_id") // wallet the money came from (optional)
  expectedOutcome String?  @map("expected_outcome") @db.Text // SELF: expected skill/return
  currentValue    Decimal? @map("current_value") @db.Decimal(18, 2) // ASSET: manually updated value
  status          String   @default("ACTIVE") @db.VarChar(12) // ACTIVE | COMPLETED | SOLD
  outcomeNote     String?  @map("outcome_note") @db.Text // SELF: "kết quả nhận được" on completion
  note            String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId, type], name: "idx_fin_investments_user_type")
  @@map("finance_investments")
}

// ===== SAVINGS =====
model SavingsAccount {
  id                  Int      @id @default(autoincrement())
  userId              Int      @map("user_id")
  bankName            String   @map("bank_name") @db.VarChar(150)
  amount              Decimal  @db.Decimal(18, 2)
  currency            String   @default("VND") @db.VarChar(8)
  interestRatePerYear Decimal  @map("interest_rate_per_year") @db.Decimal(6, 3) // %/year
  termMonths          Int      @map("term_months")
  startDate           DateTime @map("start_date") @db.Date
  maturityDate        DateTime @map("maturity_date") @db.Date // computed on create
  autoRenew           Boolean  @default(false) @map("auto_renew")
  walletId            Int?     @map("wallet_id") // funding wallet (optional)
  status              String   @default("ACTIVE") @db.VarChar(12) // ACTIVE | MATURED | WITHDRAWN
  note                String?  @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([userId, status], name: "idx_fin_savings_accounts_user_status")
  @@map("finance_savings_accounts")
}

model SavingsGoal {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  name          String    @db.VarChar(150) // "Mua MacBook", "Quỹ khẩn cấp"
  targetAmount  Decimal   @map("target_amount") @db.Decimal(18, 2)
  currentAmount Decimal   @default(0) @map("current_amount") @db.Decimal(18, 2)
  deadline      DateTime? @db.Date
  icon          String?   @db.VarChar(40)
  status        String    @default("ACTIVE") @db.VarChar(12) // ACTIVE | ACHIEVED
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([userId], name: "idx_fin_savings_goals_user")
  @@map("finance_savings_goals")
}

// User-entered VND↔USD exchange rate. Append-only history: each update
// inserts a row; the newest row is the current rate used to convert USD
// amounts into VND across dashboard/report aggregations.
model FinanceFxRate {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  vndPerUsd Decimal  @map("vnd_per_usd") @db.Decimal(18, 2) // ₫ for 1 $
  note      String?  @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt], name: "idx_fin_fx_rates_user_created")
  @@map("finance_fx_rates")
}

// ── Admin announcements ("Diễn đàn / Tin tức") ────────────────────
// Site-wide announcements the super-admin posts (maintenance, updates,
// new docs, general notices). Broadcast to all online users via socket
// on create; the /forum page is the persistent record.
model Announcement {
  id            Int      @id @default(autoincrement())
  title         String   @db.VarChar(255)
  body          String   @db.Text
  // 'maintenance' | 'update' | 'docs' | 'general'
  category      String   @default("general") @db.VarChar(20)
  coverImageUrl String?  @map("cover_image_url") @db.VarChar(500)
  isPinned      Boolean  @default(false) @map("is_pinned")
  authorId      Int?     @map("author_id")
  author        User?    @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([isPinned, createdAt], name: "idx_announcements_pinned_created")
  @@map("announcements")
}

// ═══════════════════════════════════════════════════════════════════
//  INTERVIEW SIMULATOR  (Phase 2 — STATIC self-assessment engine)
//  AI/Voice/Coding/System-Design/RAG modes are ACCOMMODATED via enum
//  values + nullable columns but NOT implemented in Phase 2.
//  All tables are self-contained: user ownership is a plain `userId Int`
//  + index (NO FK to `users`) to keep this module decoupled from the
//  core schema. Everything is gated behind the INTERVIEW_ENABLED
//  frontend flag, so these tables are inert until the feature ships.
//  Question full-text search (search_vector tsvector + GIN) is added by
//  a separate hand-written raw-SQL migration, mirroring the Projects
//  module — it is intentionally NOT modelled here.
// ═══════════════════════════════════════════════════════════════════

enum InterviewLevel {
  INTERN
  FRESHER
  JUNIOR
  MID
  SENIOR
  LEAD
  PRINCIPAL
}

enum InterviewQuestionType {
  CONCEPTUAL
  CODING
  SYSTEM_DESIGN
  BEHAVIORAL
  SCENARIO
  MCQ
}

enum InterviewQuestionSource {
  SEED
  ADMIN
  AI_GENERATED
  IMPORTED
}

enum InterviewContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InterviewSessionMode {
  TEXT
  VOICE
  CODING
  SYSTEM_DESIGN
}

enum InterviewEngineMode {
  STATIC
  HYBRID
  FULL_AI
}

enum InterviewLanguage {
  VI
  EN
}

enum InterviewSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum InterviewHireRecommendation {
  STRONG_NO
  NO
  LEAN_NO
  LEAN_YES
  YES
  STRONG_YES
}

enum InterviewMasteryLevel {
  UNSEEN
  SHAKY
  LEARNING
  SOLID
  MASTERED
}

model InterviewDomain {
  id          Int                    @id @default(autoincrement())
  slug        String                 @unique @db.VarChar(80)
  name        String                 @db.VarChar(120)
  nameVi      String?                @map("name_vi") @db.VarChar(120)
  description String?                @db.Text
  icon        String?                @db.VarChar(60)
  sortOrder   Int                    @default(0) @map("sort_order")
  status      InterviewContentStatus @default(PUBLISHED)
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  tracks InterviewTrack[]

  @@map("interview_domains")
}

model InterviewTrack {
  id          Int                    @id @default(autoincrement())
  domainId    Int                    @map("domain_id")
  domain      InterviewDomain        @relation(fields: [domainId], references: [id], onDelete: Cascade)
  slug        String                 @unique @db.VarChar(100)
  name        String                 @db.VarChar(150)
  nameVi      String?                @map("name_vi") @db.VarChar(150)
  description String?                @db.Text
  icon        String?                @db.VarChar(60)
  sortOrder   Int                    @default(0) @map("sort_order")
  status      InterviewContentStatus @default(PUBLISHED)
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  topics   InterviewTopic[]
  sessions InterviewSession[]

  @@index([domainId], name: "idx_interview_tracks_domain")
  @@map("interview_tracks")
}

model InterviewTopic {
  id        Int                    @id @default(autoincrement())
  trackId   Int                    @map("track_id")
  track     InterviewTrack         @relation(fields: [trackId], references: [id], onDelete: Cascade)
  slug      String                 @unique @db.VarChar(120)
  name      String                 @db.VarChar(150)
  nameVi    String?                @map("name_vi") @db.VarChar(150)
  weight    Int                    @default(1) // weighted sampling
  sortOrder Int                    @default(0) @map("sort_order")
  status    InterviewContentStatus @default(PUBLISHED)
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")

  concepts    InterviewConcept[]
  questions   InterviewQuestion[]
  reviewCards InterviewReviewCard[]

  @@index([trackId], name: "idx_interview_topics_track")
  @@map("interview_topics")
}

model InterviewConcept {
  id        Int            @id @default(autoincrement())
  topicId   Int            @map("topic_id")
  topic     InterviewTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  slug      String         @unique @db.VarChar(140)
  name      String         @db.VarChar(200)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  questions   InterviewQuestion[]
  reviewCards InterviewReviewCard[]

  @@index([topicId], name: "idx_interview_concepts_topic")
  @@map("interview_concepts")
}

model InterviewCompanyProfile {
  id              Int                    @id @default(autoincrement())
  slug            String                 @unique @db.VarChar(80)
  name            String                 @db.VarChar(150)
  styleDescriptor String                 @map("style_descriptor") @db.Text
  rigor           Int                    @default(3) // 1-5, injected into interviewer persona
  status          InterviewContentStatus @default(PUBLISHED)
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  sessions InterviewSession[]

  @@map("interview_company_profiles")
}

model InterviewQuestion {
  id                Int                     @id @default(autoincrement())
  topicId           Int                     @map("topic_id")
  topic             InterviewTopic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  conceptId         Int?                    @map("concept_id")
  concept           InterviewConcept?       @relation(fields: [conceptId], references: [id], onDelete: SetNull)
  level             InterviewLevel
  type              InterviewQuestionType   @default(CONCEPTUAL)
  difficulty        Int                     @default(3) // 1-5
  body              String                  @db.Text // markdown, display language
  bodyVi            String?                 @map("body_vi") @db.Text
  bodyEn            String?                 @map("body_en") @db.Text
  referenceAnswer   String?                 @map("reference_answer") @db.Text
  referenceAnswerEn String?                 @map("reference_answer_en") @db.Text
  rubric            Json                    @default("[]") @db.JsonB // [{id,criterion,weight}] (display language)
  rubricEn          Json?                   @map("rubric_en") @db.JsonB // English rubric (used when session.language=EN)
  mustMention       String[]                @default([]) @map("must_mention")
  shouldMention     String[]                @default([]) @map("should_mention")
  // English keyword sets — used by the objective (keyword) grader when
  // session.language=EN, so an English answer is matched against English keys
  // instead of the Vietnamese ones (which made EN answers fail the keyword pass).
  mustMentionEn     String[]                @default([]) @map("must_mention_en")
  shouldMentionEn   String[]                @default([]) @map("should_mention_en")
  redFlags          String[]                @default([]) @map("red_flags")
  synonyms          Json                    @default("{}") @db.JsonB // { term: [aliases] }
  mcqOptions        Json?                   @map("mcq_options") @db.JsonB // [{id,text,correct}]
  tags              String[]                @default([])
  source            InterviewQuestionSource @default(SEED)
  status            InterviewContentStatus  @default(DRAFT)
  rubricReviewed    Boolean                 @default(false) @map("rubric_reviewed")
  authorId          Int?                    @map("author_id")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  versions    InterviewQuestionVersion[]
  turns       InterviewTurn[]
  reviewCards InterviewReviewCard[]

  @@index([topicId, level, status], name: "idx_interview_questions_topic_level")
  @@index([conceptId], name: "idx_interview_questions_concept")
  @@map("interview_questions")
}

model InterviewQuestionVersion {
  id         Int               @id @default(autoincrement())
  questionId Int               @map("question_id")
  question   InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  version    Int
  snapshot   Json              @db.JsonB
  editorId   Int?              @map("editor_id")
  createdAt  DateTime          @default(now()) @map("created_at")

  @@unique([questionId, version], name: "uk_interview_qversion")
  @@map("interview_question_versions")
}

model InterviewSession {
  id               Int                      @id @default(autoincrement())
  userId           Int                      @map("user_id")
  trackId          Int                      @map("track_id")
  track            InterviewTrack           @relation(fields: [trackId], references: [id], onDelete: Restrict)
  companyProfileId Int?                     @map("company_profile_id")
  companyProfile   InterviewCompanyProfile? @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  level            InterviewLevel
  mode             InterviewSessionMode     @default(TEXT)
  engineMode       InterviewEngineMode      @default(STATIC) @map("engine_mode")
  language         InterviewLanguage        @default(VI)
  status           InterviewSessionStatus   @default(IN_PROGRESS)
  focusedMode      Boolean                  @default(false) @map("focused_mode")
  config           Json                     @default("{}") @db.JsonB
  startedAt        DateTime?                @map("started_at")
  endedAt          DateTime?                @map("ended_at")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  turns  InterviewTurn[]
  report InterviewReport?

  @@index([userId, status], name: "idx_interview_sessions_user")
  @@index([trackId], name: "idx_interview_sessions_track")
  @@map("interview_sessions")
}

model InterviewTurn {
  id                 Int                @id @default(autoincrement())
  sessionId          Int                @map("session_id")
  session            InterviewSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId         Int?               @map("question_id")
  question           InterviewQuestion? @relation(fields: [questionId], references: [id], onDelete: SetNull)
  order              Int
  questionText       String             @map("question_text") @db.Text
  userAnswer         String?            @map("user_answer") @db.Text
  selfScore          Json?              @map("self_score") @db.JsonB
  deterministicScore Json?              @map("deterministic_score") @db.JsonB
  aiFollowUps        Json?              @map("ai_follow_ups") @db.JsonB
  turnScore          Json?              @map("turn_score") @db.JsonB
  timeSpentMs        Int?               @map("time_spent_ms")
  integritySignals   Json?              @map("integrity_signals") @db.JsonB
  needsReview        Boolean            @default(false) @map("needs_review")
  injectionAttempted Boolean            @default(false) @map("injection_attempted")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  @@unique([sessionId, order], name: "uk_interview_turn_order")
  @@index([questionId], name: "idx_interview_turns_question")
  @@map("interview_turns")
}

model InterviewReport {
  id                 Int                          @id @default(autoincrement())
  sessionId          Int                          @unique @map("session_id")
  session            InterviewSession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  overallScore       Float?                       @map("overall_score")
  letterGrade        String?                      @map("letter_grade") @db.VarChar(2)
  scoreBreakdown     Json                         @default("{}") @map("score_breakdown") @db.JsonB
  strengths          String[]                     @default([])
  weaknesses         String[]                     @default([])
  actionableAdvice   String?                      @map("actionable_advice") @db.Text
  suggestedResources Json?                        @map("suggested_resources") @db.JsonB
  hireRecommendation InterviewHireRecommendation? @map("hire_recommendation")
  pdfR2Key           String?                      @map("pdf_r2_key") @db.VarChar(300)
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")

  @@map("interview_reports")
}

model InterviewReviewCard {
  id              Int                   @id @default(autoincrement())
  userId          Int                   @map("user_id")
  topicId         Int                   @map("topic_id")
  topic           InterviewTopic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
  conceptId       Int?                  @map("concept_id")
  concept         InterviewConcept?     @relation(fields: [conceptId], references: [id], onDelete: SetNull)
  questionId      Int?                  @map("question_id")
  question        InterviewQuestion?    @relation(fields: [questionId], references: [id], onDelete: SetNull)
  sourceSessionId Int?                  @map("source_session_id")
  easeFactor      Float                 @default(2.5) @map("ease_factor")
  intervalDays    Int                   @default(0) @map("interval_days")
  repetitions     Int                   @default(0)
  lapses          Int                   @default(0)
  dueAt           DateTime?             @map("due_at")
  lastReviewedAt  DateTime?             @map("last_reviewed_at")
  masteryLevel    InterviewMasteryLevel @default(UNSEEN) @map("mastery_level")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  @@unique([userId, conceptId], name: "uk_interview_reviewcard_user_concept")
  @@index([userId, dueAt], name: "idx_interview_reviewcards_due")
  @@index([topicId], name: "idx_interview_reviewcards_topic")
  @@map("interview_review_cards")
}

// ── Ops / AI-phase tables (created now, INERT until Phase 4 wires the LLM layer) ──
model InterviewPromptTemplate {
  id        Int               @id @default(autoincrement())
  key       String            @db.VarChar(80)
  name      String            @db.VarChar(150)
  content   String            @db.Text
  language  InterviewLanguage @default(VI)
  version   Int               @default(1)
  isActive  Boolean           @default(true) @map("is_active")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@unique([key, version], name: "uk_interview_prompt_key_version")
  @@map("interview_prompt_templates")
}

model InterviewLLMCallLog {
  id           Int      @id @default(autoincrement())
  userId       Int?     @map("user_id")
  sessionId    Int?     @map("session_id")
  // Which product made the call: interview | language | cv | chat | bulk_gen.
  // `step` only says which model tier to route to, so Interview grading and the
  // My Language tutor both log step='interview' and were indistinguishable —
  // there was no way to answer "which users are spending Pro AI on what".
  // Nullable: rows written before this column existed keep their history.
  feature      String?  @db.VarChar(24)
  step         String   @db.VarChar(40)
  provider     String   @db.VarChar(40)
  model        String   @db.VarChar(80)
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  costUsd      Decimal  @default(0) @map("cost_usd") @db.Decimal(12, 6)
  success      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt], name: "idx_interview_llmlog_user")
  @@index([feature, createdAt], name: "idx_interview_llmlog_feature")
  @@map("interview_llm_call_logs")
}

// ── Phase 6: Knowledge base / RAG ────────────────────────────────────
// Admin-curated authoritative material that grounds the AI grader/report so it
// stops hallucinating stale framework details. Retrieval is LEXICAL (tsvector,
// see the search migration) — semantic/pgvector is a future upgrade (prod runs
// postgis, no vector ext). authorId is a plain Int (module convention, no FK).
model InterviewKnowledgeDocument {
  id         Int                    @id @default(autoincrement())
  title      String                 @db.VarChar(300)
  content    String                 @db.Text // markdown source
  sourceType String                 @default("ADMIN_WRITTEN") @map("source_type") @db.VarChar(30) // ADMIN_WRITTEN|UPLOADED_PDF|UPLOADED_MD|SCRAPED_DOC|REFERENCE_ANSWER
  topicIds   Int[]                  @default([]) @map("topic_ids")
  trackIds   Int[]                  @default([]) @map("track_ids")
  level      InterviewLevel? // null = all levels
  language   InterviewLanguage      @default(VI)
  version    Int                    @default(1)
  status     InterviewContentStatus @default(PUBLISHED)
  sourceUrl  String?                @map("source_url") @db.Text
  authorId   Int?                   @map("author_id")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  chunks InterviewKnowledgeChunk[]

  @@index([status], name: "idx_interview_kdoc_status")
  @@map("interview_knowledge_documents")
}

model InterviewKnowledgeChunk {
  id          Int                        @id @default(autoincrement())
  documentId  Int                        @map("document_id")
  document    InterviewKnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex  Int                        @map("chunk_index")
  headingPath String?                    @map("heading_path") @db.Text // breadcrumb, e.g. "Streams > Backpressure"
  content     String                     @db.Text
  tokenCount  Int                        @default(0) @map("token_count")
  // Denormalized scope from the parent doc → fast topic-scoped retrieval without a join.
  topicIds    Int[]                      @default([]) @map("topic_ids")
  trackIds    Int[]                      @default([]) @map("track_ids")
  level       InterviewLevel?
  language    InterviewLanguage          @default(VI)
  status      InterviewContentStatus     @default(PUBLISHED)
  createdAt   DateTime                   @default(now()) @map("created_at")

  @@unique([documentId, chunkIndex], name: "uk_interview_kchunk_order")
  @@index([documentId], name: "idx_interview_kchunk_doc")
  @@map("interview_knowledge_chunks")
}

// ═══════════════════════════════════════════════════════════════════
//  CV BUILDER MODULE  (Phase 1 — foundation)
//  Honest, IT-focused CV builder. Sits alongside the Interview module
//  and reuses its LLM / quota / Pro / R2 plumbing. The CV is stored as
//  STRUCTURED data (profile → items → bullets), never a text blob —
//  that is what enables multi-template render, ATS-safe export, per-job
//  tailoring, and AI critique at the level of a single claim.
//
//  Convention (identical to the Interview module): `userId Int` carries
//  NO foreign key to User. Account-deletion cascade is done in the
//  service layer (hard-delete endpoint, a later phase). Relations WITHIN
//  the module (profile → item → bullet, document → version …) cascade
//  normally via onDelete: Cascade.
// ═══════════════════════════════════════════════════════════════════

enum CvMarket {
  VN
  INTERNATIONAL
}

enum CvLanguage {
  VI
  EN
}

enum CvExperienceLevel {
  STUDENT
  FRESHER
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum CvType {
  INDUSTRY
  ACADEMIC
  GOVERNMENT
}

// A CvItem is a unified record for anything that carries achievement
// bullets: a job, a project, a degree, an open-source contribution, a
// publication, an award, or volunteering. The `kind` discriminates.
enum CvItemKind {
  EXPERIENCE
  PROJECT
  EDUCATION
  OPEN_SOURCE
  PUBLICATION
  AWARD
  VOLUNTEER
}

enum CvBulletStrength {
  WEAK
  OK
  STRONG
}

enum CvSkillCategory {
  LANGUAGE
  FRAMEWORK
  DATABASE
  INFRA
  TOOL
  PRACTICE
  SOFT
}

enum CvEmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
  VOLUNTEER
}

enum CvDocumentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CvReviewMode {
  STATIC
  AI
}

enum CvReviewVerdict {
  INTERVIEW
  MAYBE
  REJECT
}

enum CvImportSource {
  PDF
  DOCX
  GITHUB
  LINKEDIN_ARCHIVE
  JSON_RESUME
  PASTE
}

enum CvImportStatus {
  PENDING
  PARSING
  PARSED
  COMMITTED
  FAILED
}

enum CvExportFormat {
  PDF
  DOCX
  TXT
  MD
  JSON
}

enum CvExportStatus {
  PENDING
  RENDERING
  READY
  FAILED
}

enum CvCoverLetterTone {
  FORMAL
  DIRECT
  WARM
}

// The user's MASTER career record — one per user. Contains everything
// they have ever done, including things that won't appear on any single
// CV. Individual CvDocuments are just curated views of this source.
model CvProfile {
  id            Int                @id @default(autoincrement())
  userId        Int                @unique @map("user_id")
  // Contact block
  fullName      String?            @map("full_name") @db.VarChar(150)
  headline      String?            @db.VarChar(200) // e.g. "Backend Engineer"
  email         String?            @db.VarChar(150)
  phone         String?            @db.VarChar(40)
  location      String?            @db.VarChar(150)
  links         Json               @default("{}") @db.JsonB // { github, linkedin, portfolio, website }
  photoR2Key    String?            @map("photo_r2_key") @db.VarChar(300)
  dateOfBirth   DateTime?          @map("date_of_birth") // VN market only; INTERNATIONAL strips it
  summary       String?            @db.Text
  // Preferences — seed defaults for new tailored CVs
  targetRoles   String[]           @default([]) @map("target_roles")
  seniority     CvExperienceLevel?
  locationsPref String[]           @default([]) @map("locations_pref")
  remotePref    String?            @map("remote_pref") @db.VarChar(20) // REMOTE|ONSITE|HYBRID|ANY
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  items          CvItem[]
  skills         CvSkill[]
  certifications CvCertification[]
  languageSkills CvLanguageSkill[]
  documents      CvDocument[]

  @@map("cv_profiles")
}

// A bullet-bearing entry: job / project / degree / etc. (see CvItemKind).
model CvItem {
  id             Int               @id @default(autoincrement())
  profileId      Int               @map("profile_id")
  profile        CvProfile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  kind           CvItemKind
  title          String            @db.VarChar(250) // role / project name / degree
  organization   String?           @db.VarChar(250) // company / school / publisher
  location       String?           @db.VarChar(150)
  employmentType CvEmploymentType? @map("employment_type")
  startDate      DateTime?         @map("start_date")
  endDate        DateTime?         @map("end_date") // null + isCurrent = ongoing
  isCurrent      Boolean           @default(false) @map("is_current")
  url            String?           @db.VarChar(500) // repo / demo / publication link
  techStack      String[]          @default([]) @map("tech_stack")
  context        String?           @db.Text // private notes, never rendered
  gpa            String?           @db.VarChar(20) // EDUCATION only
  sortOrder      Int               @default(0) @map("sort_order")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  bullets CvBullet[]

  @@index([profileId, kind], name: "idx_cv_items_profile_kind")
  @@map("cv_items")
}

// The atomic unit — one achievement line. This is where the value is.
// Every AI-touched bullet must trace back to `userStatedFacts`; a claim
// with no supporting user input is a hard failure (a ClarifyingQuestion
// is emitted instead). `verified` gates export.
model CvBullet {
  id              Int              @id @default(autoincrement())
  itemId          Int              @map("item_id")
  item            CvItem           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  text            String           @db.Text // the rendered line
  userStatedFacts String?          @map("user_stated_facts") @db.Text // provenance anchor
  provenance      Json?            @db.JsonB // claim → supporting user fact
  verified        Boolean          @default(false) // user confirmed accurate
  aiGenerated     Boolean          @default(false) @map("ai_generated")
  metrics         Json?            @db.JsonB // extracted numbers, reusable & checkable
  skillsEvidenced String[]         @default([]) @map("skills_evidenced") // powers skills-vs-evidence gap
  strength        CvBulletStrength @default(OK) // computed by the rules engine
  variants        Json             @default("[]") @db.JsonB // alt phrasings for tailoring
  sortOrder       Int              @default(0) @map("sort_order")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([itemId], name: "idx_cv_bullets_item")
  @@map("cv_bullets")
}

// A skill claim. Evidence is matched against CvBullet.skillsEvidenced at
// lint time — a skill with no evidencing bullet is a liability the
// rules engine surfaces (the interview will test it).
model CvSkill {
  id          Int             @id @default(autoincrement())
  profileId   Int             @map("profile_id")
  profile     CvProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String          @db.VarChar(100)
  category    CvSkillCategory @default(TOOL)
  proficiency String?         @db.VarChar(30) // never rendered as bars/stars (ATS-harmful)
  yearsUsed   Float?          @map("years_used")
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([profileId], name: "idx_cv_skills_profile")
  @@map("cv_skills")
}

model CvCertification {
  id           Int       @id @default(autoincrement())
  profileId    Int       @map("profile_id")
  profile      CvProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name         String    @db.VarChar(200)
  issuer       String?   @db.VarChar(200)
  issueDate    DateTime? @map("issue_date")
  expiryDate   DateTime? @map("expiry_date")
  credentialId String?   @map("credential_id") @db.VarChar(150)
  url          String?   @db.VarChar(500)
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([profileId], name: "idx_cv_certs_profile")
  @@map("cv_certifications")
}

// English proficiency is a first-class credential in the VN outsourcing
// market (FPT, KMS, NashTech…) — IELTS/TOEIC scores belong here and the
// VN template surfaces them prominently.
model CvLanguageSkill {
  id          Int       @id @default(autoincrement())
  profileId   Int       @map("profile_id")
  profile     CvProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  language    String    @db.VarChar(60) // "English", "Japanese"
  proficiency String?   @db.VarChar(60) // "Native", "Professional working"
  certName    String?   @map("cert_name") @db.VarChar(60) // IELTS | TOEIC | JLPT
  certScore   String?   @map("cert_score") @db.VarChar(40) // "7.5", "900", "N2"
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([profileId], name: "idx_cv_langskills_profile")
  @@map("cv_language_skills")
}

// A specific tailored CV derived from the master profile. Rendering is a
// separate concern (templates); this row is the SELECTION + config.
model CvDocument {
  id              Int               @id @default(autoincrement())
  profileId       Int               @map("profile_id")
  profile         CvProfile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId          Int               @map("user_id") // denormalized for fast listing + IDOR guard
  name            String            @db.VarChar(150) // "Backend @ KMS"
  market          CvMarket          @default(VN)
  language        CvLanguage        @default(VI)
  experienceLevel CvExperienceLevel @default(JUNIOR) @map("experience_level")
  cvType          CvType            @default(INDUSTRY) @map("cv_type")
  templateId      Int?              @map("template_id")
  template        CvTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  // Code-defined template id ('ats' | 'technical' | 'vietnam' | 'senior') — the
  // renderer uses this, not the CvTemplate row (which stays for an admin-managed
  // template library later).
  templateKey     String?           @map("template_key") @db.VarChar(60)
  targetJobId     Int?              @map("target_job_id") // soft ref to CvJobTarget (module convention)
  sectionOrder    Json              @default("[]") @db.JsonB
  includedItemIds Json              @default("{}") @map("included_item_ids") @db.JsonB // items/bullets/skills in THIS cv
  pageTarget      Int               @default(1) @map("page_target")
  includePhoto    Boolean           @default(false) @map("include_photo")
  status          CvDocumentStatus  @default(DRAFT)
  version         Int               @default(1)
  outcomeLabel    String?           @map("outcome_label") @db.VarChar(200) // "got KMS interview"
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  versions     CvVersion[]
  reviews      CvReview[]
  coverLetters CvCoverLetter[]
  exports      CvExport[]

  @@index([userId, status], name: "idx_cv_documents_user")
  @@index([profileId], name: "idx_cv_documents_profile")
  @@map("cv_documents")
}

// Full snapshot history — diffable. Lets a user compare the CV that got
// an interview against the one that didn't.
model CvVersion {
  id         Int        @id @default(autoincrement())
  documentId Int        @map("document_id")
  document   CvDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version    Int
  snapshot   Json       @db.JsonB // full structured data at this version
  note       String?    @db.VarChar(300)
  createdAt  DateTime   @default(now()) @map("created_at")

  @@unique([documentId, version], name: "uk_cv_version")
  @@map("cv_versions")
}

// A job posting the user targets. Untrusted input — parsed JD text is
// wrapped in delimiters before any LLM sees it; injection is flagged.
model CvJobTarget {
  id                 Int      @id @default(autoincrement())
  userId             Int      @map("user_id")
  title              String   @db.VarChar(250)
  company            String?  @db.VarChar(200)
  sourceUrl          String?  @map("source_url") @db.VarChar(500)
  rawJobDescription  String   @map("raw_job_description") @db.Text
  parsedRequirements Json?    @map("parsed_requirements") @db.JsonB // must-have, nice-to-have, keywords
  injectionAttempted Boolean  @default(false) @map("injection_attempted")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([userId], name: "idx_cv_jobs_user")
  @@map("cv_job_targets")
}

// Output of one analysis run — STATIC rules engine or AI critique.
model CvReview {
  id             Int              @id @default(autoincrement())
  documentId     Int              @map("document_id")
  document       CvDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId         Int              @map("user_id")
  mode           CvReviewMode     @default(STATIC)
  verdict        CvReviewVerdict?
  score          Int? // 0..100
  atsScore       Int?             @map("ats_score")
  sixSecondTest  String?          @map("six_second_test") @db.Text
  issues         Json             @default("[]") @db.JsonB // [{severity, location, problem, whyItMatters, suggestedFix}]
  strengths      Json             @default("[]") @db.JsonB
  interviewRisks Json             @default("[]") @map("interview_risks") @db.JsonB // the killer feature
  keywordGaps    Json             @default("[]") @map("keyword_gaps") @db.JsonB
  jobTargetId    Int?             @map("job_target_id")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([documentId], name: "idx_cv_reviews_document")
  @@map("cv_reviews")
}

// Render definition. Every template must pass the ATS linter and the PDF
// round-trip test in CI (a later phase). Fewer, better — four total.
model CvTemplate {
  id           Int      @id @default(autoincrement())
  key          String   @unique @db.VarChar(60)
  name         String   @db.VarChar(120)
  description  String?  @db.Text
  renderSpec   Json     @default("{}") @map("render_spec") @db.JsonB
  atsSafe      Boolean  @default(true) @map("ats_safe")
  bestFor      Json     @default("{}") @map("best_for") @db.JsonB // { market, level hints }
  previewR2Key String?  @map("preview_r2_key") @db.VarChar(300)
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  documents CvDocument[]

  @@map("cv_templates")
}

// An import run (upload / GitHub / paste …). Raw upload is retained so a
// failed parse can be retried without re-uploading. Parse is a first
// draft the user reviews — never written to the profile authoritatively.
model CvImportJob {
  id              Int            @id @default(autoincrement())
  userId          Int            @map("user_id")
  source          CvImportSource
  status          CvImportStatus @default(PENDING)
  rawContentR2Key String?        @map("raw_content_r2_key") @db.VarChar(300)
  rawText         String?        @map("raw_text") @db.Text
  parsedResult    Json?          @map("parsed_result") @db.JsonB
  confidenceFlags Json?          @map("confidence_flags") @db.JsonB // which fields the parser is unsure about
  hiddenTextFound Boolean        @default(false) @map("hidden_text_found") // white-on-white / zero-size fonts
  error           String?        @db.Text
  reviewedByUser  Boolean        @default(false) @map("reviewed_by_user")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([userId, status], name: "idx_cv_imports_user")
  @@map("cv_import_jobs")
}

// Read-only GitHub OAuth snapshot. Repos scored by substance so only
// real projects are surfaced as CV candidates.
model CvGitHubProfile {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique @map("user_id")
  username        String    @db.VarChar(100)
  repos           Json      @default("[]") @db.JsonB
  languageProfile Json      @default("{}") @map("language_profile") @db.JsonB
  lastSyncedAt    DateTime? @map("last_synced_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("cv_github_profiles")
}

model CvCoverLetter {
  id          Int               @id @default(autoincrement())
  documentId  Int               @map("document_id")
  document    CvDocument        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId      Int               @map("user_id")
  jobTargetId Int?              @map("job_target_id")
  body        String            @db.Text
  tone        CvCoverLetterTone @default(DIRECT)
  version     Int               @default(1)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([documentId], name: "idx_cv_coverletters_document")
  @@map("cv_cover_letters")
}

// Every AI rewrite proposed — powers the before/after diff and the
// accept-rate signal (a user rejecting most rewrites = wrong voice).
model CvSuggestionLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  bulletId  Int?     @map("bullet_id")
  original  String   @db.Text
  proposed  String   @db.Text
  rationale String?  @db.Text
  accepted  Boolean? // null = pending
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId], name: "idx_cv_suggestions_user")
  @@map("cv_suggestion_logs")
}

// A generated export artifact in R2. `roundTripOk` records whether the
// PDF's text re-extracted correctly (ATS-readability gate).
model CvExport {
  id          Int            @id @default(autoincrement())
  documentId  Int            @map("document_id")
  document    CvDocument     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId      Int            @map("user_id")
  format      CvExportFormat
  status      CvExportStatus @default(PENDING)
  r2Key       String?        @map("r2_key") @db.VarChar(300)
  fileName    String?        @map("file_name") @db.VarChar(200)
  roundTripOk Boolean?       @map("round_trip_ok")
  error       String?        @db.Text
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@index([documentId], name: "idx_cv_exports_document")
  @@map("cv_exports")
}

// Per-task LLM cost/token accounting, isolated from the Interview log so
// the CV cost dashboard is clean. Failed calls logged with zero tokens.
model CvLLMCallLog {
  id           Int      @id @default(autoincrement())
  userId       Int?     @map("user_id")
  documentId   Int?     @map("document_id")
  task         String   @db.VarChar(40) // critique | intake | jd_parse | parse_fallback | cover_letter
  provider     String   @db.VarChar(40)
  model        String   @db.VarChar(80)
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  costUsd      Decimal  @default(0) @map("cost_usd") @db.Decimal(12, 6)
  success      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt], name: "idx_cv_llmlog_user")
  @@map("cv_llm_call_logs")
}

// ─── My Language — Roadmap (learning path) ───────────────────────────
// A per-language visual roadmap (roadmap.sh style): ordered stages, each with
// nodes that link into the existing section pages (vocab/grammar/…). Fully
// additive. Node completion is per-user and manual (LangRoadmapDone).
model LangRoadmapNode {
  id          Int      @id @default(autoincrement())
  languageId  Int      @map("language_id")
  stage       Int      @default(0) // group index (0,1,2,…)
  stageLabel  String   @map("stage_label") @db.VarChar(120) // "N5", "IELTS nền (B2)"
  order       Int      @default(0) // order within the stage
  side        String   @default("center") @db.VarChar(10) // center | left | right
  kind        String   @default("primary") @db.VarChar(16) // primary | alternative | info
  title       String   @db.VarChar(255)
  subtitle    String?  @db.VarChar(255)
  level       String?  @db.VarChar(20) // A1..C2 | N5..N1 — used to deep-link the section
  icon        String?  @db.VarChar(48) // lucide icon name
  description String?  @db.Text // the "intro" shown when the node is opened
  linkType    String?  @map("link_type") @db.VarChar(32) // section key: vocab|grammar|listening|reading|conversation|roleplay|writing|alphabet | external
  linkRef     String?  @map("link_ref") @db.VarChar(255) // optional override (e.g. external URL)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  language Language          @relation(fields: [languageId], references: [id], onDelete: Cascade)
  doneBy   LangRoadmapDone[]

  @@index([languageId, stage, order], name: "idx_lang_roadmap_lang")
  @@map("lang_roadmap_nodes")
}

model LangRoadmapDone {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  nodeId    Int      @map("node_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  node LangRoadmapNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId], map: "uk_lang_roadmap_done")
  @@index([userId], name: "idx_lang_roadmap_done_user")
  @@map("lang_roadmap_done")
}

// ─── My Language — Practice (Duolingo-style gamification) ────────────
// Per-user, per-language game state (XP / streak / daily goal / hearts /
// reminder pref) + per-lesson crown progress. Fully additive. Exercises are
// generated client-side from the existing vocab content; only the game state is
// server-authoritative here.
model LangGameState {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  languageId       Int       @map("language_id")
  xp               Int       @default(0)
  streak           Int       @default(0)
  longestStreak    Int       @default(0) @map("longest_streak")
  lastPracticeDate DateTime? @map("last_practice_date")
  dailyGoalXp      Int       @default(30) @map("daily_goal_xp")
  dailyXp          Int       @default(0) @map("daily_xp")
  dailyXpDate      String?   @map("daily_xp_date") @db.VarChar(10)
  weeklyXp         Int       @default(0) @map("weekly_xp")
  weekKey          String?   @map("week_key") @db.VarChar(10)
  hearts           Int       @default(5)
  heartsUpdatedAt  DateTime  @default(now()) @map("hearts_updated_at")
  reminderEnabled  Boolean   @default(false) @map("reminder_enabled")
  reminderHour     Int       @default(20) @map("reminder_hour")
  lastReminderAt   DateTime? @map("last_reminder_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([userId, languageId], map: "uk_lang_game_user_lang")
  @@map("lang_game_states")
}

model LangLessonProgress {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  languageId      Int       @map("language_id")
  lessonKey       String    @map("lesson_key") @db.VarChar(80)
  crown           Int       @default(0)
  bestScore       Int       @default(0) @map("best_score")
  timesCompleted  Int       @default(0) @map("times_completed")
  lastCompletedAt DateTime? @map("last_completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonKey], map: "uk_lang_lesson_user_key")
  @@index([userId, languageId], name: "idx_lang_lesson_user_lang")
  @@map("lang_lesson_progress")
}

// ============================================================
// 31. GAME LIBRARY ("Playground") — added 2026-07-16
// ============================================================
// DB-backed replacement for the old static GAMES_DATA array in
// frontend/src/types/games.ts. Games are admin-curated; plays
// (scores) are recorded per game and may be anonymous.
//
// `kind` preserves the pre-existing capability of hosting a
// standalone HTML game in /public via an iframe (the `love-me`
// game) alongside React component games — the old GameRenderer
// supported this and dropping it would regress that game.
// React games resolve `componentKey` through the client-side
// registry (components/games/registry.ts).

enum GameDifficulty {
  EASY
  MEDIUM
  HARD
}

enum GameStatus {
  DRAFT
  PUBLISHED
  COMING_SOON
}

enum GameKind {
  REACT
  IFRAME
}

model GameCategory {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(80)
  nameVi    String?  @map("name_vi") @db.VarChar(80)
  slug      String   @unique(map: "uk_game_category_slug") @db.VarChar(80)
  icon      String?  @db.VarChar(40)
  color     String?  @db.VarChar(16)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  games Game[]

  @@index([sortOrder], name: "idx_game_category_sort")
  @@map("game_categories")
}

model Game {
  id              Int            @id @default(autoincrement())
  title           String         @db.VarChar(160)
  titleVi         String?        @map("title_vi") @db.VarChar(160)
  slug            String         @unique(map: "uk_game_slug") @db.VarChar(160)
  description     String         @db.Text
  descriptionVi   String?        @map("description_vi") @db.Text
  longDescription String?        @map("long_description") @db.Text
  coverImage      String?        @map("cover_image") @db.VarChar(500)
  screenshots     String[]       @default([])
  difficulty      GameDifficulty @default(EASY)
  status          GameStatus     @default(DRAFT)
  featured        Boolean        @default(false)
  sortOrder       Int            @default(0) @map("sort_order")
  playCount       Int            @default(0) @map("play_count")
  // REACT → resolved via the client registry; IFRAME → iframeSrc.
  kind            GameKind       @default(REACT)
  componentKey    String?        @map("component_key") @db.VarChar(64)
  iframeSrc       String?        @map("iframe_src") @db.VarChar(500)
  estimatedTime   String?        @map("estimated_time") @db.VarChar(40)
  techStack       String[]       @default([]) @map("tech_stack")
  tags            String[]       @default([])
  controls        String?        @db.Text
  controlsVi      String?        @map("controls_vi") @db.Text
  categoryId      Int            @map("category_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  category GameCategory @relation(fields: [categoryId], references: [id])
  plays    GamePlay[]

  @@index([status, featured], name: "idx_game_status_featured")
  @@index([categoryId], name: "idx_game_category")
  @@index([sortOrder], name: "idx_game_sort")
  @@map("games")
}

model GamePlay {
  id       Int      @id @default(autoincrement())
  gameId   Int      @map("game_id")
  // Nullable: anonymous plays are allowed. SetNull (not Cascade) so
  // deleting an account anonymises its scores instead of silently
  // rewriting every leaderboard.
  userId   Int?     @map("user_id")
  score    Int      @default(0)
  duration Int?
  playedAt DateTime @default(now()) @map("played_at")

  game Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([gameId, score(sort: Desc)], name: "idx_game_play_game_score")
  @@index([userId], name: "idx_game_play_user")
  @@index([playedAt(sort: Desc)], name: "idx_game_play_time")
  @@map("game_plays")
}

// ===== LANDING PROMO ==================================================
// Short muted promo clips shown in the marquee on the public landing page ("/").
// Admin-managed: the video bytes live in R2 (uploaded via the presign flow) and
// only the URL + metadata live here. Site content, not user data → no user FK.
model LandingPromo {
  id         Int      @id @default(autoincrement())
  title      String   @db.VarChar(160)
  tagline    String?  @db.VarChar(255)
  videoUrl   String   @map("video_url") @db.VarChar(500)
  posterUrl  String?  @map("poster_url") @db.VarChar(500)
  href       String?  @db.VarChar(255)
  accent     String?  @db.VarChar(16)
  featureKey String?  @map("feature_key") @db.VarChar(48)
  isActive   Boolean  @default(true) @map("is_active")
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([isActive, order], name: "idx_landing_promo_active_order")
  @@map("landing_promos")
}

// ─────────────────────────────────────────────────────────────────────────
// Voice Hub — admin-only creator channel: Vlog / Reaction / Kinh nghiệm code
// / Podcast (voice) / Tutorial. Media is a YouTube embed, a self-hosted R2
// video, or audio-only. Mirrors the Tech Trends pattern (slug + status +
// publishedAt + featured + viewCount) plus media/series/chapters. Comments
// are auth-only with one level of replies + likes. Fully additive.
// ─────────────────────────────────────────────────────────────────────────

model VoiceSeries {
  id            Int      @id @default(autoincrement())
  title         String   @db.VarChar(255)
  slug          String   @unique(map: "uk_voice_series_slug") @db.VarChar(255)
  description   String?  @db.Text
  coverImageUrl String?  @map("cover_image_url") @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  posts VoicePost[]

  @@map("voice_series")
}

model VoicePost {
  id              Int       @id @default(autoincrement())
  title           String    @db.VarChar(255)
  slug            String    @unique(map: "uk_voice_post_slug") @db.VarChar(255)
  summary         String?   @db.Text
  // Rich show-notes. `description` is the Markdown source the admin edits;
  // `descriptionHtml` is the rendered HTML cached at write time.
  description     String?   @db.Text
  descriptionHtml String?   @map("description_html") @db.Text
  type            String    @default("VLOG") @db.VarChar(20) // VLOG | REACTION | CODE_EXP | PODCAST | TUTORIAL
  mediaKind       String    @default("YOUTUBE") @db.VarChar(20) // YOUTUBE | R2_VIDEO | AUDIO
  youtubeId       String?   @map("youtube_id") @db.VarChar(32)
  videoUrl        String?   @map("video_url") @db.VarChar(555)
  audioUrl        String?   @map("audio_url") @db.VarChar(555)
  thumbnailUrl    String?   @map("thumbnail_url") @db.VarChar(500)
  durationSec     Int?      @map("duration_sec")
  chapters        Json?     @db.JsonB // [{ t: number(seconds), label: string }]
  tags            String[]  @default([])
  status          String    @default("DRAFT") @db.VarChar(20) // DRAFT | PUBLISHED | SCHEDULED
  isFeatured      Boolean   @default(false) @map("is_featured")
  isPinned        Boolean   @default(false) @map("is_pinned")
  viewCount       Int       @default(0) @map("view_count")
  likeCount       Int       @default(0) @map("like_count")
  seriesId        Int?      @map("series_id")
  authorId        Int?      @map("author_id")
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  series   VoiceSeries?   @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  author   User?          @relation("VoicePostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  comments VoiceComment[]
  likes    VoiceLike[]

  @@index([type], name: "idx_voice_post_type")
  @@index([status], name: "idx_voice_post_status")
  @@index([isFeatured], name: "idx_voice_post_featured")
  @@index([publishedAt(sort: Desc)], name: "idx_voice_post_published_at")
  @@index([seriesId], name: "idx_voice_post_series")
  @@index([authorId], name: "idx_voice_post_author")
  @@map("voice_posts")
}

model VoiceLike {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post VoicePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId], name: "uk_voice_like")
  @@index([postId], name: "idx_voice_likes_post")
  @@index([userId], name: "idx_voice_likes_user")
  @@map("voice_likes")
}

model VoiceComment {
  id         Int      @id @default(autoincrement())
  postId     Int      @map("post_id")
  userId     Int      @map("user_id")
  parentId   Int?     @map("parent_id")
  content    String   @db.Text
  likesCount Int      @default(0) @map("likes_count")
  isEdited   Boolean  @default(false) @map("is_edited")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  post    VoicePost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  VoiceComment?      @relation("VoiceCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies VoiceComment[]     @relation("VoiceCommentReplies")
  likes   VoiceCommentLike[]

  @@index([postId, createdAt(sort: Desc)], name: "idx_voice_comments_post_time")
  @@index([parentId], name: "idx_voice_comments_parent")
  @@index([userId], name: "idx_voice_comments_user")
  @@map("voice_comments")
}

model VoiceCommentLike {
  id        Int      @id @default(autoincrement())
  commentId Int      @map("comment_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  comment VoiceComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId], name: "uk_voice_comment_like")
  @@index([commentId], name: "idx_voice_comment_likes_comment")
  @@index([userId], name: "idx_voice_comment_likes_user")
  @@map("voice_comment_likes")
}

// ════════════════════════════════════════════════════════════════
//  CODE LAB — coding-practice + learning-roadmap module
//  Hierarchy:  CodeGroup ▸ CodeTrack ▸ CodeModule ▸ CodeExercise
//  Plus per-user CodeProgress (save attempt / mark solved).
//  All content authored in ENGLISH. Additive — no changes to
//  existing tables. Mirrors the Snippet* (Exp Hub) pipeline.
// ════════════════════════════════════════════════════════════════

// Coarse skill tier used on tracks + modules (ordering the roadmap).
enum CodeLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED

  @@map("code_level")
}

// Per-exercise difficulty badge (LeetCode-style, four tiers).
enum CodeDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT

  @@map("code_difficulty")
}

// Publication state for tracks / exercises. DRAFT = admin-only.
enum CodeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("code_status")
}

// Per-user practice status for a single exercise.
enum CodeProgressStatus {
  IN_PROGRESS
  SOLVED

  @@map("code_progress_status")
}

// ─── Top-level groups (the tabs across the top of the hub) ───────
model CodeGroup {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  slug        String   @unique(map: "uk_code_group_slug") @db.VarChar(100)
  description String?  @db.Text
  // Lucide icon name OR an absolute R2 image URL.
  icon        String?  @db.VarChar(500)
  // Accent hex color for the group tab (e.g. "#3178c6"). Null = derived.
  color       String?  @db.VarChar(20)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tracks CodeTrack[]

  @@index([sortOrder], name: "idx_code_group_order")
  @@map("code_groups")
}

// ─── Tracks (a learning path for one technology) ─────────────────
model CodeTrack {
  id            Int        @id @default(autoincrement())
  groupId       Int        @map("group_id")
  name          String     @db.VarChar(150)
  slug          String     @unique(map: "uk_code_track_slug") @db.VarChar(150)
  // Primary language/tech key ("java", "python", "sql", "spring", "nextjs"…).
  language      String     @db.VarChar(40)
  description   String?    @db.Text
  icon          String?    @db.VarChar(500)
  color         String?    @db.VarChar(20)
  coverImageUrl String?    @map("cover_image_url") @db.VarChar(2000)
  docsUrl       String?    @map("docs_url") @db.VarChar(500)
  // Overall entry level of the track (roadmap ordering hint).
  level         CodeLevel  @default(BEGINNER)
  sortOrder     Int        @default(0) @map("sort_order")
  status        CodeStatus @default(PUBLISHED)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  group     CodeGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  modules   CodeModule[]
  exercises CodeExercise[]

  @@index([groupId, sortOrder], name: "idx_code_track_group_order")
  @@index([slug], name: "idx_code_track_slug")
  @@map("code_tracks")
}

// ─── Modules (ordered chapters/stages inside a track) ────────────
model CodeModule {
  id                Int       @id @default(autoincrement())
  trackId           Int       @map("track_id")
  name              String    @db.VarChar(150)
  slug              String    @db.VarChar(150)
  description       String?   @db.Text
  level             CodeLevel @default(BEGINNER)
  sortOrder         Int       @default(0) @map("sort_order")
  // ─── NTU-style long-form LESSON (P2) ─────────────────────────────
  // A comprehensive tutorial for this module — intro, concepts explained
  // with annotated code + output, old-vs-new comparisons, best practices —
  // stored as the SAME ordered DocBlock array used by Exp Hub docs
  // ({type: heading|prose|code|mermaid|image|links}). Rendered above the
  // module's exercises. Additive/nullable — null = no lesson yet.
  lessonBlocks      Json?     @map("lesson_blocks")
  lessonModel       String?   @map("lesson_model") @db.VarChar(80)
  lessonGeneratedAt DateTime? @map("lesson_generated_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  track     CodeTrack      @relation(fields: [trackId], references: [id], onDelete: Cascade)
  exercises CodeExercise[]

  // slug is unique within a track (not globally).
  @@unique([trackId, slug], name: "uk_code_module_track_slug")
  @@index([trackId, sortOrder], name: "idx_code_module_track_order")
  @@map("code_modules")
}

// ─── Exercises (the graded practice problems) ────────────────────
model CodeExercise {
  id         Int            @id @default(autoincrement())
  moduleId   Int            @map("module_id")
  // Denormalised for fast track-wide queries / progress rollups.
  trackId    Int            @map("track_id")
  title      String         @db.VarChar(255)
  slug       String         @unique(map: "uk_code_exercise_slug") @db.VarChar(255)
  difficulty CodeDifficulty @default(EASY)
  sortOrder  Int            @default(0) @map("sort_order")
  status     CodeStatus     @default(PUBLISHED)
  // Primary language for the editor/solution ("java", "python"…).
  language   String         @db.VarChar(40)

  // ─── Problem body (all English, NTU-style) ─────────────────────
  // The problem statement, rendered as sanitized HTML on the client.
  problemHtml             String? @map("problem_html") @db.Text
  // "Knowledge to learn & apply" — JSON array of strings.
  concepts                Json?   @map("concepts")
  // Prerequisite concepts / links — JSON array of strings.
  prerequisites           Json?   @map("prerequisites")
  // Free-text specs shown as their own sections.
  inputSpec               String? @map("input_spec") @db.Text
  outputSpec              String? @map("output_spec") @db.Text
  constraints             String? @db.Text
  // Worked examples: JSON array of { input, output, explanation }.
  examplesJson            Json?   @map("examples_json")
  // Progressive hints: JSON array of strings (revealed one by one).
  hintsJson               Json?   @map("hints_json")
  // Starter code: JSON array of { name, language, code } (like Snippet.codeBlocks).
  starterCodeJson         Json?   @map("starter_code_json")
  // Official solution: JSON array of { name, language, code }.
  solutionCodeJson        Json?   @map("solution_code_json")
  // Walkthrough of the solution (sanitized HTML).
  solutionExplanationHtml String? @map("solution_explanation_html") @db.Text
  // Optional UML/diagram image (R2) + extra images [{ url, caption }].
  diagramImageUrl         String? @map("diagram_image_url") @db.VarChar(2000)
  // Optional Mermaid diagram illustrating the problem (a class diagram for OOP
  // tasks, a flowchart for algorithm tasks) — rendered above the problem so the
  // learner can picture the structure, NTU-style. Additive/nullable.
  diagramMermaid          String? @map("diagram_mermaid") @db.Text
  imagesJson              Json?   @map("images_json")
  // Extra references.
  youtubeUrl              String? @map("youtube_url") @db.VarChar(500)
  referenceUrl            String? @map("reference_url") @db.VarChar(500)
  // Freeform tags: JSON array of strings.
  tags                    Json?
  // Meta.
  estimatedMinutes        Int?    @map("estimated_minutes")
  points                  Int     @default(10)
  viewCount               Int     @default(0) @map("view_count")
  solveCount              Int     @default(0) @map("solve_count")

  authorId Int? @map("author_id")

  // Full-text search vector over title + problem + concepts (config 'simple').
  // Maintained by Postgres; queried only via $queryRaw. Unsupported so Prisma
  // tracks the column but never reads/writes it. (Same pattern as Snippet.)
  searchVector Unsupported("tsvector")? @map("search_vector")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  module   CodeModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  track    CodeTrack      @relation(fields: [trackId], references: [id], onDelete: Cascade)
  author   User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
  progress CodeProgress[]

  @@index([moduleId, sortOrder], name: "idx_code_exercise_module_order")
  @@index([trackId], name: "idx_code_exercise_track")
  @@index([status], name: "idx_code_exercise_status")
  @@index([difficulty], name: "idx_code_exercise_difficulty")
  @@index([language], name: "idx_code_exercise_language")
  @@index([slug], name: "idx_code_exercise_slug")
  @@map("code_exercises")
}

// ─── Per-user practice progress (one row per user+exercise) ──────
model CodeProgress {
  id         Int                @id @default(autoincrement())
  userId     Int                @map("user_id")
  exerciseId Int                @map("exercise_id")
  status     CodeProgressStatus @default(IN_PROGRESS)
  // The user's last saved attempt: JSON array of { name, language, code }.
  savedCode  Json?              @map("saved_code")
  solvedAt   DateTime?          @map("solved_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise CodeExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId], name: "uk_code_progress_user_exercise")
  @@index([userId, status], name: "idx_code_progress_user_status")
  @@index([exerciseId], name: "idx_code_progress_exercise")
  @@map("code_progress")
}

// ─── Web analytics — page views (added 2026-07-20) ───────────────
// One row per page view. Deliberately NOT one row per request: the
// site is a Next.js app, so most navigation is client-side and a
// server request log would miss it entirely — the client reports
// each route change instead.
//
// `sessionId` is a random id the browser keeps for the tab session.
// It is never linked to an identity and never leaves as-is: it
// exists so "3 pages by one person" doesn't read as 3 visitors.
// `isBot` rows are KEPT rather than dropped, so a traffic spike can
// be explained ("that was Googlebot") instead of silently inflating
// the numbers — every aggregate filters them out by default.
model PageView {
  id        Int      @id @default(autoincrement())
  path      String   @db.VarChar(500)
  // Page title as the client saw it — useful when a path is opaque.
  title     String?  @db.VarChar(300)
  referrer  String?  @db.VarChar(500)
  sessionId String   @map("session_id") @db.VarChar(64)
  userId    Int?     @map("user_id")
  // 'mobile' | 'tablet' | 'desktop', derived server-side from the UA.
  device    String?  @db.VarChar(16)
  isBot     Boolean  @default(false) @map("is_bot")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)], name: "idx_pageview_created_at")
  @@index([path, createdAt(sort: Desc)], name: "idx_pageview_path_time")
  @@index([sessionId], name: "idx_pageview_session")
  @@index([isBot, createdAt(sort: Desc)], name: "idx_pageview_bot_time")
  @@map("page_views")
}
