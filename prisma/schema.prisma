  structure      String   @db.Text // formula
  explanation    Json?    @db.JsonB // TipTap rich text (HTML string or JSON)
  examples       Json?    @db.JsonB // [{ sentence, pronunciation, meaningVi }]
  commonMistakes String?  @map("common_mistakes") @db.Text
  comparedWith   String?  @map("compared_with") @db.Text
  order          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@index([languageId, order], name: "idx_lang_grammar_points_lang")
  @@map("lang_grammar_points")
}

// ===== 4. LISTENING =====
model LangListeningItem {
  id          Int                 @id @default(autoincrement())
  languageId  Int                 @map("language_id")
  level       String?             @db.VarChar(20) // free-text level tag (A1..C2 | N5..N1 | HSK)
