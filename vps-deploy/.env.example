# ===============================================================
# CUONGHOANGDEV - VPS PRODUCTION ENVIRONMENT (NODE.JS STACK)
# Single VPS: 4GB RAM, 4 vCPU, Ubuntu 24.04
# Copy this file to /opt/cuonghoangdev/.env
# ===============================================================

# ===============================================================
# PUBLIC URLS
# ===============================================================
# Frontend public domain that users visit
FRONTEND_PUBLIC_URL=https://cuonghoangdev.com

# Backend/API public base URL
APP_BASE_URL=https://api.cuonghoangdev.com
NEXT_PUBLIC_API_URL=https://api.cuonghoangdev.com

# ===============================================================
# PERSISTENT DATA PATHS (host filesystem)
# ===============================================================
DATA_PATH=/opt/cuonghoangdev/data

# ===============================================================
# DATABASE (PostgreSQL 16 on VPS — local Docker)
# ===============================================================
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_VERY_SECURE_PASSWORD_2026!
DATABASE_URL=postgresql://postgres:CHANGE_THIS_TO_A_VERY_SECURE_PASSWORD_2026!@postgres:5432/cuonghoangdev_db?schema=public

# ===============================================================
# SECURITY
# ===============================================================
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS_LONG!
JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_SECOND_LONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS_LONG!
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_COOKIE_SECRET!

# ===============================================================
# REDIS
# ===============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ===============================================================
# FRONTEND / CORS
# ===============================================================
FRONTEND_URL=https://cuonghoangdev.com
ALLOWED_ORIGINS=https://cuonghoangdev.com,https://www.cuonghoangdev.com,https://api.cuonghoangdev.com
NEXTAUTH_URL=https://cuonghoangdev.com
AUTH_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_AUTH_SECRET!
AUTH_TRUST_HOST=true

# ===============================================================
# FILE STORAGE (local VPS only)
# ===============================================================
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_IMAGES=10485760
MAX_FILE_SIZE_AUDIO=104857600
MAX_FILE_SIZE_VIDEO=524288000
MAX_FILE_SIZE_DOCUMENT=52428800

# ===============================================================
# ADMIN
# ===============================================================
ADMIN_EMAILS=admin@cuonghoangdev.com
ADMIN_USERNAME=admin

# ===============================================================
# AI — Hugging Face DeepSeek R1
# ===============================================================
# Token: get from https://huggingface.co/settings/tokens
OPENROUTER_API_KEY=your-huggingface-token-here
AI_CHAT_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-32B
AI_EMBEDDING_MODEL=gemini-embedding-002
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7
AI_CHUNK_SIZE=1000
AI_CHUNK_OVERLAP=200
AI_SIMILARITY_THRESHOLD=0.7

# ===============================================================
# OAUTH2 — Google
# ===============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===============================================================
# OAUTH2 — GitHub
# ===============================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ===============================================================
# MAIL (optional)
# ===============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cuonghoangdev.com
CONTACT_ADMIN_EMAIL=admin@cuonghoangdev.com

# ===============================================================
# CI/CD
# ===============================================================
DOCKER_HUB_USERNAME=cuonghoangdev
